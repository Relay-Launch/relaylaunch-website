{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "/",
        "/services",
        "/complete-analysis",
        "/about",
        "/contact",
        "/how-we-work",
        "/blog",
        "/case-studies",
        "/case-studies/luxury-wellness-spa",
        "/case-studies/events-erp-migration",
        "/console",
        "/intake",
        "/privacy",
        "/terms"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:best-practices": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

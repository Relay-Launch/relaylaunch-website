---
import BaseLayout from '../components/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage, ogType, canonicalUrl, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} canonicalUrl={canonicalUrl} jsonLd={jsonLd}>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Nav />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</BaseLayout>

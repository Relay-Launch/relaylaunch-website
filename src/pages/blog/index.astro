---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
import { getPublishedPosts, formatDate } from '@/utils/blog';

const posts = await getPublishedPosts();
const webhookUrl = import.meta.env.PUBLIC_LEAD_MAGNET_WEBHOOK_URL || '#';
---

<Layout
  title="Blog | RelayLaunch | Small Business Infrastructure & Automation"
  description="Practical insights on digital infrastructure, automation, and operations for small businesses. From a team with Fortune 500 engineering experience."
  canonicalUrl="https://www.relaylaunch.com/blog/"
  breadcrumbs={[
    { name: 'Home', url: 'https://www.relaylaunch.com/' },
    { name: 'Blog', url: 'https://www.relaylaunch.com/blog/' },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'RelayLaunch Blog',
    description: 'Practical insights on digital infrastructure, automation, and operations for small businesses.',
    url: 'https://www.relaylaunch.com/blog/',
    publisher: {
      '@type': 'Organization',
      name: 'RelayLaunch LLC',
      url: 'https://www.relaylaunch.com',
    },
    author: {
      '@type': 'Person',
      name: 'Victor David Medina',
    },
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero-section">
    <div class="container">
      <span class="section-eyebrow">Blog</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px);">
        Insights on infrastructure,<br />automation, and growth.
      </h1>
      <p class="section-sub">
        Practical thinking on the systems, tools, and workflows that help small businesses
        run leaner and be seen more.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ POSTS -->
  <section class="section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card card">
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} class="post-hero" loading="lazy" />
              )}
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="badge badge-primary">{tag}</span>
                ))}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                {post.data.author && <span> · {post.data.author}</span>}
              </div>
              <span class="post-read-more">Read article →</span>
            </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ NEWSLETTER -->
  <section class="section newsletter-section">
    <div class="container">
      <div class="newsletter-card card" style="padding: var(--card-padding); border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-sm);">
        <div class="newsletter-inner">
          <div class="newsletter-text">
            <span class="section-eyebrow">Stay in the Loop</span>
            <h2 style="font-size: 22px; font-weight: 800; margin-bottom: 8px;">Get the Digital Readiness Assessment</h2>
            <p style="color: var(--color-muted); font-size: 15px; line-height: 1.6;">
              A 1-page checklist to see if your business has outgrown its current digital setup.
              Score yourself across 10 areas and find out where you're leaving time and money on the table.
            </p>
          </div>
          <div class="newsletter-form-wrap">
            <form id="blog-newsletter-form" class="newsletter-form" data-webhook={webhookUrl} novalidate>
              <div class="hp-field" aria-hidden="true"><label for="blog-website">Website</label><input type="text" id="blog-website" name="website" tabindex="-1" autocomplete="off" /></div>
              <div class="form-field">
                <input type="text" id="blog-name" name="name" required autocomplete="name" placeholder="Your name" />
              </div>
              <div class="form-field">
                <input type="email" id="blog-email" name="email" required autocomplete="email" placeholder="you@company.com" />
              </div>
              <Button type="submit" variant="primary" class="w-full justify-center">Get the Assessment →</Button>
              <p style="font-size: 12px; color: var(--color-muted); margin-top: 8px; text-align: center;">No spam. Unsubscribe anytime.</p>
            </form>
            <div id="blog-newsletter-success" class="newsletter-success" hidden>
              <p style="font-weight: 700; margin-bottom: 4px;">You're in.</p>
              <p style="color: var(--color-muted); font-size: 14px;">Check your inbox for the assessment.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title" style="font-size: clamp(22px, 3vw, 30px);">
        Want this kind of infrastructure for your business?
      </h2>
      <p class="section-sub" style="margin: 12px auto 28px; max-width: var(--container-xs);">
        Every engagement starts with a conversation. Tell us where you are.
        We'll figure out the right fit.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <Button variant="primary" href="/complete-analysis">Start with a Complete Analysis →</Button>
        <Button variant="outline" href="/services">View All Services</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-section { border-bottom: 1px solid var(--color-border); }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 32px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease,
                box-shadow 0.2s ease,
                transform 0.25s cubic-bezier(.22,1,.36,1);
  }

  .post-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-md);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .post-hero {
    width: 100%;
    border-radius: var(--radius-sm);
    margin-bottom: 16px;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .post-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

  .post-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .post-excerpt {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }

  .post-meta {
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 16px;
  }

  .post-read-more {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── Newsletter ── */
  .newsletter-section {
    background: var(--color-surface);
  }

  .newsletter-card {
    background: linear-gradient(135deg, var(--color-bg) 0%, color-mix(in srgb, var(--primary) 3%, var(--color-bg)) 100%);
  }

  .newsletter-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    align-items: center;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .newsletter-form input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 14px;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent);
  }

  @media (max-width: 768px) {
    .newsletter-inner { grid-template-columns: 1fr; gap: 24px; }
  }

  .cta-section { background: var(--color-surface); }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--color-muted);
    font-size: 16px;
  }
</style>

<script>
  const blogForm = document.getElementById('blog-newsletter-form') as HTMLFormElement | null;
  if (blogForm) {
    blogForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = blogForm.querySelector<HTMLInputElement>('[name="website"]');
      if (hp && hp.value) return;

      const webhookUrl = blogForm.dataset.webhook;
      if (!webhookUrl || webhookUrl === '#') return;

      const data = Object.fromEntries(new FormData(blogForm));
      delete data.website;

      try {
        await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, source: 'blog-newsletter' }),
        });
        blogForm.hidden = true;
        const success = document.getElementById('blog-newsletter-success');
        if (success) success.hidden = false;
      } catch {
        // Silently fail - form stays visible for retry
      }
    });
  }
</script>

---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title="Blog — RelayLaunch"
  description="Insights on small business infrastructure, automation, and digital operations from RelayLaunch."
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero-section">
    <div class="container">
      <span class="section-eyebrow">Blog</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px);">
        Insights on infrastructure,<br />automation, and growth.
      </h1>
      <p class="section-sub">
        Practical thinking on the systems, tools, and workflows that help small businesses
        run leaner and be seen more.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ POSTS -->
  <section class="section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <a href={`/blog/${post.id}`} class="post-card card">
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="badge badge-green">{tag}</span>
                ))}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <div class="post-meta">
                <time datetime={post.data.date}>{formattedDate}</time>
                {post.data.author && <span> · {post.data.author}</span>}
              </div>
              <span class="post-read-more">Read article →</span>
            </a>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title" style="font-size: clamp(22px, 3vw, 30px);">
        Want this kind of infrastructure for your business?
      </h2>
      <p class="section-sub" style="margin: 12px auto 28px; max-width: 480px;">
        Every engagement starts with a conversation. Tell us where you are —
        we'll figure out the right fit.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <Button variant="primary" href="/contact">Start a Project →</Button>
        <Button variant="outline" href="/services">View Services</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-section { border-bottom: 1px solid var(--color-border); }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 32px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .post-card:hover {
    border-color: var(--color-green);
    box-shadow: 0 0 0 1px var(--color-green);
    text-decoration: none;
  }

  .post-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

  .post-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .post-excerpt {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }

  .post-meta {
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 16px;
  }

  .post-read-more {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-green);
  }

  .cta-section { background: var(--color-surface); }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--color-muted);
    font-size: 16px;
  }
</style>

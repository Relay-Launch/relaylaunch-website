---
import { render } from 'astro:content';
import BlogPostLayout from '../../components/layouts/BlogPostLayout.astro';
import { getPublishedPosts, getReadingTime } from '@/utils/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `https://www.relaylaunch.com/blog/${post.id}/`;
const readingTime = post.body ? getReadingTime(post.body) : '1 min read';
---

<BlogPostLayout frontmatter={post.data} canonicalUrl={canonicalUrl} readingTime={readingTime}>
  <Content />
</BlogPostLayout>

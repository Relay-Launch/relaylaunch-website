---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
---

<Layout
  title="Contact | RelayLaunch"
  description="Start a project with RelayLaunch. Submit a project request or ask a quick question. We'll respond within 1–2 business days."
  canonicalUrl="https://www.relaylaunch.com/contact/"
  breadcrumbs={[
    { name: 'Home', url: 'https://www.relaylaunch.com/' },
    { name: 'Contact', url: 'https://www.relaylaunch.com/contact/' },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'RelayLaunch LLC',
    url: 'https://www.relaylaunch.com',
    email: 'hello@relaylaunch.com',
    description: 'Digital infrastructure consulting for small businesses. Website, automation, email, social, and unified dashboards.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Watertown',
      addressRegion: 'MA',
      addressCountry: 'US',
    },
    founder: { '@type': 'Person', name: 'Victor David Medina' },
    sameAs: ['https://github.com/Relay-Launch'],
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero">
    <div class="container">
      <span class="section-eyebrow">Get in Touch</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px);">
        Every engagement starts<br />with a conversation.
      </h1>
      <p class="section-sub">
        No commitment required. Tell us where you are and what you're trying to build.
        We'll figure out the right fit and move fast.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONTACT OPTIONS -->
  <section class="section">
    <div class="container contact-grid">

      <div class="contact-primary">
        <h2 class="section-title" style="font-size: 26px; margin-bottom: 8px;">Book a Discovery Call</h2>
        <p style="color: var(--color-muted); font-size: 15px; margin-bottom: 24px;">
          Pick a time that works for you. 30 minutes, no pitch, no commitment.
          We'll learn about your business and figure out if we're a fit.
        </p>
        <Button
          variant="primary"
          size="lg"
          data-cal-link="victor-medina-vh0z5e/30min"
          data-cal-config='{"layout":"month_view"}'
        >
          Pick a Time →
        </Button>

        <div class="divider-label">or send an email</div>

        <h2 class="section-title" style="font-size: 26px; margin-bottom: 8px;">Start a Project Request</h2>
        <p style="color: var(--color-muted); font-size: 15px; margin-bottom: 24px;">
          Tell us about your business and what you're looking to build. We'll respond within
          1–2 business days.
        </p>
        <Button
          variant="outline"
          href="mailto:hello@relaylaunch.com?subject=Project%20Request%20—%20RelayLaunch&body=Hi%20RelayLaunch%2C%0A%0AI%27d%20like%20to%20discuss%20a%20project.%20Here%27s%20a%20bit%20about%20my%20business%3A%0A%0ABusiness%20name%3A%20%0AIndustry%3A%20%0AWhat%20I%27m%20looking%20for%3A%20%0ACurrent%20tools%20I%20use%3A%20%0ABiggest%20pain%20point%3A%20%0A%0AThanks!"
          size="lg"
        >
          Send a Project Request →
        </Button>

        <div class="divider-label">or</div>

        <h2 class="section-title" style="font-size: 26px; margin-bottom: 8px;">Ask a Quick Question</h2>
        <p style="color: var(--color-muted); font-size: 15px; margin-bottom: 24px;">
          Not ready to submit a full request? Have a specific question? Just send us a quick email.
        </p>
        <Button
          variant="outline"
          href="mailto:hello@relaylaunch.com?subject=Quick%20Question%20—%20RelayLaunch"
          size="lg"
        >
          Ask a Quick Question
        </Button>

        <div class="divider-label">also available on github</div>

        <div class="github-options">
          <a href="https://github.com/Relay-Launch/.github/issues/new?template=project-request.yml" target="_blank" rel="noopener" class="github-link">
            <span class="github-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </span>
            Submit a project request on GitHub
          </a>
          <a href="https://github.com/Relay-Launch/.github/issues/new?template=quick-question.yml" target="_blank" rel="noopener" class="github-link">
            <span class="github-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </span>
            Ask a quick question on GitHub
          </a>
        </div>
      </div>

      <div class="contact-sidebar">
        <div class="card">
          <p class="section-eyebrow" style="margin-bottom: 16px;">What to Expect</p>
          <ol class="process-list">
            <li>
              <span class="step-num">1</span>
              <div>
                <strong>Pick a time</strong>
                <p>Choose a slot that works for you. You'll get a calendar invite instantly.</p>
              </div>
            </li>
            <li>
              <span class="step-num">2</span>
              <div>
                <strong>Discovery call</strong>
                <p>30–45 minutes. We learn your business, current tools, goals, and pain points.</p>
              </div>
            </li>
            <li>
              <span class="step-num">3</span>
              <div>
                <strong>Follow-up & proposal</strong>
                <p>After the call, we send a clear summary with scope, deliverables, timeline, and pricing.</p>
              </div>
            </li>
            <li>
              <span class="step-num">4</span>
              <div>
                <strong>Proposal + scoping</strong>
                <p>We send a clear proposal with scope, deliverables, timeline, and pricing. No surprises.</p>
              </div>
            </li>
          </ol>
        </div>

        <div class="card" style="margin-top: 16px; padding: 20px;">
          <p class="section-eyebrow" style="margin-bottom: 12px;">Direct Contact</p>
          <div class="direct-links">
            <a href="mailto:hello@relaylaunch.com" class="direct-link">
              <span class="direct-icon">✉</span> hello@relaylaunch.com
            </a>
            <a href="https://github.com/Relay-Launch" target="_blank" rel="noopener" class="direct-link">
              <span class="direct-icon">⬡</span> github.com/Relay-Launch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FAQ -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">FAQ</span>
      <h2 class="section-title" style="margin-bottom: 40px;">Common Questions</h2>

      <div class="faq-grid reveal-stagger">
        <div class="faq-item">
          <h3>What do I need to know before reaching out?</h3>
          <p>Not much. Tell us what business you run, what's frustrating you most, and roughly what you're hoping to change. That's enough to have a productive first conversation.</p>
        </div>
        <div class="faq-item">
          <h3>Do you only work with businesses that need a full build?</h3>
          <p>Not at all. The Complete Analysis is specifically designed for businesses that want clarity before committing. Some clients start there and handle the build themselves.</p>
        </div>
        <div class="faq-item">
          <h3>How long do projects take?</h3>
          <p>It depends on scope. A website build or automation setup can be turned around in a few weeks. A full operational infrastructure build is a multi-month engagement. We'll give you a realistic timeline upfront.</p>
        </div>
        <div class="faq-item">
          <h3>Do I need to keep paying after the build is done?</h3>
          <p>No. The Launch build delivers a self-running system. The Run retainer is for ongoing optimization, content, and growth, not for keeping the lights on. Your automations keep running whether or not you're on a retainer.</p>
        </div>
        <div class="faq-item">
          <h3>What industry do you focus on?</h3>
          <p>Any local or small business that serves clients directly: spas, wellness, trades, professional services, retail, restaurants, fitness, and more. The infrastructure problems are the same across industries.</p>
        </div>
        <div class="faq-item">
          <h3>Can you work with our existing tools?</h3>
          <p>Yes. If you have tools that work and just need to be connected, that's exactly what Systems Integration Consulting is for. We don't force a full replacement. We start with what you have.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero { padding-top: 80px; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 56px;
    align-items: start;
  }

  .contact-primary { display: flex; flex-direction: column; }

  .divider-label {
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--color-muted);
    font-size: 13px;
    font-weight: 600;
    margin: 32px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .divider-label::before,
  .divider-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Process list */
  .process-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .process-list li { display: flex; gap: 14px; align-items: flex-start; }

  .step-num {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .process-list strong { display: block; font-size: 14px; margin-bottom: 4px; }
  .process-list p { font-size: 13px; line-height: 1.6; }

  /* Direct links */
  .direct-links { display: flex; flex-direction: column; gap: 12px; }

  .direct-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .direct-link:hover { color: var(--color-text); text-decoration: none; }
  .direct-icon { font-style: normal; color: var(--color-primary); }

  /* FAQ */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .faq-item {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .faq-item:hover {
    border-color: color-mix(in srgb, var(--primary) 20%, var(--color-border));
    box-shadow: var(--shadow-sm);
  }

  .faq-item h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .faq-item p { font-size: 14px; line-height: 1.7; }

  /* GitHub secondary options */
  .github-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.2s ease;
  }

  .github-link:hover {
    color: var(--color-text);
    border-color: var(--color-muted);
    background: var(--color-bg);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .github-icon {
    display: flex;
    align-items: center;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .github-link:hover .github-icon { color: var(--color-text); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

</style>

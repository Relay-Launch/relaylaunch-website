    color: color-mix(in srgb, var(--color-white) 45%, transparent);
    background: color-mix(in srgb, var(--color-white) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-white) 8%, transparent);
    border-radius: 4px;
    padding: 2px 8px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .cc-agent-card:hover .cc-tag {
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
  }

  /* ── Dashboard Preview ── */
  .cc-preview-card {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--color-bg);
  }

  .cc-preview-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-navy);
    border-bottom: 1px solid color-mix(in srgb, var(--color-white) 10%, transparent);
  }

  .cc-preview-dots {
    display: flex;
    gap: 6px;
  }

  .cc-preview-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-white) 20%, transparent);
  }

  .cc-preview-dots span:first-child { background: color-mix(in srgb, #ff5f57 80%, transparent); }
  .cc-preview-dots span:nth-child(2) { background: color-mix(in srgb, #febc2e 80%, transparent); }
  .cc-preview-dots span:nth-child(3) { background: color-mix(in srgb, #28c840 80%, transparent); }

  .cc-preview-title {
    font-size: 12px;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
    letter-spacing: 0.3px;
  }

  .cc-preview-body {
    display: grid;
    grid-template-columns: 180px 1fr;
    min-height: 380px;
  }

  .cc-preview-sidebar {
    background: var(--color-navy);
    padding: 16px 0;
    border-right: 1px solid color-mix(in srgb, var(--color-white) 8%, transparent);
  }

  .cc-sidebar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
    transition: color 0.15s;
  }

  .cc-sidebar-active {
    color: var(--color-white);
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    border-left: 2px solid var(--color-primary);
  }

  .cc-sidebar-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .cc-sidebar-dot-dim {
    background: color-mix(in srgb, var(--color-white) 20%, transparent);
  }

  .cc-preview-main {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cc-preview-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .cc-preview-metric {
    padding: 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-align: center;
  }

  .cc-metric-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 4px;
  }

  .cc-metric-value {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .cc-preview-agents-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  .cc-preview-agent-status {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 4px;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .cc-pa-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .cc-pa-active { background: var(--color-primary); box-shadow: 0 0 6px color-mix(in srgb, var(--primary) 50%, transparent); }
  .cc-pa-monitoring { background: var(--color-primary); opacity: 0.6; }

  .cc-pa-name { font-size: 11px; font-weight: 700; color: var(--color-text); }
  .cc-pa-state { font-size: 10px; color: var(--color-muted); }

  .cc-preview-feed {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .cc-feed-item {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-size: 13px;
    color: var(--color-muted);
  }

  .cc-feed-time {
    font-size: 11px;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-muted) 70%, transparent);
    white-space: nowrap;
    min-width: 70px;
  }

  .cc-feed-msg strong { color: var(--color-primary); font-weight: 700; }

  /* ── Use Cases Grid ── */
  .cc-usecases-section { background: var(--color-surface); }

  .cc-usecase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cc-usecase-card {
    padding: 28px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .cc-usecase-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--primary) 40%, var(--color-border));
  }

  .cc-uc-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .cc-uc-icon svg { width: 22px; height: 22px; }
  .cc-usecase-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
  .cc-usecase-card p { font-size: 14px; color: var(--color-muted); line-height: 1.65; }

  /* ── Command Center Module ── */
  .cc-module-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .cc-module-card {
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .cc-mod-header {
    padding: 16px 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-navy);
    border-bottom: 2px solid var(--color-primary);
  }

  .cc-mod-list {
    padding: 8px 0;
  }

  .cc-mod-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s;
  }

  .cc-mod-item:last-child { border-bottom: none; }
  .cc-mod-item:hover { background: color-mix(in srgb, var(--primary) 4%, transparent); }

  .cc-mod-active {
    background: color-mix(in srgb, var(--primary) 5%, transparent);
    font-weight: 600;
  }

  .cc-mod-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .cc-mod-dot-building {
    background: color-mix(in srgb, var(--color-muted) 50%, transparent);
  }

  .cc-mod-badge {
    margin-left: auto;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    border-radius: 4px;
    padding: 2px 8px;
  }

  .cc-mod-badge-building {
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-muted) 10%, transparent);
    border-color: color-mix(in srgb, var(--color-muted) 25%, transparent);
  }

  /* ── Scroll Reveal ── */
  .scroll-hidden {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .scroll-hidden.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-stagger > .scroll-hidden:nth-child(1) { transition-delay: 0s; }
  .reveal-stagger > .scroll-hidden:nth-child(2) { transition-delay: 0.1s; }
  .reveal-stagger > .scroll-hidden:nth-child(3) { transition-delay: 0.2s; }
  .reveal-stagger > .scroll-hidden:nth-child(4) { transition-delay: 0.3s; }
  .reveal-stagger > .scroll-hidden:nth-child(5) { transition-delay: 0.4s; }
  .reveal-stagger > .scroll-hidden:nth-child(6) { transition-delay: 0.5s; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cc-agents-grid { grid-template-columns: 1fr; }
    .cc-usecase-grid { grid-template-columns: repeat(2, 1fr); }
    .cc-preview-row { grid-template-columns: repeat(2, 1fr); }
    .cc-preview-agents-row { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .cc-hero { padding-top: 72px; padding-bottom: 56px; }
    .cc-hero-headline { font-size: clamp(28px, 6vw, 42px); }

    .cc-flow {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .cc-flow-connector {
      transform: rotate(90deg);
      padding-top: 0;
      font-size: 20px;
    }

    .cc-agents-grid { grid-template-columns: 1fr; }
    .cc-agents-bg-grid { display: none; }
    .cc-hero-grid-bg { display: none; }

    .cc-preview-body {
      grid-template-columns: 1fr;
    }

    .cc-preview-sidebar {
      display: flex;
      overflow-x: auto;
      padding: 8px 12px;
      gap: 4px;
      border-right: none;
      border-bottom: 1px solid color-mix(in srgb, var(--color-white) 8%, transparent);
    }

    .cc-sidebar-item {
      white-space: nowrap;
      padding: 6px 12px;
      font-size: 12px;
      border-radius: var(--radius-sm);
    }

    .cc-sidebar-active {
      border-left: none;
      border-radius: var(--radius-sm);
    }

    .cc-preview-row { grid-template-columns: repeat(2, 1fr); }
    .cc-preview-agents-row { grid-template-columns: repeat(3, 1fr); }

    .cc-usecase-grid { grid-template-columns: 1fr; }

    .cc-module-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-actions { flex-direction: column; width: 100%; }
    .hero-actions :global(a) { width: 100%; justify-content: center; }
  }

  @media (max-width: 640px) {
    .cc-preview-row { grid-template-columns: 1fr; }
    .cc-preview-agents-row { grid-template-columns: repeat(2, 1fr); }
    .cc-feed-item { flex-direction: column; gap: 4px; }
    .cc-feed-time { min-width: auto; }
  }

  /* ── Launch badge ── */
  .cc-launch-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    border-radius: 40px;
    margin-bottom: 28px;
  }

  .cc-launch-badge-light {
    color: var(--color-white);
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .cc-launch-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 6px var(--color-primary);
    animation: cc-pulse 2s ease-in-out infinite;
  }

  @keyframes cc-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--color-primary); }
    50% { opacity: 0.4; box-shadow: 0 0 16px var(--color-primary); }
  }

  /* ── Hero stats ── */
  .cc-hero-stats {
    display: flex;
    align-items: center;
    gap: 28px;
    margin: 32px 0;
    padding: 20px 0;
    border-top: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
  }

  .cc-hero-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cc-hero-stat-number {
    font-size: 28px;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .cc-hero-stat-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
  }

  .cc-hero-stat-divider {
    width: 1px;
    height: 36px;
    background: color-mix(in srgb, var(--color-white) 15%, transparent);
  }

  /* ── Hero CTA buttons ── */
  .cc-hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 700;
    background: var(--color-primary);
    color: var(--color-white);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-md);
    text-decoration: none;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-primary) 40%, transparent);
    animation: cc-cta-glow 3s ease-in-out infinite;
    transition: all 0.3s cubic-bezier(.22,1,.36,1);
  }

  .cc-hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px color-mix(in srgb, var(--color-primary) 55%, transparent);
    text-decoration: none;
    color: var(--color-white);
    animation: none;
  }

  @keyframes cc-cta-glow {
    0%, 100% { box-shadow: 0 4px 20px color-mix(in srgb, var(--color-primary) 40%, transparent); }
    50% { box-shadow: 0 4px 32px color-mix(in srgb, var(--color-primary) 60%, transparent); }
  }

  .cc-hero-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 700;
    background: transparent;
    color: var(--color-primary);
    border: 2px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(.22,1,.36,1);
  }

  .cc-hero-btn-outline:hover {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border-color: var(--color-primary);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-primary);
  }

  .cc-btn-arrow {
    display: inline-flex;
    transition: transform 0.3s cubic-bezier(.22,1,.36,1);
    font-size: 18px;
  }

  .cc-hero-btn-primary:hover .cc-btn-arrow,
  .cc-hero-btn-outline:hover .cc-btn-arrow { transform: translateX(4px); }

  /* ── Floating particles ── */
  .cc-hero-particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  .cc-particle {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.3;
  }

  .cc-particle-1 { top: 20%; right: 15%; animation: cc-float-1 8s ease-in-out infinite; }
  .cc-particle-2 { top: 60%; right: 25%; animation: cc-float-2 12s ease-in-out infinite; opacity: 0.2; }
  .cc-particle-3 { top: 40%; right: 8%; animation: cc-float-1 10s ease-in-out infinite 2s; width: 2px; height: 2px; }
  .cc-particle-4 { top: 75%; right: 35%; animation: cc-float-2 9s ease-in-out infinite 1s; opacity: 0.15; }
  .cc-particle-5 { top: 15%; right: 30%; animation: cc-float-1 14s ease-in-out infinite 3s; width: 4px; height: 4px; opacity: 0.2; }

  @keyframes cc-float-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, -30px); }
  }
  @keyframes cc-float-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(15px, 25px); }
  }

  /* ── CTA section ── */
  .cc-cta-section {
    background: var(--color-navy);
    position: relative;
    overflow: hidden;
  }

  .cc-cta-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--primary) 4%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--primary) 4%, transparent) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, black 20%, transparent 100%);
    pointer-events: none;
  }

  .cc-cta-inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .cc-cta-urgency {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .cc-urgency-item {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.3px;
  }

  .cc-urgency-divider {
    color: color-mix(in srgb, var(--color-white) 30%, transparent);
  }

  /* ── Animations ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; opacity: 0; }

  @media (max-width: 768px) {
    .cc-hero-stats { gap: 20px; flex-wrap: wrap; }
    .cc-hero-stat-number { font-size: 22px; }
    .cc-hero-btn-primary,
    .cc-hero-btn-outline { width: 100%; justify-content: center; padding: 14px 24px; font-size: 15px; }
    .cc-cta-urgency { flex-direction: column; gap: 6px; }
    .cc-urgency-divider { display: none; }
    .cc-hero-particles { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cc-hero-grid-bg,
    .cc-hero-orb,
    .cc-agents-bg-grid,
    .cc-agents-orb { animation: none; }
    .cc-status-dot { animation: none; }
    .cc-launch-pulse { animation: none; }
    .cc-particle { animation: none; }
    .cc-hero-btn-primary { animation: none; }
  }

  /* ── Waitlist Block (Hero) ── */
  .cc-waitlist-block {
    max-width: 540px;
    text-align: left;
  }

  .cc-waitlist-badge-row {
    margin-bottom: 12px;
  }

  .cc-waitlist-badge {
    display: inline-block;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-primary);
    border-radius: 4px;
  }

  .cc-waitlist-headline {
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 10px;
  }

  .cc-waitlist-pitch {
    font-size: 15px;
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .cc-waitlist-form {
    max-width: 440px;
  }

  .cc-waitlist-fields {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .cc-waitlist-input {
    flex: 1;
    padding: 12px 16px;
    font-size: 14px;
    border: 1px solid color-mix(in srgb, var(--color-white) 20%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-white) 8%, transparent);
    color: var(--color-white);
    outline: none;
    min-width: 0;
  }

  .cc-waitlist-input::placeholder {
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
  }

  .cc-waitlist-input:focus {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-white) 12%, transparent);
  }

  .cc-waitlist-submit {
    width: 100%;
    padding: 14px 24px;
    font-size: 16px;
    font-weight: 700;
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .cc-waitlist-submit:hover {
    background: color-mix(in srgb, var(--color-primary) 85%, #000);
    transform: translateY(-1px);
  }

  .cc-waitlist-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .cc-waitlist-fine-print {
    font-size: 12px;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
    margin-top: 12px;
    line-height: 1.5;
  }

  .cc-waitlist-success {
    padding: 24px 0;
  }

  .cc-waitlist-success-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 8px;
  }

  .cc-waitlist-success-text {
    font-size: 15px;
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
    line-height: 1.55;
  }

  .cc-waitlist-error {

<script>
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal, .reveal-stagger > *').forEach(el => {
    el.classList.add('scroll-hidden');
    revealObserver.observe(el);
  });

  // ── Waitlist Form Handler ──
  const wlForm = document.getElementById('waitlist-form-cc') as HTMLFormElement;
  const wlSuccess = document.getElementById('waitlist-success-cc') as HTMLElement;
  const wlError = document.getElementById('waitlist-error-cc') as HTMLElement;

  wlForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    wlError.hidden = true;

    const nameInput = wlForm.querySelector('input[name="name"]') as HTMLInputElement;
    const emailInput = wlForm.querySelector('input[name="email"]') as HTMLInputElement;
    const name = nameInput?.value.trim();
    const email = emailInput?.value.trim();

    if (!name) { nameInput.focus(); nameInput.reportValidity(); return; }
    if (!email || !emailInput.validity.valid) { emailInput.focus(); emailInput.reportValidity(); return; }

    const submitBtn = wlForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalHTML = submitBtn?.innerHTML || '';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting\u2026';
    }

    // Check for honeypot - if filled, silently "succeed" to fool bots
    const honeypot = wlForm.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) {
      wlForm.hidden = true;
      wlSuccess.hidden = false;
      return;
    }

    const webhook = wlForm.dataset.webhook;
    if (!webhook || webhook === '#') {
      // Webhook not configured - show error instead of false promise
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHTML;
      }
      wlError.hidden = false;
      return;
    }

    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);

      const res = await fetch(webhook, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, source: 'control-center-waitlist', page: 'control-center' }),
        signal: controller.signal,
      });

      clearTimeout(timeoutId);
      if (!res.ok) throw new Error('Webhook error');

      wlForm.hidden = true;
      wlSuccess.hidden = false;
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHTML;
      }
      wlError.hidden = false;
    }
  });
</script>


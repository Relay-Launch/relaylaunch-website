---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const waitlistWebhookUrl = import.meta.env.PUBLIC_WAITLIST_WEBHOOK_URL || '#';
---

<Layout
  title="RelayLaunch Console | AI Agents & Unified Operations"
  description="142+ specialist AI agents. One unified dashboard. The RelayLaunch Console replaces scattered tools with an intelligent operations system that monitors, builds, protects, and grows your business."
  canonicalUrl="https://www.relaylaunch.com/console/"
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'RelayLaunch Console',
      description: 'AI-powered operations platform with 142+ specialist agents across BMAD, Agency, and Superpowers frameworks for infrastructure, security, content, growth, brand, and development.',
      url: 'https://www.relaylaunch.com/console',
    },
  ]}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="cc-hero section">
    <div class="cc-hero-grid-bg" aria-hidden="true"></div>
    <div class="cc-hero-orb cc-hero-orb-1" aria-hidden="true"></div>
    <div class="cc-hero-orb cc-hero-orb-2" aria-hidden="true"></div>
    <div class="cc-hero-particles" aria-hidden="true">
      <span class="cc-particle cc-particle-1"></span>
      <span class="cc-particle cc-particle-2"></span>
      <span class="cc-particle cc-particle-3"></span>
      <span class="cc-particle cc-particle-4"></span>
      <span class="cc-particle cc-particle-5"></span>
    </div>
    <div class="container">
      <div class="cc-hero-content">
        <div class="cc-launch-badge animate-fade-in-up">
          <span class="cc-launch-pulse"></span>
          Early Preview
        </div>
        <h1 class="cc-hero-headline animate-fade-in-up" style="animation-delay: 0.1s;">
          142+ AI agents.<br />
          <span class="text-accent">One intelligent console.</span>
        </h1>
        <p class="cc-hero-sub animate-fade-in-up" style="animation-delay: 0.2s;">
          We built this for ourselves first. 142+ specialist AI agents across three
          frameworks — BMAD, Agency, and Superpowers — handling infrastructure,
          security, content, growth, brand, sales, and engineering. Now we're opening
          it to clients. One console, every agent coordinated, your business on autopilot.
        </p>
        <div class="cc-hero-stats animate-fade-in-up" style="animation-delay: 0.3s;">
          <div class="cc-hero-stat">
            <span class="cc-hero-stat-number">142+</span>
            <span class="cc-hero-stat-label">Specialist Agents</span>
          </div>
          <div class="cc-hero-stat-divider"></div>
          <div class="cc-hero-stat">
            <span class="cc-hero-stat-number">3</span>
            <span class="cc-hero-stat-label">AI Frameworks</span>
          </div>
          <div class="cc-hero-stat-divider"></div>
          <div class="cc-hero-stat">
            <span class="cc-hero-stat-number">24/7</span>
            <span class="cc-hero-stat-label">Autonomous Ops</span>
          </div>
          <div class="cc-hero-stat-divider"></div>
          <div class="cc-hero-stat">
            <span class="cc-hero-stat-number">1</span>
            <span class="cc-hero-stat-label">Unified Console</span>
          </div>
        </div>
        <div class="cc-waitlist-block animate-fade-in-up" style="animation-delay: 0.4s;">
          <h3 class="cc-waitlist-headline">We're bringing on the first group now.</h3>
          <p class="cc-waitlist-pitch">
            We're testing the RelayLaunch Console with a small number of business
            owners before opening it wider. If you want early access, put your
            name in and we'll reach out.
          </p>
          <form id="waitlist-form-cc" class="cc-waitlist-form" data-webhook={waitlistWebhookUrl} novalidate>
            <div class="hp-field" aria-hidden="true"><label for="cc-website">Website</label><input type="text" id="cc-website" name="website" tabindex="-1" autocomplete="off" /></div>
            <div class="cc-waitlist-fields">
              <label for="waitlist-name-cc" class="sr-only">Name</label>
              <input type="text" id="waitlist-name-cc" name="name" required autocomplete="name" placeholder="Your name" class="cc-waitlist-input" />
              <label for="waitlist-email-cc" class="sr-only">Email address</label>
              <input type="email" id="waitlist-email-cc" name="email" required autocomplete="email" placeholder="you@company.com" class="cc-waitlist-input" />
            </div>
            <button type="submit" class="cc-waitlist-submit">Join the Waitlist <span>&rarr;</span></button>
            <p class="cc-waitlist-fine-print">*Early Preview slots are limited and granted on a rolling basis. No commitment required.</p>
          </form>
          <div id="waitlist-success-cc" class="cc-waitlist-success" role="status" aria-live="polite" hidden>
            <p class="cc-waitlist-success-title">You're in.</p>
            <p class="cc-waitlist-success-text">We're reviewing waitlist requests now and will reach out when your preview access is ready.</p>
          </div>
          <div id="waitlist-error-cc" class="cc-waitlist-error" role="alert" aria-live="assertive" hidden>
            <p class="cc-waitlist-error-text">Something went wrong. Please try again.</p>
          </div>
        </div>
        <div class="hero-actions animate-fade-in-up" style="animation-delay: 0.5s;">
          <a href="#how-it-works" class="cc-hero-btn-outline">See How It Works <span class="cc-btn-arrow">&darr;</span></a>
        </div>
        <p class="cc-hero-proof animate-fade-in-up" style="animation-delay: 0.55s;">
          Already running our own operations. Launching to clients March 2026.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ HOW IT WORKS OVERVIEW -->
  <section class="section" id="how-it-works">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">How It Works</span>
        <h2 class="section-title">One system. Six agents. You stay in the loop without doing the work.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          Each agent has a specific job. They run on their own, coordinate with
          each other, and report back to a single dashboard. You see what matters
          without logging into eight different tools.
        </p>
      </div>

      <div class="cc-flow reveal-stagger">
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>You define the mission</h3>
          <p>Tell us your goals, constraints, and priorities. We configure your agents to match your business.</p>
        </div>
        <div class="cc-flow-connector" aria-hidden="true">→</div>
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          </div>
          <h3>Agents activate</h3>
          <p>Each agent starts monitoring and operating in its domain — infrastructure, security, content, growth, brand, and code.</p>
        </div>
        <div class="cc-flow-connector" aria-hidden="true">→</div>
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3>You see one dashboard</h3>
          <p>All agent activity, alerts, metrics, and recommendations surface to a single view. Your business briefs you — not the other way around.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ THE SIX AGENTS -->
  <section class="section cc-agents-section">
    <div class="cc-agents-bg-grid" aria-hidden="true"></div>
    <div class="cc-agents-orb cc-agents-orb-1" aria-hidden="true"></div>
    <div class="cc-agents-orb cc-agents-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow" style="color: var(--color-primary);">The Agent Roster — 142+ Specialists</span>
        <h2 class="section-title" style="color: var(--color-white);">Not six agents. An entire company working for yours.</h2>
        <p class="section-sub" style="color: color-mix(in srgb, var(--color-white) 70%, transparent); margin-bottom: 24px;">
          Every agent is a specialist — built on BMAD, Agency, and Superpowers frameworks,
          trained on real workflows, and coordinated through one console. Six lead agents
          run the day-to-day. Behind them: 142+ specialists handling content, sales,
          security, growth, brand, SEO, outreach, data modeling, and more.
        </p>
        <div style="display: flex; gap: 32px; justify-content: center; margin-bottom: 48px; flex-wrap: wrap;">
          <div style="text-align: center;">
            <div style="font-size: 28px; font-weight: 800; color: var(--color-primary);">142+</div>
            <div style="font-size: 12px; color: color-mix(in srgb, var(--color-white) 50%, transparent); text-transform: uppercase; letter-spacing: 1px;">Total Agents</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 28px; font-weight: 800; color: var(--color-white);">25+</div>
            <div style="font-size: 12px; color: color-mix(in srgb, var(--color-white) 50%, transparent); text-transform: uppercase; letter-spacing: 1px;">Specialties</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 28px; font-weight: 800; color: var(--color-white);">3</div>
            <div style="font-size: 12px; color: color-mix(in srgb, var(--color-white) 50%, transparent); text-transform: uppercase; letter-spacing: 1px;">AI Frameworks</div>
          </div>
        </div>
      </div>

      <div class="cc-agents-grid reveal-stagger">
        <!-- Infrastructure Command -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-infra">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
              <circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/>
              <line x1="12" y1="6" x2="18" y2="6"/><line x1="12" y1="18" x2="18" y2="18"/>
            </svg>
          </div>
          <div class="cc-agent-count">18 agents</div>
          <h3>Infrastructure Command</h3>
          <p class="cc-agent-role">DNS, hosting, CI/CD, uptime, architecture</p>
          <p class="cc-agent-desc">Enterprise-grade infrastructure at small business cost. DNS, hosting, deployments, and architecture — all managed by specialist agents that keep your site fast, secure, and always online.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>DevOps Engineer, Cloud Architect, Site Reliability</li>
              <li>DNS Manager, SSL/CDN Optimizer, CI/CD Pipeline</li>
              <li>Performance Monitor, Uptime Sentinel</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">BMAD</span>
            <span class="cc-tag">Agency</span>
            <span class="cc-tag">/infra</span>
          </div>
        </div>

        <!-- Security Division -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot cc-status-dot-alert"></span>Monitoring</div>
          <div class="cc-agent-icon cc-icon-security">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <div class="cc-agent-count">14 agents</div>
          <h3>Security Division</h3>
          <p class="cc-agent-role">Threat detection, vulnerability scanning, compliance</p>
          <p class="cc-agent-desc">Every code change scanned. Every dependency audited. Every header locked down. Your customers never see the threats because our agents catch them first.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>Vulnerability Scanner, Secret Detector, CSP Enforcer</li>
              <li>Dependency Auditor, Penetration Tester</li>
              <li>Compliance Monitor, Incident Responder</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">BMAD</span>
            <span class="cc-tag">Superpowers</span>
            <span class="cc-tag">/security</span>
          </div>
        </div>

        <!-- Engineering Corps -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-build">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              <line x1="14" y1="4" x2="10" y2="20"/>
            </svg>
          </div>
          <div class="cc-agent-count">28 agents</div>
          <h3>Engineering Corps</h3>
          <p class="cc-agent-role">Full-stack development, QA, code review</p>
          <p class="cc-agent-desc">Features ship. Bugs get fixed. Code stays clean. A full engineering team that builds, reviews, and deploys — maintaining Lighthouse 95+ and sub-second loads.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>Frontend Dev, Backend Architect, Full-Stack Builder</li>
              <li>QA Engineer, Code Reviewer, Data Modeler</li>
              <li>API Designer, Sprint Planner, Technical Writer</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">BMAD</span>
            <span class="cc-tag">Agency</span>
            <span class="cc-tag">Superpowers</span>
          </div>
        </div>

        <!-- Content Studio -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-content">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div class="cc-agent-count">32 agents</div>
          <h3>Content Studio</h3>
          <p class="cc-agent-role">Blog, social, email, SEO, copywriting</p>
          <p class="cc-agent-desc">Your audience hears from you consistently — blog posts, social content, email sequences, SEO-optimized pages — all written in your voice and published on schedule.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>Blog Writer, Social Strategist, Email Marketer</li>
              <li>SEO Specialist, Copywriter, Content Planner</li>
              <li>Editorial Director, Brand Voice Coach</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">Agency</span>
            <span class="cc-tag">Superpowers</span>
            <span class="cc-tag">/content</span>
          </div>
        </div>

        <!-- Growth Engine -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-growth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <div class="cc-agent-count">30 agents</div>
          <h3>Growth Engine</h3>
          <p class="cc-agent-role">Acquisition, conversion, outreach, revenue</p>
          <p class="cc-agent-desc">Finds where leads drop off, tests what converts, qualifies prospects, and tracks revenue opportunities. Growth backed by data, not guesswork.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>Growth Hacker, Conversion Optimizer, Ad Strategist</li>
              <li>Outreach Coordinator, Lead Qualifier, Deal Strategist</li>
              <li>Analytics Analyst, Proposal Writer, Pipeline Manager</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">Agency</span>
            <span class="cc-tag">Superpowers</span>
            <span class="cc-tag">/growth</span>
          </div>
        </div>

        <!-- Brand & Design Lab -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot cc-status-dot-alert"></span>Monitoring</div>
          <div class="cc-agent-icon cc-icon-brand">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <div class="cc-agent-count">20 agents</div>
          <h3>Brand &amp; Design Lab</h3>
          <p class="cc-agent-role">Brand identity, UI/UX, visual consistency</p>
          <p class="cc-agent-desc">Your brand looks and sounds the same everywhere. Colors, fonts, voice, visual identity — enforced across every touchpoint, every deployment, every piece of content.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">Specialist agents include:</p>
            <ul>
              <li>Brand Guardian, UI Designer, UX Researcher</li>
              <li>Visual QA, Accessibility Auditor, Style Enforcer</li>
              <li>Design System Manager, Voice Consistency Checker</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/brand</span>
            <span class="cc-tag">/audit</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONTROL CENTER PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">The Dashboard</span>
        <h2 class="section-title">One screen. Complete visibility.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          The RelayLaunch Console is a unified dashboard where all agents report.
          Instead of logging into eight different tools, you open one view and see
          everything — builds deploying, content publishing, security scanning,
          growth tracking, and brand compliance — all in real time.
        </p>
      </div>

      <div class="cc-preview-card reveal">
        <div class="cc-preview-header">
          <div class="cc-preview-dots">
            <span></span><span></span><span></span>
          </div>
          <span class="cc-preview-title">RelayLaunch Console</span>
        </div>
        <div class="cc-preview-body">
          <div class="cc-preview-sidebar">
            <div class="cc-sidebar-item cc-sidebar-active">
              <span class="cc-sidebar-dot"></span> Dashboard
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Agents
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Workflows
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Content
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Analytics
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Settings
            </div>
          </div>
          <div class="cc-preview-main">
            <div class="cc-preview-row">
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Uptime</div>
                <div class="cc-metric-value">99.98%</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Deploys Today</div>
                <div class="cc-metric-value">4</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Security Score</div>
                <div class="cc-metric-value">A+</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Brand Compliance</div>
                <div class="cc-metric-value">100%</div>
              </div>
            </div>
            <div class="cc-preview-agents-row">
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Infra</span>
                <span class="cc-pa-state">Deploying</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-monitoring"></span>
                <span class="cc-pa-name">Security</span>
                <span class="cc-pa-state">Scanning</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Build</span>
                <span class="cc-pa-state">PR Review</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Content</span>
                <span class="cc-pa-state">Publishing</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Growth</span>
                <span class="cc-pa-state">Tracking</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-monitoring"></span>
                <span class="cc-pa-name">Brand</span>
                <span class="cc-pa-state">Watching</span>
              </div>
            </div>
            <div class="cc-preview-feed">
              <div class="cc-feed-item">
                <span class="cc-feed-time">2 min ago</span>
                <span class="cc-feed-msg"><strong>Build Agent</strong> deployed v2.4.1 to production</span>
              </div>
              <div class="cc-feed-item">
                <span class="cc-feed-time">14 min ago</span>
                <span class="cc-feed-msg"><strong>Content Agent</strong> published blog post: "5 Signs Your Tools Are Costing You"</span>
              </div>
              <div class="cc-feed-item">
                <span class="cc-feed-time">1 hr ago</span>
                <span class="cc-feed-msg"><strong>Security Agent</strong> completed dependency audit — 0 vulnerabilities found</span>
              </div>
              <div class="cc-feed-item">

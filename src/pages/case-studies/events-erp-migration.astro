---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
---

<Layout
  title="Global Events Company ERP Migration Case Study | RelayLaunch"
  description="How RelayLaunch architected a 6-month QuickBooks-to-Sage Intacct migration for a global events company with three US entities, multi-currency consolidation, and a 10-day close cycle."
  canonicalUrl="https://www.relaylaunch.com/case-studies/events-erp-migration/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'ERP Migration & Systems Integration Consulting',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'Multi-entity ERP migration from QuickBooks to Sage Intacct with consolidated financial reporting.',
    areaServed: 'US',
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero">
    <div class="container">
      <a href="/case-studies" class="back-link">← Case Studies</a>
      <div class="cs-meta">
        <span class="badge badge-primary">Events & Trade Shows / Finance Systems</span>
        <span class="cs-location">Multi-Entity · US + UK Operations</span>
      </div>
      <h1 class="hero-headline">
        Three siloed QuickBooks instances.<br />
        <span class="text-accent">One unified Sage Intacct environment.</span>
      </h1>
      <p class="hero-sub">
        A global events and trade show company needed to migrate three US subsidiaries from
        QuickBooks to Sage Intacct, with multi-entity consolidation, multi-currency reporting,
        and a 10-day close cycle. Their UK parent had frozen further acquisitions until financial
        infrastructure was modernized.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ HEADLINE STATS -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <div class="stat-number accent">3 → 1</div>
        <div class="stat-label">siloed systems → unified platform</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">15+ → 10</div>
        <div class="stat-label">day close cycle reduced</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">7</div>
        <div class="stat-label">enterprise deliverables</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">6 months</div>
        <div class="stat-label">structured migration program</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CLIENT -->
  <section class="section">
    <div class="container two-col">
      <div>
        <span class="section-eyebrow">The Client</span>
        <h2 class="section-title" style="font-size: clamp(24px, 3vw, 36px);">Global Events & Trade Show Company</h2>
        <p style="color: var(--color-muted); font-size: 15px; line-height: 1.75; margin-top: 16px;">
          This client operates multiple US entities acquired over recent years under a UK-based
          parent company. Their business spans the trade show and events industry, managing
          complex revenue streams: booth sales, sponsorships, registrations, and
          media partnerships.
        </p>
        <p style="color: var(--color-muted); font-size: 15px; line-height: 1.75; margin-top: 16px;">
          Each entity was running its own independent QuickBooks instance with cash-basis
          accounting. The UK parent required accrual-basis, multi-currency (USD→GBP) consolidated
          reporting, and had blocked further US acquisitions until the financial infrastructure
          was upgraded.
        </p>
      </div>

      <div class="card before-card">
        <p class="section-eyebrow" style="margin-bottom: 16px;">Before RelayLaunch</p>
        <table class="rl-table">
          <thead>
            <tr>
              <th>Problem Area</th>
              <th>Impact</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>3 siloed QuickBooks instances</td>
              <td>No consolidation capability</td>
            </tr>
            <tr>
              <td>Cash-basis financials only</td>
              <td>Can't meet UK GAAP/IFRS requirements</td>
            </tr>
            <tr>
              <td>No multi-currency translation</td>
              <td>USD→GBP reporting impossible</td>
            </tr>
            <tr>
              <td>15+ day month-end close</td>
              <td>Manual processes, no quality gates</td>
            </tr>
            <tr>
              <td>No deferred revenue tracking</td>
              <td>ASC 606 compliance gap</td>
            </tr>
            <tr>
              <td><strong>Result</strong></td>
              <td><strong>Acquisitions frozen by parent</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ THE PROBLEM -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">The Problem</span>
      <h2 class="section-title">Three systems. Zero consolidation. Acquisitions frozen.</h2>
      <div class="problem-grid">
        <div class="problem-item">
          <div class="problem-icon">🔀</div>
          <h3>Siloed Data</h3>
          <p>Three separate QuickBooks instances with no consolidation capability. Each entity operated independently, with no unified view of financial performance across the organization.</p>
        </div>
        <div class="problem-item">
          <div class="problem-icon">📋</div>
          <h3>Compliance Gap</h3>
          <p>Cash-basis financials that didn't meet UK GAAP/IFRS parent reporting requirements. No multi-currency translation. No deferred revenue tracking for ASC 606 compliance.</p>
        </div>
        <div class="problem-item">
          <div class="problem-icon">🕐</div>
          <h3>15+ Day Close</h3>
          <p>Month-end close exceeded 15 business days with manual processes, no quality gates, and no RACI assignments. Decision-quality data arrived too late to act on.</p>
        </div>
        <div class="problem-item">
          <div class="problem-icon">🚫</div>
          <h3>Growth Blocked</h3>
          <p>UK parent had frozen all further US acquisitions until financial infrastructure was modernized. Every month without migration was a month of stalled growth.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ APPROACH -->
  <section class="section">
    <div class="container">
      <span class="section-eyebrow">The Approach</span>
      <h2 class="section-title">Two-Lane Delivery Model.<br />Architecture separated from execution.</h2>
      <p class="section-sub" style="margin-bottom: 48px;">
        The previous attempt failed because it tried to combine systems architecture with
        day-to-day accounting in one role. RelayLaunch introduced a Two-Lane Delivery Model
        that separates the architect from the executor, with clear boundaries and accountability.
      </p>

      <div class="lanes-grid">
        <div class="card lane-card">
          <div class="lane-label">Lane A: Executor</div>
          <h3>Controller / Staff Accountant</h3>
          <p>Day-to-day transactions, book cleanup, close execution, bank reconciliations, journal entries. Stays as a permanent finance team member.</p>
        </div>
        <div class="card lane-card featured-lane">
          <div class="lane-label accent-label">Lane B: Architect (RelayLaunch)</div>
          <h3>Systems Integration Consultant</h3>
          <p>Target-state design, migration governance, integration architecture, SOPs, quality gates, handoff. Transitions out after 6-month program completion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ DELIVERABLES -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">The Deliverables</span>
      <h2 class="section-title">7 enterprise deliverables.<br />6-month structured program.</h2>

      <div class="deliverables-grid">
        <div class="card deliverable-card">
          <div class="del-icon">🏗️</div>
          <h3>Target-State Architecture</h3>
          <p>Entity structure, dimensional Chart of Accounts, UK consolidation alignment. Fewer base accounts, richer dimensional tagging for flexible reporting.</p>
          <div class="del-num">01</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">🔗</div>
          <h3>Integration Blueprint</h3>
          <p>API contracts, data flows, and exception handling for all upstream systems: event platforms, payment processing, and internal tools.</p>
          <div class="del-num">02</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">📊</div>
          <h3>Migration Mapping Workbook</h3>
          <p>Field-level mapping from every QuickBooks account to Sage Intacct dimensions, with transformation rules and reconciliation evidence.</p>
          <div class="del-num">03</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">📅</div>
          <h3>10-Day Close Calendar</h3>
          <p>Day-by-day close schedule with RACI assignments, cutoff rules, and quality gates. Reverse-engineered from the UK reporting deadline.</p>
          <div class="del-num">04</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">📝</div>
          <h3>SOPs & Runbooks</h3>
          <p>Step-by-step procedures for every close task, journal entry type, and reconciliation. Nothing left undocumented.</p>
          <div class="del-num">05</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">🚀</div>
          <h3>Go-Live Cutover Plan</h3>
          <p>Phased 3-wave strategy: pilot one entity first, prove the architecture, then scale. Rollback triggers and acceptance criteria at every gate.</p>
          <div class="del-num">06</div>
        </div>
        <div class="card deliverable-card">
          <div class="del-icon">📦</div>
          <h3>Handoff Bundle</h3>
          <p>Admin guide, training materials, and 8-day close roadmap. The team operates independently from day one after handoff.</p>
          <div class="del-num">07</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ ROADMAP -->
  <section class="section">
    <div class="container">
      <span class="section-eyebrow">The Roadmap</span>
      <h2 class="section-title">6 months. 3 migration waves.<br />9 quality gates.</h2>

      <div class="roadmap">
        <div class="roadmap-item">
          <div class="roadmap-month">Month 1</div>
          <div class="roadmap-content">
            <h3>Discovery & Design</h3>
            <p>Current-state assessment across all 3 entities. Data quality profiling. UK reporting requirements mapping. Target-state architecture approved.</p>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-month">Month 2</div>
          <div class="roadmap-content">
            <h3>Architecture & Mapping</h3>
            <p>Field-level mapping workbook built. Integration blueprint documented. Close calendar designed. Every account mapped to its Intacct destination.</p>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-month">Month 3</div>
          <div class="roadmap-content">
            <h3>Pilot Migration, Wave 1</h3>
            <p>First entity goes live in Sage Intacct. Architecture proven. Reconciliation evidence generated. Lessons learned applied to Waves 2 and 3.</p>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-month">Month 4</div>
          <div class="roadmap-content">
            <h3>Wave 2 & Hardening</h3>
            <p>Second entity migrated. Close process hardened. Controls implemented. Consolidation tested. First USD→GBP translation report produced.</p>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-month">Month 5</div>
          <div class="roadmap-content">
            <h3>Wave 3 & First 10-Day Close</h3>
            <p>All three entities live. First full 10-day close achieved. KPI dashboard built. Consolidated report delivered to UK parent by Day 12.</p>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-month">Month 6</div>
          <div class="roadmap-content">
            <h3>Stabilization & Handoff</h3>
            <p>Hypercare support. Team training. Complete handoff bundle delivered. 8-day close roadmap for continued optimization. Team operates independently.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ METHODOLOGY -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">The Methodology</span>
      <h2 class="section-title">Engineering-grade project delivery<br />applied to finance systems.</h2>

      <div class="method-grid">
        <div class="method-item">
          <h3>Phase-Gated Delivery</h3>
          <p>9 quality gates govern the entire program. Each with specific acceptance criteria, responsible parties, and rollback triggers. No gate is passed without documented evidence.</p>
        </div>
        <div class="method-item">
          <h3>Automated Testing</h3>
          <p>Custom-built automation pipelines run data integrity checks at every transformation step. Reconciliation evidence generated automatically, not manually in spreadsheets.</p>
        </div>
        <div class="method-item">
          <h3>Change Control</h3>
          <p>Every decision logged. Every scope change assessed for timeline impact. Every migration has a rollback procedure. Cloud infrastructure rigor applied to ERP migration.</p>
        </div>
        <div class="method-item">
          <h3>Wave Strategy</h3>
          <p>Prove the architecture on one entity before scaling. Each wave follows a repeatable playbook: extract, transform, load, reconcile, accept. Lessons learned cascade forward.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">This is systems integration at scale.</h2>
      <p class="section-sub" style="margin: 16px auto 32px; max-width: 560px;">
        Whether you need an ERP migration, multi-entity consolidation, or a structured
        approach to replacing disconnected systems, RelayLaunch brings engineering-grade
        methodology to complex business problems.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <Button variant="primary" href="/contact">Start Your Project →</Button>
        <Button variant="outline" href="/services">See All Services</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero { padding-top: 80px; }

  .back-link {
    display: inline-block;
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-text); text-decoration: none; }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .cs-location {
    font-size: 14px;
    color: var(--color-muted);
  }

  .hero-headline {
    font-size: clamp(30px, 4.5vw, 52px);
    font-weight: 800;
    margin-bottom: 24px;
    max-width: 800px;
    line-height: 1.1;
  }

  .text-accent { color: var(--color-primary); }

  .hero-sub {
    font-size: 17px;
    color: var(--color-muted);
    max-width: 640px;
    line-height: 1.7;
  }

  /* Stats bar */
  .stats-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 36px 0;
  }
  .stats-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
  }
  .stat { text-align: center; flex: 1; padding: 16px; }
  .stat-divider { width: 1px; height: 48px; background: var(--color-border); flex-shrink: 0; }
  .stat-number.accent { color: var(--color-primary); }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .before-card { padding: 24px; }

  /* Problem grid */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }
  .problem-item {
    padding: 24px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .problem-icon { font-size: 28px; margin-bottom: 12px; }
  .problem-item h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .problem-item p { font-size: 14px; line-height: 1.65; }

  /* Lanes grid */
  .lanes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .lane-card { padding: 28px; }
  .lane-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }
  .accent-label { color: var(--color-primary); }
  .lane-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .lane-card p { font-size: 14px; line-height: 1.65; color: var(--color-muted); }
  .featured-lane {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  /* Deliverables grid */
  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }
  .deliverable-card { padding: 24px; position: relative; }
  .del-icon { font-size: 24px; margin-bottom: 10px; }
  .deliverable-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .deliverable-card p { font-size: 14px; line-height: 1.6; }
  .del-num {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--color-primary);
    opacity: 0.5;
  }

  /* Roadmap */
  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 40px;
  }
  .roadmap-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }
  .roadmap-item:last-child { border-bottom: none; }
  .roadmap-month {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    padding-top: 2px;
  }
  .roadmap-content h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .roadmap-content p { font-size: 14px; line-height: 1.65; color: var(--color-muted); }

  /* Methodology grid */
  .method-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }
  .method-item {
    padding: 24px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .method-item h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .method-item p { font-size: 14px; line-height: 1.65; color: var(--color-muted); }

  @media (max-width: 900px) {
    .two-col, .lanes-grid { grid-template-columns: 1fr; }
    .stats-grid { flex-wrap: wrap; }
    .stat-divider { display: none; }
    .stat { border-bottom: 1px solid var(--color-border); flex: 0 0 50%; }
    .stat:last-child, .stat:nth-last-child(2):nth-child(odd) { border-bottom: none; }
    .roadmap-item { grid-template-columns: 1fr; gap: 8px; }
  }
</style>

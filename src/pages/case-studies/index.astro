---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
---

<Layout
  title="Case Studies | RelayLaunch | Real Infrastructure Results for Small Business"
  description="Real results for real businesses. See how RelayLaunch cut tool costs from $342 to $51/month, migrated enterprise ERP systems, and built connected infrastructure that pays for itself."
  canonicalUrl="https://www.relaylaunch.com/case-studies/"
  breadcrumbs={[
    { name: 'Home', url: 'https://www.relaylaunch.com/' },
    { name: 'Case Studies', url: 'https://www.relaylaunch.com/case-studies/' },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'RelayLaunch Case Studies',
    description: 'Real results for real businesses. Digital infrastructure builds, automation deployments, and enterprise system migrations.',
    url: 'https://www.relaylaunch.com/case-studies/',
    publisher: {
      '@type': 'Organization',
      name: 'RelayLaunch LLC',
      url: 'https://www.relaylaunch.com',
    },
    hasPart: [
      {
        '@type': 'Article',
        name: 'Luxury Wellness Spa: Tool Cost Reduction & Infrastructure Build',
        url: 'https://www.relaylaunch.com/case-studies/luxury-wellness-spa/',
        description: 'How RelayLaunch replaced $342/month in disconnected tools with $51/month in unified infrastructure for a luxury wellness spa.',
      },
      {
        '@type': 'Article',
        name: 'Global Events Company: ERP Migration',
        url: 'https://www.relaylaunch.com/case-studies/events-erp-migration/',
        description: 'QuickBooks-to-Sage Intacct migration for a global events company with three US entities and multi-currency consolidation.',
      },
    ],
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero-section">
    <div class="container">
      <p class="section-eyebrow">Proof of Work</p>
      <h1 class="section-title">Case Studies</h1>
      <p class="section-sub">
        Every engagement is documented. Real numbers, real clients, real before-and-after.
        No stock photography. No fabricated testimonials.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CASE STUDY CARDS -->
  <section class="section cards-section">
    <div class="container">

      <a href="/case-studies/luxury-wellness-spa" class="cs-card card reveal">
        <div class="cs-card-header">
          <div class="cs-meta">
            <span class="badge badge-primary">Wellness / Hospitality</span>
            <span class="cs-location">Five-Star Resort · South Florida</span>
          </div>
          <span class="cs-arrow">→</span>
        </div>

        <h2 class="cs-title">Luxury Wellness Spa</h2>
        <p class="cs-summary">
          $342/month in disconnected tools replaced with $51/month in unified infrastructure.
          One luxury spa. Five platforms. Zero integration. We fixed all of it.
        </p>

        <div class="cs-stats">
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">$3,492</span>
            <span class="cs-stat-label">Annual savings</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">11</span>
            <span class="cs-stat-label">Workflows automated</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">$50k+</span>
            <span class="cs-stat-label">Infrastructure value delivered</span>
          </div>
        </div>

        <span class="cs-read-more">Read the full case study →</span>
      </a>

      <a href="/case-studies/events-erp-migration" class="cs-card card reveal">
        <div class="cs-card-header">
          <div class="cs-meta">
            <span class="badge badge-primary">Events & Trade Shows / Finance Systems</span>
            <span class="cs-location">Multi-Entity · US + UK Operations</span>
          </div>
          <span class="cs-arrow">→</span>
        </div>

        <h2 class="cs-title">Global Events Company: ERP Migration</h2>
        <p class="cs-summary">
          Three siloed QuickBooks instances replaced with one unified Sage Intacct environment.
          Multi-entity consolidation, multi-currency reporting, and a 10-day close cycle, all delivered
          through a structured 6-month migration program.
        </p>

        <div class="cs-stats">
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">3 → 1</span>
            <span class="cs-stat-label">Unified platform</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">10-day</span>
            <span class="cs-stat-label">Close cycle achieved</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-number text-accent">7</span>
            <span class="cs-stat-label">Enterprise deliverables</span>
          </div>
        </div>

        <span class="cs-read-more">Read the full case study →</span>
      </a>

      <!-- Upcoming case studies -->
      <div class="coming-soon">
        <div class="coming-soon-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" aria-hidden="true">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
        </div>
        <p class="coming-soon-label">More success stories on the way</p>
        <p class="coming-soon-sub">
          We're documenting active client wins right now. Each completed engagement becomes
          a full case study with real numbers. Want your business to be next?
        </p>
        <a href="/contact" class="coming-soon-cta">Start Your Project &rarr;</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2 class="cta-title">Ready to build your own success story?</h2>
      <p class="cta-sub">
        Every case study started with a free discovery call. Tell us where you're stuck, and
        we'll map out exactly what needs to change.
      </p>
      <div class="cta-actions">
        <Button variant="primary" href="/contact">Start a Project</Button>
        <Button variant="outline" href="/services">View Services</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-section {
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  /* ── Case study card ── */
  .cards-section { background: var(--color-bg); }

  .cs-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 36px;
    transition: border-color 0.2s ease,
                box-shadow 0.2s ease,
                transform 0.25s cubic-bezier(.22,1,.36,1);
    max-width: 760px;
    margin-inline: auto;
  }

  .cs-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .cs-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .cs-location {
    font-size: 13px;
    color: var(--color-muted);
  }

  .cs-arrow {
    font-size: 20px;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  .cs-card:hover .cs-arrow { transform: translateX(4px); }

  .cs-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }

  .cs-summary {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .cs-stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .cs-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-stat-number {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .cs-stat-label {
    font-size: 12px;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }

  .text-accent { color: var(--color-primary); }

  .cs-read-more {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── Coming soon — polished ── */
  .coming-soon {
    max-width: 760px;
    margin: 32px auto 0;
    padding: 40px 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-align: center;
    background: linear-gradient(135deg, var(--color-surface) 0%, color-mix(in srgb, var(--primary) 3%, var(--color-surface)) 100%);
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .coming-soon:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .coming-soon-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    animation: spin-slow 8s linear infinite;
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .coming-soon-label {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .coming-soon-sub {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 460px;
    margin: 0 auto 20px;
  }

  .coming-soon-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    padding: 10px 24px;
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-md);
    transition: all 0.3s cubic-bezier(.22,1,.36,1);
  }

  .coming-soon-cta:hover {
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    box-shadow: 0 4px 14px color-mix(in srgb, var(--primary) 25%, transparent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* ── CTA section ── */
  .cta-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-title {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
  }

  .cta-sub {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .cs-card { padding: 24px 20px; }
    .cs-stats { gap: 20px; }
    .coming-soon { padding: 20px 16px; }
  }
</style>

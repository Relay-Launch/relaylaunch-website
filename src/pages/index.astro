---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="RelayLaunch — Build Smarter. Launch Faster. Grow With Purpose."
  description="RelayLaunch builds unified digital infrastructure for small businesses — one connected system replacing the 5 disconnected tools draining your time and money."
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="hero section">
    <div class="container">
      <div class="badge badge-green hero-badge">Small Business Infrastructure</div>
      <h1 class="hero-headline">
        Stop paying $400/month for tools that<br />
        <span class="text-green">don't talk to each other.</span>
      </h1>
      <p class="hero-sub">
        The average small business juggles 5–8 separate platforms — website, email, social, scheduling,
        payments, analytics. RelayLaunch replaces that entire stack with one connected system,
        running your business while you focus on your clients.
      </p>
      <div class="hero-actions">
        <a href="/services" class="btn-primary">See Our Packages →</a>
        <a href="/case-studies/hrc" class="btn-secondary">View Case Study</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ STATS BAR -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <div class="stat-number">33.2M</div>
        <div class="stat-label">small businesses in the US</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">37%</div>
        <div class="stat-label">have a website but zero automation</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">$300–500</div>
        <div class="stat-label">per month on disconnected tools</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">5–10 hrs</div>
        <div class="stat-label">lost every week to manual data entry</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PROBLEM -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="two-col-text">
          <span class="section-eyebrow">The Problem</span>
          <h2 class="section-title">You became a business owner. Not a software administrator.</h2>
          <p class="section-sub" style="margin-bottom: 24px;">
            You didn't sign up to be your own IT department, social media manager, email marketer,
            and data analyst. But here you are — logging into 6 different dashboards, copying
            information between platforms, doing manually what a system should handle automatically.
          </p>
          <ul class="checklist problem-list">
            <li>5–8 platforms that require separate logins and don't share data</li>
            <li>Manual work between systems eating 5–10 hours every week</li>
            <li>No unified view — decisions based on gut feeling, not actual data</li>
            <li>Customers experiencing inconsistent branding across every touchpoint</li>
            <li>Money going out every month for tools duplicating the same features</li>
          </ul>
        </div>
        <div class="tool-chaos">
          <div class="tool-grid">
            {['Website', 'Email', 'Social', 'Scheduling', 'Payments', 'Analytics', 'Automation', 'CRM'].map((tool, i) => (
              <div class:list={['tool-item', { dim: i > 3 }]}>{tool}</div>
            ))}
          </div>
          <div class="tool-chaos-label">5–8 tools. None connected. All manual.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SOLUTION -->
  <section class="section solution-section">
    <div class="container">
      <span class="section-eyebrow">The Solution</span>
      <h2 class="section-title">One system. One dashboard.<br />Everything connected.</h2>
      <p class="section-sub" style="margin-bottom: 48px;">
        RelayLaunch builds unified digital infrastructure — your website, automations, email, social,
        and reporting all wired together. When a new client books, the system follows up automatically.
        When a post goes out, it goes to all four platforms. When something needs your attention, it
        surfaces to one dashboard.
      </p>

      <div class="solution-grid">
        <div class="solution-card">
          <div class="solution-icon">⚡</div>
          <h3>Live Automation Workflows</h3>
          <p>Appointment follow-ups, review requests, lead nurturing, social publishing — built once, running 24/7 for $6/month in infrastructure.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">🔗</div>
          <h3>Everything Connected</h3>
          <p>Your website, email, CRM, social, and scheduling all talk to each other. No more copy-pasting between platforms. No more manual reports.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">📊</div>
          <h3>One Unified Dashboard</h3>
          <p>All your metrics, alerts, bookings, and approvals in a single Slack dashboard. Your business briefs you every morning — not the other way around.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">🌐</div>
          <h3>Built to Be Found</h3>
          <p>Mobile-first, SEO-optimized websites built in Astro — faster than WordPress, cheaper to host ($0 on Cloudflare), and designed to rank.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PACKAGES -->
  <section class="section" id="services">
    <div class="container">
      <span class="section-eyebrow">Service Packages</span>
      <h2 class="section-title">Find the right level of engagement.</h2>
      <p class="section-sub" style="margin-bottom: 48px;">
        Every engagement starts with a conversation. We match you to the right package based on
        where you are and where you want to go.
      </p>

      <div class="packages-grid">
        <div class="card pkg-card">
          <div class="pkg-name">Signal</div>
          <div class="pkg-tagline">Visibility &amp; Ops Audit</div>
          <div class="pkg-price">$500–$900</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Business &amp; digital presence audit</li>
            <li>Tool stack inventory</li>
            <li>Workflow bottleneck map</li>
            <li>30-day priority action plan</li>
          </ul>
          <a href="/services#signal" class="btn-secondary pkg-cta">Learn More</a>
        </div>

        <div class="card pkg-card">
          <div class="pkg-name">Blueprint</div>
          <div class="pkg-tagline">Systems Strategy</div>
          <div class="pkg-price">$1,200–$2,000</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>All Signal deliverables</li>
            <li>90-day growth roadmap</li>
            <li>Automation opportunity map</li>
            <li>Tech stack recommendation</li>
          </ul>
          <a href="/services#blueprint" class="btn-secondary pkg-cta">Learn More</a>
        </div>

        <div class="card featured pkg-card">
          <div class="badge badge-solid-green" style="margin-bottom: 16px;">Most Popular</div>
          <div class="pkg-name">Relay</div>
          <div class="pkg-tagline">Build &amp; Connect</div>
          <div class="pkg-price">$1,800–$6,000</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Custom SEO-optimized website</li>
            <li>Live automation workflows</li>
            <li>Email + social scheduling</li>
            <li>Unified business dashboard</li>
            <li>SOP library + 30-day support</li>
          </ul>
          <a href="/services#relay" class="btn-primary pkg-cta">Learn More</a>
        </div>

        <div class="card pkg-card">
          <div class="pkg-name">Sustain</div>
          <div class="pkg-tagline">Monthly Growth Support</div>
          <div class="pkg-price">$300–$500/mo</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Social content (30 posts/mo)</li>
            <li>SEO &amp; blog maintenance</li>
            <li>Automation monitoring</li>
            <li>Monthly strategy call</li>
            <li>Priority support channel</li>
          </ul>
          <a href="/services#sustain" class="btn-secondary pkg-cta">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CASE STUDY TEASER -->
  <section class="section case-study-teaser">
    <div class="container">
      <div class="cs-inner">
        <div class="cs-text">
          <span class="section-eyebrow">Proof of Concept</span>
          <h2 class="section-title">Real client. Real numbers.<br />Day one.</h2>
          <p style="color: var(--color-muted); margin-bottom: 24px;">
            The Holistic Rejuvenation Center at the JW Marriott Turnberry in Miami was spending
            $342/month on disconnected tools — ClickFunnels, Squarespace, and manual everything.
            RelayLaunch replaced the entire stack for $51/month.
          </p>
          <div class="cs-stats">
            <div class="cs-stat">
              <div class="stat-number" style="color: var(--color-green);">$342 → $51</div>
              <div class="stat-label">monthly infrastructure cost</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">$3,492</div>
              <div class="stat-label">saved every year</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">11</div>
              <div class="stat-label">automation workflows running 24/7</div>
            </div>
          </div>
          <a href="/case-studies/hrc" class="btn-primary" style="margin-top: 32px;">Read the Full Case Study →</a>
        </div>
        <div class="cs-deliverables">
          <div class="card" style="padding: 24px;">
            <p class="section-eyebrow" style="margin-bottom: 16px;">What Was Built</p>
            <ul class="checklist">
              <li>15-page custom Astro 6 website</li>
              <li>11 n8n automation workflows</li>
              <li>5 MailChimp email sequences</li>
              <li>30 days of social content (4 platforms)</li>
              <li>8 SEO blog posts</li>
              <li>Slack automated daily dashboard</li>
              <li>Membership platform (free + paid tiers)</li>
              <li>Corporate wellness sub-site</li>
              <li>Full platform migration</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FOUNDER -->
  <section class="section founder-section">
    <div class="container">
      <div class="two-col">
        <div>
          <span class="section-eyebrow">Who Builds This</span>
          <h2 class="section-title">Cloud engineer.<br />Marine veteran.<br />Small business advocate.</h2>
          <p style="color: var(--color-muted); margin-bottom: 20px;">
            Victor David Medina brings Fortune 500 infrastructure experience to small business problems.
            The same engineering discipline that managed 1,000-user enterprise integrations at ezCater —
            now applied to local businesses that deserve the same quality systems.
          </p>
          <div class="credentials">
            <div class="credential">
              <span class="cred-icon">🏗️</span>
              <div>
                <strong>Cloud Engineering</strong>
                <p>DNS, CDN, CI/CD, security headers — enterprise-grade infrastructure for small business budgets.</p>
              </div>
            </div>
            <div class="credential">
              <span class="cred-icon">🎖️</span>
              <div>
                <strong>USMC Sergeant (E-5)</strong>
                <p>Structured execution and mission completion — not aspirational values. Ingrained ones.</p>
              </div>
            </div>
            <div class="credential">
              <span class="cred-icon">⚙️</span>
              <div>
                <strong>Enterprise Ops Background</strong>
                <p>ezCater (1,000-user integrations), Blue Matter (cross-border post-merger systems) — built for complexity.</p>
              </div>
            </div>
          </div>
          <a href="/about" class="btn-secondary" style="margin-top: 28px;">More About Victor →</a>
        </div>
        <div class="advantage-card card">
          <p class="section-eyebrow" style="margin-bottom: 16px;">The Difference</p>
          <div class="compare-row">
            <div class="compare-col">
              <p class="compare-label">Web Designer</p>
              <ul class="compare-list">
                <li>Builds a website and hands it over</li>
                <li>Uses templates and page builders</li>
                <li>Bolts on automation as an upsell</li>
                <li>Hands you credentials and disappears</li>
              </ul>
            </div>
            <div class="compare-col green-side">
              <p class="compare-label green-label">RelayLaunch</p>
              <ul class="compare-list">
                <li>Builds an operating system for your business</li>
                <li>Custom-coded in Astro + Tailwind — no templates</li>
                <li>Automation built in from day one</li>
                <li>Daily dashboard briefings in Slack</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2 class="section-title" style="font-size: clamp(24px, 3.5vw, 38px); max-width: 600px;">
        Ready to replace your tool stack with one connected system?
      </h2>
      <p style="color: var(--color-muted); margin-top: 16px; margin-bottom: 32px; max-width: 500px;">
        Whether you need a full build or just want an honest audit of what's slowing you down —
        start with a conversation. No commitment required.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn-primary">Start a Project →</a>
        <a href="/services" class="btn-secondary">See All Packages</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero { padding-top: 100px; padding-bottom: 80px; }
  .hero-badge { margin-bottom: 24px; }
  .hero-headline {
    font-size: clamp(34px, 5vw, 58px);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 24px;
    max-width: 800px;
    line-height: 1.1;
  }
  .text-green { color: var(--color-green); }
  .hero-sub {
    font-size: 18px;
    color: var(--color-muted);
    max-width: 620px;
    margin-bottom: 36px;
    line-height: 1.65;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ── Stats bar ── */
  .stats-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 36px 0;
  }
  .stats-grid {
    display: flex;
    gap: 0;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .stat { text-align: center; flex: 1; padding: 16px; }
  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* ── Two col ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Tool chaos ── */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }
  .tool-item {
    padding: 12px 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }
  .tool-item.dim { opacity: 0.45; }
  .tool-chaos-label {
    font-size: 13px;
    color: var(--color-muted);
    text-align: center;
  }

  /* ── Problem checklist ── */
  .problem-list li::before { content: '✗'; color: #f85149; }

  /* ── Solution section ── */
  .solution-section { background: var(--color-surface); }
  .solution-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }
  .solution-card {
    padding: 28px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .solution-icon { font-size: 28px; margin-bottom: 14px; }
  .solution-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
  .solution-card p { font-size: 14px; }

  /* ── Packages ── */
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }
  .pkg-card { display: flex; flex-direction: column; }
  .pkg-name { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
  .pkg-tagline { font-size: 13px; color: var(--color-muted); margin-bottom: 10px; }
  .pkg-price { font-size: 15px; font-weight: 700; color: var(--color-green); }
  .pkg-cta { margin-top: auto; padding-top: 20px; display: block; text-align: center; }

  /* ── Case study teaser ── */
  .case-study-teaser { background: var(--color-surface); }
  .cs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .cs-stats { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 24px; }
  .cs-stat { flex: 1; min-width: 120px; }

  /* ── Founder ── */
  .credentials { display: flex; flex-direction: column; gap: 20px; margin-top: 28px; }
  .credential {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .cred-icon { font-size: 20px; margin-top: 2px; flex-shrink: 0; }
  .credential strong { display: block; font-size: 15px; margin-bottom: 4px; }
  .credential p { font-size: 14px; }

  .advantage-card { padding: 28px; }
  .compare-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .compare-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }
  .green-label { color: var(--color-green) !important; }
  .compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .compare-list li { font-size: 13px; color: var(--color-muted); }
  .green-side .compare-list li { color: var(--color-text); }

  /* ── CTA section ── */
  .cta-section { background: var(--color-surface); }
  .cta-inner { max-width: 700px; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .two-col, .cs-inner { grid-template-columns: 1fr; gap: 40px; }
    .stats-grid { gap: 0; }
    .stat-divider { display: none; }
    .stat { border-bottom: 1px solid var(--color-border); }
    .stat:last-child { border-bottom: none; }
    .compare-row { grid-template-columns: 1fr; }
    .tool-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>

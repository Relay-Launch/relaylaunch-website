---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
import ArchitectureDiagram from '@/components/ArchitectureDiagram.astro';

const webhookUrl = import.meta.env.PUBLIC_LEAD_MAGNET_WEBHOOK_URL || '#';
---

<Layout
  title="RelayLaunch | Ops on Autopilot. You on Strategy."
  description="Tired of scattered AI tools? RelayLaunch designs and runs a single Control Center for your automations and infrastructure so your ops run on autopilot and you stay focused on strategy."
  canonicalUrl="https://www.relaylaunch.com/"
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'RelayLaunch',
      url: 'https://www.relaylaunch.com',
      description: 'RelayLaunch designs and runs a single Control Center for your automations and infrastructure.',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'RelayLaunch',
      description: 'Digital infrastructure consultancy. One Control Center replacing scattered AI tools and disconnected systems. AI agents built in.',
      url: 'https://www.relaylaunch.com',
      founder: {
        '@type': 'Person',
        name: 'Victor David Medina',
        jobTitle: 'Founder',
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Watertown',
        addressRegion: 'MA',
        addressCountry: 'US',
      },
      areaServed: {
        '@type': 'Country',
        name: 'United States',
      },
      priceRange: '$$',
      knowsAbout: ['digital infrastructure', 'business automation', 'ERP migration', 'web development'],
    },
  ]}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="hero section hero-gradient section-hero-enhanced">
    <div class="container">
      <div class="badge badge-primary hero-badge animate-fade-in-up">Ops on Autopilot. You on Strategy.</div>
      <h1 class="hero-headline animate-fade-in-up" style="animation-delay: 0.1s;">
        Tired of scattered AI tools?<br />
        <span class="text-accent">Meet your Control Center.</span>
      </h1>
      <p class="hero-sub animate-fade-in-up" style="animation-delay: 0.2s;">
        Small and mid&#8209;size teams are adopting AI and cloud everywhere--but
        most are stuck juggling disconnected tools, manual glue work, and growing
        risk. RelayLaunch designs and runs a single Control Center for your
        automations and infrastructure so your ops run on autopilot and you stay
        focused on strategy.
      </p>
      <div class="hero-actions animate-fade-in-up" style="animation-delay: 0.3s;">
        <Button variant="primary" href="/complete-analysis" size="lg">Book a Control Center Assessment →</Button>
        <Button variant="outline" href="/case-studies/luxury-wellness-spa" size="lg">See the Luxury Wellness Spa Dashboard Case Study</Button>
      </div>
      <a href="/how-we-work" class="animate-fade-in-up" style="animation-delay: 0.35s; display: inline-block; margin-top: 14px; font-size: 14px; font-weight: 600; color: var(--color-muted); text-decoration: none; transition: color 0.2s ease;">See how we work →</a>
      <p class="hero-no-commit animate-fade-in-up" style="animation-delay: 0.38s;">
        No commitment required. Discovery call is free.
      </p>
      <div class="hero-trust animate-fade-in-up" style="animation-delay: 0.45s;">
        <div class="trust-item">
          <span class="trust-check">✓</span> Fortune 500 Engineering
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> One Control Center, Not 6 Tools
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> AI Agents Built In
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> Fixed, Transparent Pricing
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ TECH STACK MARQUEE -->
  <section class="tech-marquee-section">
    <div class="container">
      <p class="marquee-label">Built With Industry-Leading Tools</p>
    </div>
    <div class="marquee-track">
      <div class="marquee-inner">
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#FF5D01" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Astro</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#F48120"/><path d="M8.5 14.5l-3-2.5 3-2.5M15.5 14.5l3-2.5-3-2.5M10.5 16l3-8" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Cloudflare</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="4" fill="#EA4B71"/><path d="M8 12h8M12 8v8" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>n8n</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z" fill="#06B6D4"/><path d="M7.5 11.5L12 14l4.5-2.5M12 14v5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Tailwind CSS</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" fill="#4A154B"/><path d="M7 9v2a2 2 0 004 0V9M13 9v4M17 9v2a2 2 0 01-2 2" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>Slack</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 5.58 2 10c0 2.76 1.64 5.19 4.14 6.71L5 22l4.22-2.11C10.13 20.13 11.04 20.25 12 20.25c5.52 0 10-3.58 10-8s-4.48-8-10-8z" fill="#FFE01B"/><circle cx="9" cy="10" r="1.5" fill="#241C15"/><circle cx="15" cy="10" r="1.5" fill="#241C15"/></svg>Mailchimp</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" fill="#fff"/></svg>GitHub</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="#D97757"/><path d="M8 10c0-2.2 1.8-4 4-4s4 1.8 4 4c0 3-4 7-4 7s-4-4-4-7z" fill="#fff" opacity="0.9"/></svg>Claude AI</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" fill="#635BFF"/><path d="M10 10c0-.55.45-1 1-1h2c.55 0 1 .45 1 1v4c0 .55-.45 1-1 1h-2c-.55 0-1-.45-1-1v-4z" fill="#fff"/></svg>Stripe</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="#E37400" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Google Analytics</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="9" fill="#006BFF"/><path d="M8 12h8M8 9h8M8 15h5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>Calendly</span>
        <!-- Duplicate for seamless scroll -->
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#FF5D01" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Astro</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#F48120"/><path d="M8.5 14.5l-3-2.5 3-2.5M15.5 14.5l3-2.5-3-2.5M10.5 16l3-8" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Cloudflare</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="4" fill="#EA4B71"/><path d="M8 12h8M12 8v8" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>n8n</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z" fill="#06B6D4"/><path d="M7.5 11.5L12 14l4.5-2.5M12 14v5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Tailwind CSS</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" fill="#4A154B"/><path d="M7 9v2a2 2 0 004 0V9M13 9v4M17 9v2a2 2 0 01-2 2" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>Slack</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 5.58 2 10c0 2.76 1.64 5.19 4.14 6.71L5 22l4.22-2.11C10.13 20.13 11.04 20.25 12 20.25c5.52 0 10-3.58 10-8s-4.48-8-10-8z" fill="#FFE01B"/><circle cx="9" cy="10" r="1.5" fill="#241C15"/><circle cx="15" cy="10" r="1.5" fill="#241C15"/></svg>Mailchimp</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" fill="#fff"/></svg>GitHub</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="#D97757"/><path d="M8 10c0-2.2 1.8-4 4-4s4 1.8 4 4c0 3-4 7-4 7s-4-4-4-7z" fill="#fff" opacity="0.9"/></svg>Claude AI</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" fill="#635BFF"/><path d="M10 10c0-.55.45-1 1-1h2c.55 0 1 .45 1 1v4c0 .55-.45 1-1 1h-2c-.55 0-1-.45-1-1v-4z" fill="#fff"/></svg>Stripe</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="#E37400" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Google Analytics</span>
        <span class="marquee-item"><svg class="marquee-logo" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="9" fill="#006BFF"/><path d="M8 12h8M8 9h8M8 15h5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>Calendly</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ OBJECTION HANDLING -->
  <section class="section objection-section">
    <div class="container">
      <h2 class="section-title" style="font-size: clamp(22px, 3vw, 30px); margin-bottom: 36px; text-align: center;">What Makes This Different</h2>
      <div class="objection-grid">
        <div class="objection-item">
          <svg class="objection-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <p class="objection-text">You own 100% of everything we build. No vendor lock-in.</p>
        </div>
        <div class="objection-item">
          <svg class="objection-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <p class="objection-text">No technical background needed. We handle the complexity.</p>
        </div>
        <div class="objection-item">
          <svg class="objection-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p class="objection-text">Long-term focused. We build it, run it, and stay in the work.</p>
        </div>
        <div class="objection-item">
          <svg class="objection-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <p class="objection-text">Fixed pricing, clear scope. No hourly surprises.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ LEAD MAGNET -->
  <section class="section lead-magnet-section">
    <div class="container">
      <div class="lead-magnet-inner card">
        <div class="lead-magnet-text">
          <span class="section-eyebrow">Free Download</span>
          <h2 class="lead-magnet-title">Digital Readiness Assessment</h2>
          <p class="lead-magnet-desc">
            A 1-page checklist to see if your business has outgrown its current digital setup.
            Score yourself across 10 areas, from tool sprawl to automation maturity, and find out
            where you're leaving time and money on the table.
          </p>
        </div>
        <div class="lead-magnet-form-wrap">
          <form
            id="lead-magnet-form"
            class="lead-magnet-form"
            data-webhook={webhookUrl}
            novalidate
          >
            <div class="form-field">
              <label for="lm-name">Name</label>
              <input type="text" id="lm-name" name="name" required autocomplete="name" placeholder="Your name" />
            </div>
            <div class="form-field">
              <label for="lm-email">Email</label>
              <input type="email" id="lm-email" name="email" required autocomplete="email" placeholder="you@company.com" />
            </div>
            <Button type="submit" variant="primary" class="w-full justify-center">Get the Assessment →</Button>
            <p class="form-note">No spam. Unsubscribe anytime.</p>
          </form>
          <div id="lead-magnet-success" class="lead-magnet-success" hidden>
            <p class="success-title">You're in.</p>
            <p class="success-desc">
              Check your inbox. Your Digital Readiness Assessment is on the way.
            </p>
          </div>
          <div id="lead-magnet-error" class="lead-magnet-error" hidden>
            <p class="error-title">Something went wrong.</p>
            <p class="error-desc">
              Please try again, or reach out to us at <a href="/contact">contact</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ STATS BAR -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <div class="stat-number">33.2M</div>
        <div class="stat-label">small businesses in the US</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">37%</div>
        <div class="stat-label">have a website but zero automation</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">$300–500</div>
        <div class="stat-label">per month on disconnected tools</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">5–10 hrs</div>
        <div class="stat-label">lost every week to manual data entry</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ WHY RELAYLAUNCH -->
  <section class="section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">Why RelayLaunch</span>
        <h2 class="section-title" style="margin-bottom: 40px;">Built different. On purpose.</h2>
      </div>

      <div class="why-grid reveal-stagger">
        <div class="why-card">
          <div class="why-icon">🤖</div>
          <h3>AI Agents, Not Just AI Tools</h3>
          <p>Purpose-built specialist agents handle your content, growth, security, and infrastructure. Not generic chatbots. Agents that know your brand, your systems, and your business logic.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🏗️</div>
          <h3>Infrastructure-First + AI</h3>
          <p>We don't bolt AI onto a broken foundation. We build the infrastructure first: website, automations, integrations. Then we layer in AI where it actually saves time and money.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🔗</div>
          <h3>Full-Service, One Partner</h3>
          <p>Web, SEO, AI agents, workflow automation, systems integration, cloud infrastructure. All from one team. No coordinating between five freelancers who don't talk to each other.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">💲</div>
          <h3>Clear Fixed Pricing</h3>
          <p>Market-validated tiers with defined scope and deliverables. You know what you're getting and what it costs before anything starts. No hourly surprises, no scope creep.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONTROL CENTER APP -->
  <section class="section agents-section">
    <div class="agents-bg-grid" aria-hidden="true"></div>
    <div class="agents-bg-orb agents-bg-orb-1" aria-hidden="true"></div>
    <div class="agents-bg-orb agents-bg-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="reveal">
        <div class="cc-coming-soon-badge">Coming Soon</div>
        <span class="section-eyebrow">The RelayLaunch Control Center</span>
        <h2 class="section-title">Six specialist agents. One unified system.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          Every client gets a full operations team built into their Control Center.
          These agents don't just respond to prompts — they monitor, build, protect,
          and optimize your systems around the clock.
        </p>
      </div>

      <div class="agents-grid reveal-stagger">
        <!-- Infrastructure Agent -->
        <div class="agent-card agent-card-infra">
          <div class="agent-status"><span class="agent-status-dot"></span>Active</div>
          <div class="agent-icon agent-icon-infra">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
              <circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/>
              <line x1="12" y1="6" x2="18" y2="6"/><line x1="12" y1="18" x2="18" y2="18"/>
            </svg>
          </div>
          <h3>Infra Agent</h3>
          <p class="agent-role">DNS, CDN, CI/CD, hosting, uptime</p>
          <p>Manages your entire cloud stack. DNS propagation, edge deployments, build pipelines, and zero-downtime releases. Enterprise-grade infrastructure on autopilot.</p>
          <div class="agent-tags">
            <span class="agent-tag">/devops</span>
            <span class="agent-tag">/architect</span>
          </div>
        </div>

        <!-- Security Agent -->
        <div class="agent-card agent-card-security">
          <div class="agent-status"><span class="agent-status-dot agent-status-dot-alert"></span>Monitoring</div>
          <div class="agent-icon agent-icon-security">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h3>Security Agent</h3>
          <p class="agent-role">Threat detection, headers, compliance</p>
          <p>Scans for vulnerabilities, enforces CSP headers, monitors dependencies, and runs security audits. Your always-on threat detection layer.</p>
          <div class="agent-tags">
            <span class="agent-tag">/security</span>
            <span class="agent-tag">/qa</span>
          </div>
        </div>

        <!-- Build Agent -->
        <div class="agent-card agent-card-build">
          <div class="agent-status"><span class="agent-status-dot"></span>Active</div>
          <div class="agent-icon agent-icon-build">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              <line x1="14" y1="4" x2="10" y2="20"/>
            </svg>
          </div>
          <h3>Build Agent</h3>

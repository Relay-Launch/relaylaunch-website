<script>
  const form = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const success = document.getElementById('lead-magnet-success') as HTMLElement;
  const error = document.getElementById('lead-magnet-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();

    if (!name || !email) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn?.textContent || '';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
    }

    const webhook = form.dataset.webhook;
    if (!webhook || webhook === '#') {
      // Webhook not configured - show error instead of false promise
      form.hidden = true;
      error.hidden = false;
      return;
    }

    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);

      const res = await fetch(webhook, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, source: 'digital-readiness-assessment' }),
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      if (!res.ok) throw new Error('Webhook returned an error');

      form.hidden = true;
      success.hidden = false;
    } catch {
      // Restore form so user can retry
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
      error.hidden = false;
    }
  });

  // ── ROI Calculator ──
  function calcROI() {
    const tools = parseFloat((document.getElementById('roi-tools') as HTMLInputElement)?.value) || 0;
    const hours = parseFloat((document.getElementById('roi-hours') as HTMLInputElement)?.value) || 0;
    const rate = parseFloat((document.getElementById('roi-rate') as HTMLInputElement)?.value) || 0;
    const toolSavings = Math.round((tools - 51) * 12);
    const timeValue = Math.round(hours * rate * 52);
    const total = toolSavings + timeValue;
    const fmt = (n: number) => '$' + Math.abs(n).toLocaleString();
    const el = (id: string) => document.getElementById(id);
    if (el('roi-tool-savings')) el('roi-tool-savings')!.textContent = fmt(Math.max(0, toolSavings));
    if (el('roi-time-value')) el('roi-time-value')!.textContent = fmt(Math.max(0, timeValue));
    if (el('roi-total')) el('roi-total')!.textContent = fmt(Math.max(0, total));
  }
  document.querySelectorAll('.roi-field input').forEach(input => {
    input.addEventListener('input', calcROI);
  });
  calcROI();

  // ── Scroll Reveal ──
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal, .reveal-stagger > *, .result-card, .ba-card, .testimonial-card').forEach(el => {
    el.classList.add('scroll-hidden');
    revealObserver.observe(el);
  });

  // ── Animated Number Counters (P1-1: upgraded to requestAnimationFrame) ──
  function animateCounter(el: HTMLElement, target: number, prefix: string, suffix: string) {
    const duration = 1200;
    const start = performance.now();
    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease-out cubic for smooth deceleration
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = prefix + current.toLocaleString() + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const card = entry.target as HTMLElement;
      const numEl = card.querySelector('.result-number') as HTMLElement;
      if (!numEl || card.dataset.animated) return;
      card.dataset.animated = '1';
      const target = parseInt(card.dataset.count || '0');
      const prefix = card.dataset.prefix || '';
      const suffix = card.dataset.suffix || '';
      animateCounter(numEl, target, prefix, suffix);
      counterObserver.unobserve(card);
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.result-card').forEach(el => counterObserver.observe(el));
</script>


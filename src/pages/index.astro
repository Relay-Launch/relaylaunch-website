    bottom: 2px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), color-mix(in srgb, var(--primary) 40%, transparent));
    border-radius: 2px;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--color-muted);
    max-width: 620px;
    margin-bottom: 36px;
    line-height: 1.65;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  /* ── Unified Hero Buttons (consistent on mobile + desktop) ── */
  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 28px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.2px;
    border-radius: var(--radius-md);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.22,1,.36,1);
    position: relative;
    overflow: hidden;
    line-height: 1.2;
  }

  .hero-btn-arrow {
    display: inline-flex;
    transition: transform 0.3s cubic-bezier(.22,1,.36,1);
    font-size: 18px;
  }

  .hero-btn:hover .hero-btn-arrow { transform: translateX(4px); }
  .hero-btn:hover { text-decoration: none; }

  .hero-btn-primary {
    background: var(--color-primary);
    color: var(--color-white);
    border: 2px solid var(--color-primary);
    box-shadow: var(--shadow-primary-sm);
    animation: cta-pulse 2.5s ease-in-out infinite;
  }

  .hero-btn-primary:hover {
    box-shadow: var(--shadow-primary-md);
    transform: translateY(-2px);
    color: var(--color-white);
    animation: none;
  }

  .hero-btn-primary:active {
    transform: scale(0.98) translateY(0);
    box-shadow: var(--shadow-primary-focus);
    animation: none;
  }

  .hero-btn-outline {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .hero-btn-outline:hover {
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    box-shadow: var(--shadow-primary-sm);
    transform: translateY(-2px);
    color: var(--color-primary);
  }

  .hero-btn-outline:active {
    transform: scale(0.98) translateY(0);
  }
  .hero-no-commit {
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 10px;
    margin-bottom: 0;
  }

  /* ── Hero trust bar ── */
  .hero-trust {
    display: flex;
    gap: 24px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.2px;
  }

  .trust-check {
    color: var(--color-primary);
    font-weight: 800;
    font-size: 14px;
  }

  /* ── Animations ── */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  /* ── Stats bar ── */
  .stats-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);
    padding: 36px 0;
    box-shadow: inset 0 1px 0 0 color-mix(in srgb, var(--primary) 5%, transparent);
  }

  .stats-grid {
    display: flex;
    gap: 0;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    flex: 1;
    padding: 16px;
    transition: transform 0.2s ease;
  }

  .stat:hover {
    transform: scale(1.05);
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, transparent 0%, var(--color-border) 50%, transparent 100%);
    flex-shrink: 0;
  }

  /* ── Two col ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Tool chaos ── */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }
  .tool-item {
    padding: 12px 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }
  .tool-item.dim { opacity: 0.45; }
  .tool-chaos-label {
    font-size: 13px;
    color: var(--color-muted);
    text-align: center;
  }

  /* ── Why RelayLaunch ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .why-card {
    padding: 28px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s cubic-bezier(.22,1,.36,1),
                box-shadow 0.25s cubic-bezier(.22,1,.36,1),
                border-color 0.25s ease;
  }

  .why-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--primary) 30%, var(--color-border));
  }

  .why-icon {
    font-size: 32px;
    margin-bottom: 14px;
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .why-card:hover .why-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .why-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
  .why-card p { font-size: 14px; line-height: 1.65; }

  /* ── AI Agents Showcase ── */
  .agents-section {
    background: var(--color-navy);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  /* Animated grid background */
  .agents-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--primary) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--primary) 6%, transparent) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 100%);
    animation: grid-drift 20s linear infinite;
    pointer-events: none;
  }

  @keyframes grid-drift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
  }

  /* Floating orbs */
  .agents-bg-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .agents-bg-orb-1 {
    width: 400px;
    height: 400px;
    top: -10%;
    left: -5%;
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    animation: orb-float-1 15s ease-in-out infinite;
  }

  .agents-bg-orb-2 {
    width: 300px;
    height: 300px;
    bottom: -10%;
    right: -5%;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    animation: orb-float-2 18s ease-in-out infinite;
  }

  @keyframes orb-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, 30px) scale(1.1); }
    66% { transform: translate(-20px, 50px) scale(0.95); }
  }

  @keyframes orb-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, -40px) scale(1.08); }
  }

  .agents-section .section-eyebrow { color: var(--color-primary); }
  .agents-section .section-title { color: var(--color-white); }
  .agents-section .section-sub { color: color-mix(in srgb, var(--color-white) 70%, transparent); }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    position: relative;
    z-index: var(--z-base);
  }

  .agent-card {
    padding: 28px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--color-white) 10%, transparent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--color-white) 5%, transparent) 0%,
      color-mix(in srgb, var(--color-white) 2%, transparent) 100%
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: transform 0.35s cubic-bezier(.22,1,.36,1),
                border-color 0.3s ease,
                box-shadow 0.35s ease;
    position: relative;
    overflow: hidden;
  }

  .agent-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--color-primary) 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .agent-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--primary) 50%, transparent);
    box-shadow:
      0 8px 32px color-mix(in srgb, var(--primary) 12%, transparent),
      0 0 0 1px color-mix(in srgb, var(--primary) 15%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-white) 6%, transparent);
  }

  .agent-card:hover::before { opacity: 1; }

  /* Status indicator */
  .agent-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
    margin-bottom: 16px;
  }

  .agent-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 6px color-mix(in srgb, var(--primary) 50%, transparent);
    animation: status-blink 2s ease-in-out infinite;
  }

  .agent-status-dot-alert {
    background: var(--color-primary);
    box-shadow: 0 0 6px color-mix(in srgb, var(--primary) 50%, transparent);
  }

  @keyframes status-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Agent icons - larger, more distinctive */
  .agent-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 18px;
    color: var(--color-primary);
    position: relative;
    transition: transform 0.3s cubic-bezier(.22,1,.36,1), box-shadow 0.3s ease;
  }

  .agent-icon::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--color-primary), color-mix(in srgb, var(--primary) 30%, transparent));
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
    filter: blur(8px);
  }

  .agent-card:hover .agent-icon {
    transform: scale(1.15) rotate(-3deg);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--primary) 25%, transparent);
  }

  .agent-card:hover .agent-icon::after { opacity: 0.6; }

  /* Per-agent icon backgrounds (brand-compliant: Electric Blue #007AFF at varying opacity) */
  .agent-icon-infra {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 20%, transparent), color-mix(in srgb, var(--primary) 8%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
  }
  .agent-icon-security {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 25%, transparent), color-mix(in srgb, var(--primary) 10%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 35%, transparent);
  }
  .agent-icon-build {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 18%, transparent), color-mix(in srgb, var(--primary) 6%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 28%, transparent);
  }
  .agent-icon-content {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 15%, transparent), color-mix(in srgb, var(--primary) 5%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
  }
  .agent-icon-growth {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 22%, transparent), color-mix(in srgb, var(--primary) 8%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
  }
  .agent-icon-brand {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 16%, transparent), color-mix(in srgb, var(--primary) 5%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
  }
  .agent-icon-sales {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 20%, transparent), color-mix(in srgb, var(--primary) 7%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 28%, transparent);
  }
  .agent-icon-social {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 14%, transparent), color-mix(in srgb, var(--primary) 5%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 22%, transparent);
  }

  .agent-icon svg {
    width: 24px;
    height: 24px;
  }

  .agent-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--color-white);
  }

  .agent-role {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .agent-card > p:last-of-type {
    font-size: 14px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
  }

  /* Agent trigger tags */
  .agent-tags {
    display: flex;
    gap: 6px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .agent-tag {
    font-size: 11px;
    font-weight: 600;
    font-family: Arial, Helvetica, sans-serif;
    letter-spacing: 0.3px;
    color: color-mix(in srgb, var(--color-white) 45%, transparent);
    background: color-mix(in srgb, var(--color-white) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-white) 8%, transparent);
    border-radius: 4px;
    padding: 2px 8px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .agent-card:hover .agent-tag {
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
  }

  /* ── Premium Agents Block ── */
  .premium-agents-block {
    margin-top: 48px;
    padding: 40px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
    background: linear-gradient(145deg,
      color-mix(in srgb, var(--color-white) 4%, transparent) 0%,
      color-mix(in srgb, var(--color-white) 1%, transparent) 100%
    );
    position: relative;
    z-index: var(--z-base);
  }

  .premium-agents-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .premium-agents-title {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 12px;
  }

  .premium-agents-sub {
    font-size: 15px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
    max-width: 520px;
    margin: 0 auto;
  }

  .premium-agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .premium-agent-card {
    padding: 28px;
    border-radius: var(--radius-card);
    border: 1px dashed color-mix(in srgb, var(--color-white) 15%, transparent);
    background: color-mix(in srgb, var(--color-white) 3%, transparent);
    text-align: center;
    position: relative;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .premium-agent-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }

  .premium-agent-silhouette {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 20%, transparent), color-mix(in srgb, var(--primary) 8%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    opacity: 0.7;
  }

  .premium-agent-silhouette svg {
    width: 28px;
    height: 28px;
  }

  .premium-agent-lock {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-white) 8%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
  }

  .premium-agent-lock svg {
    width: 10px;
    height: 10px;
  }

  .premium-agent-card h4 {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 8px;
  }

  .premium-agent-card p {
    font-size: 13px;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
    margin-bottom: 16px;
  }

  .premium-agent-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    border-radius: var(--radius-xs);
    padding: 2px 8px;
  }

  .premium-agents-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .premium-agents-grid { grid-template-columns: 1fr; }
    .premium-agents-block { padding: 28px 20px; }
  }

  /* ── Relay Method Methodology Block ── */
  .relay-method-block {
    margin-top: 48px;
    margin-bottom: 48px;
    padding: 36px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
    background: color-mix(in srgb, var(--color-white) 3%, transparent);
    position: relative;
    z-index: var(--z-base);
  }

  .relay-method-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .relay-method-title {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 12px;
  }

  .relay-method-intro {
    font-size: 15px;
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
    max-width: 600px;
    margin: 0 auto;
  }

  .relay-method-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }

  .relay-method-card {
    padding: 24px;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--color-white) 8%, transparent);
    background: color-mix(in srgb, var(--color-white) 2%, transparent);
  }

  .relay-method-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .relay-method-card h4 {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 8px;
  }

  .relay-method-card p {
    font-size: 13px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
    margin: 0;
  }

  .relay-method-evolution {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 24px;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    background: color-mix(in srgb, var(--primary) 5%, transparent);
  }

  .relay-method-evolution-icon {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .relay-method-evolution p {
    font-size: 14px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-white) 75%, transparent);
    margin: 0;
  }

  .relay-method-evolution strong {
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .relay-method-grid { grid-template-columns: 1fr; }
    .relay-method-block { padding: 24px 20px; }
    .relay-method-evolution { flex-direction: column; gap: 12px; }
  }

  .cc-cta-block {
    text-align: center;
    margin-top: 48px;
    padding: 32px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
    background: color-mix(in srgb, var(--color-white) 3%, transparent);
    position: relative;
    z-index: var(--z-base);
  }

  .cc-cta-text {
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
    font-size: 15px;
    max-width: 560px;
    margin: 0 auto 24px;
    line-height: 1.65;
  }

  /* ── Waitlist Inline Signup ── */
  .waitlist-inline {
    margin: 24px auto 0;
    max-width: 520px;
    text-align: center;
  }

  .waitlist-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .waitlist-badge {
    display: inline-block;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-primary);
    border-radius: 4px;
  }

  .waitlist-headline {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-white);
  }

  .waitlist-pitch {
    font-size: 14px;
    color: color-mix(in srgb, var(--color-white) 65%, transparent);
    margin-bottom: 16px;
    line-height: 1.55;
  }

  .waitlist-form {
    margin: 0 auto;
    max-width: 440px;
  }

  .waitlist-input-group {
    display: flex;
    gap: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-white) 20%, transparent);
  }

  .waitlist-input {
    flex: 1;
    padding: 12px 16px;
    font-size: 14px;
    border: none;
    background: color-mix(in srgb, var(--color-white) 8%, transparent);
    color: var(--color-white);
    outline: none;
    min-width: 0;
  }

  .waitlist-input::placeholder {
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
  }

  .waitlist-input:focus {
    background: color-mix(in srgb, var(--color-white) 12%, transparent);
  }

  .waitlist-submit {
    padding: 12px 20px;
    font-size: 14px;
    font-weight: 700;
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .waitlist-submit:hover {
    background: color-mix(in srgb, var(--color-primary) 85%, #000);
  }

  .waitlist-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .waitlist-fine-print {
    font-size: 12px;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
    margin-top: 10px;
  }

  .waitlist-success {
    padding: 20px;
    text-align: center;
  }

  .waitlist-success-text {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-white);
  }

  .waitlist-error {
    padding: 16px;
    text-align: center;
  }

  .waitlist-error-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .agents-grid { grid-template-columns: 1fr; }
    .agents-bg-grid { display: none; }
    .agent-card { padding: 24px; }
    .cc-cta-block { padding: 24px; }
    .waitlist-input-group {
      flex-direction: column;
    }
    .waitlist-submit {
      justify-content: center;
      padding: 14px 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .agents-bg-grid,
    .agents-bg-orb { animation: none; }
    .agent-status-dot { animation: none; }
  }

  /* ── Problem checklist ── */
  .problem-list li::before { content: '✗'; color: var(--color-muted); font-weight: 800; }

  /* ── Solution section ── */
  .solution-section {
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .solution-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: -50%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 8%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    position: relative;
    z-index: var(--z-base);
  }

  .solution-card {
    padding: 28px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s cubic-bezier(.22,1,.36,1),
                box-shadow 0.25s cubic-bezier(.22,1,.36,1),
                border-color 0.25s ease;
  }

  .solution-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
  }

  .solution-icon {
    font-size: 32px;
    margin-bottom: 14px;
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .solution-card:hover .solution-icon {
    transform: scale(1.1) rotate(-5deg);
  }

  .solution-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
  .solution-card p { font-size: 14px; }

  /* ── Packages ── */
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .pkg-card {
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-align: center;
    align-items: center;
    padding: 32px 20px;
  }
  .pkg-card-start-here { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
  .pkg-start-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    border-radius: var(--radius-xs);
    padding: 3px 10px;
    margin-bottom: 12px;
  }
  .pkg-name { font-size: 22px; font-weight: 800; letter-spacing: -0.3px; margin-bottom: 4px; color: var(--color-text); }
  .pkg-tagline { font-size: 13px; color: var(--color-muted); margin-bottom: 8px; }
  .pkg-price { font-size: 20px; font-weight: 800; color: var(--color-primary); letter-spacing: -0.2px; margin-bottom: 4px; }
  .pkg-card .checklist { text-align: left; width: 100%; }
  .pkg-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .pkg-cta-wrap {
    margin-top: auto;
    padding-top: 20px;
    width: 100%;
  }

  .pkg-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 24px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.3px;
    border-radius: var(--radius-md);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.22,1,.36,1);
    position: relative;
    overflow: hidden;
  }

  .pkg-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 15%, transparent), transparent);
  }

  .pkg-btn:hover::before { opacity: 1; }

  .pkg-btn-arrow {
    display: inline-flex;
    transition: transform 0.3s cubic-bezier(.22,1,.36,1);
    font-size: 18px;
  }

  .pkg-btn:hover .pkg-btn-arrow { transform: translateX(4px); }

  .pkg-btn-primary {
    background: var(--color-primary);
    color: var(--color-white);
    border: 2px solid var(--color-primary);
    box-shadow: var(--shadow-primary-sm);
  }

  .pkg-btn-primary:hover {
    box-shadow: var(--shadow-primary-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-white);
  }

  .pkg-btn-outline {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .pkg-btn-outline:hover {
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    box-shadow: var(--shadow-primary-sm);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-primary);
  }

  /* ── Case study teaser ── */
  .case-study-teaser {
    background: var(--color-surface);
    position: relative;
  }

  .case-study-teaser::before {
    content: '';
    position: absolute;
    top: 50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, color-mix(in srgb, var(--primary) 10%, transparent) 0%, transparent 70%);
    pointer-events: none;
    transform: translateY(-50%);
  }

  .cs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
    position: relative;
    z-index: var(--z-base);
  }

  .cs-stats { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 24px; }
  .cs-stat { flex: 1; min-width: 120px; }

  /* ── Case study teaser 2 ── */
  .case-study-teaser-2 {
    position: relative;
  }

  /* ── Founder ── */
  .credentials { display: flex; flex-direction: column; gap: 20px; margin-top: 28px; }
  .credential {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .cred-icon { font-size: 20px; margin-top: 2px; flex-shrink: 0; }
  .credential strong { display: block; font-size: 15px; margin-bottom: 4px; }
  .credential p { font-size: 14px; }

  .advantage-card { padding: 28px; }
  .compare-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .compare-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }
  .compare-label.accent-label { color: var(--color-primary); }
  .compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .compare-list li { font-size: 13px; color: var(--color-muted); }
  .accent-side .compare-list li { color: var(--color-text); }

  /* ── CTA section ── */
  .cta-section {
    background: linear-gradient(135deg,
      var(--color-surface) 0%,
      color-mix(in srgb, var(--color-primary) 8%, var(--color-surface)) 50%,
      var(--color-surface) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, color-mix(in srgb, var(--primary) 12%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    max-width: 700px;
    position: relative;
    z-index: var(--z-base);
  }

  /* ── Lead magnet ── */
  .lead-magnet-section {
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .lead-magnet-section::before {
    content: '';
    position: absolute;
    top: -20%;
    left: 50%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 10%, transparent) 0%, transparent 70%);
    pointer-events: none;
    transform: translateX(-50%);
  }

  .lead-magnet-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding: 40px;
    align-items: center;
    border-color: var(--color-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    position: relative;
    z-index: var(--z-base);
    background: linear-gradient(135deg, var(--color-surface) 0%, color-mix(in srgb, var(--color-primary) 3%, var(--color-surface)) 100%);
  }

  .lead-magnet-title {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800;
    margin-bottom: 12px;
  }

  .lead-magnet-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .lead-magnet-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-field input {
    padding: 10px 14px;
    font-size: 15px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-field input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--shadow-primary-focus);
  }

  .form-field input::placeholder { color: var(--color-muted); opacity: 0.6; }

  .form-note {
    font-size: 12px;
    color: var(--color-muted);
    text-align: center;
  }

  .lead-magnet-success { text-align: center; }

  .success-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .success-desc {
    font-size: 15px;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  .lead-magnet-error { text-align: center; }

  .error-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .error-desc {
    font-size: 15px;
    color: var(--color-muted);
  }

  .error-desc a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Tech Stack Marquee ── */
  .tech-marquee-section {
    padding: 32px 0 40px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);
  }

  .marquee-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 20px;
  }

  .marquee-track {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .marquee-inner {
    display: flex;
    gap: 12px;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .marquee-item:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .marquee-logo {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0.6;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .marquee-item:hover .marquee-logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Client Results Counter ── */
  .results-counter-section {
    background: var(--color-navy);
    color: var(--color-white);
  }
  .results-counter-section .section-eyebrow { color: var(--color-primary); }
  .results-counter-section .section-title { color: var(--color-white); }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }
  .result-card {
    padding: 32px 16px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
    background: color-mix(in srgb, var(--color-white) 4%, transparent);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .result-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
  }
  .result-number {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }
  .result-label { font-size: 14px; color: color-mix(in srgb, var(--color-white) 65%, transparent); }

  /* ── Before / After ── */
  .ba-section { background: var(--color-surface); }
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .ba-arrow {
    font-size: 36px;
    font-weight: 800;
    color: var(--color-primary);
    animation: pulse-arrow 2s ease-in-out infinite;
  }
  @keyframes pulse-arrow {
    0%, 100% { opacity: 1; transform: translateX(0); }
    50% { opacity: 0.6; transform: translateX(6px); }
  }
  .ba-card {
    padding: 32px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .ba-before { border-color: color-mix(in srgb, var(--color-muted) 40%, var(--color-border)); }
  .ba-after { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
  .ba-title { font-size: 18px; font-weight: 800; margin-bottom: 20px; }
  .ba-tools-chaos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 20px;
  }
  .ba-tool {
    padding: 8px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
  .ba-tool-disconnected { border-color: color-mix(in srgb, var(--color-muted) 35%, var(--color-border)); }
  .ba-unified { text-align: center; margin-bottom: 20px; }
  .ba-hub {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--primary) 10%, var(--color-surface));
    border: 2px solid var(--color-primary);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 12px;
  }
  .ba-hub-icon { color: var(--color-primary); }
  .ba-spokes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }
  .ba-spokes span {
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--primary) 8%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--primary) 20%, var(--color-border));
    color: var(--color-primary);
  }
  .ba-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .ba-list li { font-size: 14px; padding-left: 22px; position: relative; }
  .ba-list-bad li { color: var(--color-muted); }
  .ba-list-bad li::before { content: '✗'; position: absolute; left: 0; color: var(--color-muted); font-weight: 700; }
  .ba-list-good li { color: var(--color-text); }
  .ba-list-good li::before { content: '✓'; position: absolute; left: 0; color: var(--color-primary); font-weight: 700; }

  /* ── Testimonials ── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .testimonial-card {
    padding: 32px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .testimonial-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .testimonial-quote {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 20px;
    flex: 1;
  }
  .testimonial-quote::before { content: '"'; }
  .testimonial-meta { border-top: 1px solid var(--color-border); padding-top: 16px; }
  .testimonial-meta strong { display: block; font-size: 14px; margin-bottom: 2px; }
  .testimonial-meta span { font-size: 13px; color: var(--color-muted); }

  /* ── ROI Calculator ── */
  .roi-section { background: var(--color-surface); }
  .roi-inputs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }
  .roi-field { display: flex; flex-direction: column; gap: 6px; }
  .roi-field label { font-size: 13px; font-weight: 600; color: var(--color-text); }
  .roi-field input {
    padding: 10px 14px;
    font-size: 16px;
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .roi-field input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--shadow-primary-focus);
  }
  .roi-input-wrap { position: relative; display: flex; }
  .roi-prefix {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-muted);
    pointer-events: none;
  }
  .roi-input-wrap input { padding-left: 28px; width: 100%; }
  .roi-results { text-align: center; padding-top: 24px; border-top: 1px solid var(--color-border); }
  .roi-results h3 { font-size: 18px; font-weight: 800; margin-bottom: 24px; }
  .roi-stats { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
  .roi-stat { flex: 1; min-width: 140px; }

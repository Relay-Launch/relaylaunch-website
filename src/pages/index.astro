---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const webhookUrl = import.meta.env.PUBLIC_LEAD_MAGNET_WEBHOOK_URL || '#';
---

<Layout
  title="RelayLaunch | Build Smarter. Launch Faster. Grow With Purpose."
  description="RelayLaunch builds unified digital infrastructure for small businesses. One connected system replacing the 5 disconnected tools draining your time and money."
  canonicalUrl="https://www.relaylaunch.com/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'RelayLaunch',
    url: 'https://www.relaylaunch.com',
    description: 'RelayLaunch builds unified digital infrastructure for small businesses.',
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="hero section hero-gradient section-hero-enhanced">
    <div class="container">
      <div class="badge badge-primary hero-badge animate-fade-in-up">Veteran-Owned · Digital Infrastructure Consultancy</div>
      <h1 class="hero-headline animate-fade-in-up" style="animation-delay: 0.1s;">
        Your business runs on 6 tools.<br />
        <span class="text-accent">None of them talk to each other.</span>
      </h1>
      <p class="hero-sub animate-fade-in-up" style="animation-delay: 0.2s;">
        37% of small businesses have a website but zero automation. The rest are paying $300–500/month
        for disconnected platforms and losing 5–10 hours a week to manual work that a connected system
        handles automatically. RelayLaunch replaces the entire stack with one unified system — so you
        can stop managing software and start running your business.
      </p>
      <div class="hero-actions animate-fade-in-up" style="animation-delay: 0.3s;">
        <Button variant="primary" href="/complete-analysis" size="lg">Get Your Free Assessment →</Button>
        <Button variant="outline" href="/case-studies/luxury-wellness-spa" size="lg">See a Real Build</Button>
      </div>
      <p class="hero-no-commit animate-fade-in-up" style="animation-delay: 0.38s;">
        No commitment required. Discovery call is free.
      </p>
      <div class="hero-trust animate-fade-in-up" style="animation-delay: 0.45s;">
        <div class="trust-item">
          <span class="trust-check">✓</span> USMC Veteran-Owned
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> Fortune 500 Engineering
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> Fixed, Transparent Pricing
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span> One System, Not 6 Tools
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ LEAD MAGNET -->
  <section class="section lead-magnet-section">
    <div class="container">
      <div class="lead-magnet-inner card">
        <div class="lead-magnet-text">
          <span class="section-eyebrow">Free Download</span>
          <h2 class="lead-magnet-title">Digital Readiness Assessment</h2>
          <p class="lead-magnet-desc">
            A 1-page checklist to see if your business has outgrown its current digital setup.
            Score yourself across 10 areas, from tool sprawl to automation maturity, and find out
            where you're leaving time and money on the table.
          </p>
        </div>
        <div class="lead-magnet-form-wrap">
          <form
            id="lead-magnet-form"
            class="lead-magnet-form"
            data-webhook={webhookUrl}
            novalidate
          >
            <div class="form-field">
              <label for="lm-name">Name</label>
              <input type="text" id="lm-name" name="name" required autocomplete="name" placeholder="Your name" />
            </div>
            <div class="form-field">
              <label for="lm-email">Email</label>
              <input type="email" id="lm-email" name="email" required autocomplete="email" placeholder="you@company.com" />
            </div>
            <Button type="submit" variant="primary" class="w-full justify-center">Get the Assessment →</Button>
            <p class="form-note">No spam. Unsubscribe anytime.</p>
          </form>
          <div id="lead-magnet-success" class="lead-magnet-success" hidden>
            <p class="success-title">You're in.</p>
            <p class="success-desc">
              Check your inbox. Your Digital Readiness Assessment is on the way.
            </p>
          </div>
          <div id="lead-magnet-error" class="lead-magnet-error" hidden>
            <p class="error-title">Something went wrong.</p>
            <p class="error-desc">
              Please try again, or reach out to us at <a href="/contact">contact</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ STATS BAR -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <div class="stat-number">33.2M</div>
        <div class="stat-label">small businesses in the US</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">37%</div>
        <div class="stat-label">have a website but zero automation</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">$300–500</div>
        <div class="stat-label">per month on disconnected tools</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <div class="stat-number">5–10 hrs</div>
        <div class="stat-label">lost every week to manual data entry</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ WHY RELAYLAUNCH -->
  <section class="section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">Why RelayLaunch</span>
        <h2 class="section-title" style="margin-bottom: 40px;">Built different. On purpose.</h2>
      </div>

      <div class="why-grid reveal-stagger">
        <div class="why-card">
          <div class="why-icon">🎖️</div>
          <h3>Veteran-Owned, Mission-Driven</h3>
          <p>USMC discipline meets enterprise engineering experience. Structured execution, clear communication, and zero fluff. The same rigor that managed Fortune 500 integrations, applied to your business.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🏗️</div>
          <h3>Infrastructure-First + AI</h3>
          <p>We don't bolt AI onto a broken foundation. We build the infrastructure first: website, automations, integrations. Then we layer in AI where it actually saves time and money.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🔗</div>
          <h3>Full-Service, One Partner</h3>
          <p>Web, SEO, AI agents, workflow automation, systems integration, cloud infrastructure. All from one team. No coordinating between five freelancers who don't talk to each other.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">💲</div>
          <h3>Clear Fixed Pricing</h3>
          <p>Market-validated tiers with defined scope and deliverables. You know what you're getting and what it costs before anything starts. No hourly surprises, no scope creep.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PROBLEM -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="two-col-text reveal">
          <span class="section-eyebrow">The Problem</span>
          <h2 class="section-title">You became a business owner. Not a software administrator.</h2>
          <p class="section-sub" style="margin-bottom: 24px;">
            You didn't sign up to be your own IT department, social media manager, email marketer,
            and data analyst. But here you are, logging into 6 different dashboards, copying
            information between platforms, doing manually what a system should handle automatically.
          </p>
          <ul class="checklist problem-list">
            <li>5–8 platforms that require separate logins and don't share data</li>
            <li>Manual work between systems eating 5–10 hours every week</li>
            <li>No unified view, so decisions rely on gut feeling instead of actual data</li>
            <li>Customers experiencing inconsistent branding across every touchpoint</li>
            <li>Money going out every month for tools duplicating the same features</li>
          </ul>
        </div>
        <div class="tool-chaos">
          <div class="tool-grid">
            {['Website', 'Email', 'Social', 'Scheduling', 'Payments', 'Analytics', 'Automation', 'CRM'].map((tool, i) => (
              <div class:list={['tool-item', { dim: i > 3 }]}>{tool}</div>
            ))}
          </div>
          <div class="tool-chaos-label">5–8 tools. None connected. All manual.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SOLUTION -->
  <section class="section solution-section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">The Solution</span>
        <h2 class="section-title">One system. One dashboard.<br />Everything connected.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          RelayLaunch builds unified digital infrastructure: your website, automations, email, social,
          and reporting all wired together. When a new client books, the system follows up automatically.
          When a post goes out, it goes to all four platforms. When something needs your attention, it
          surfaces to one dashboard.
        </p>
      </div>

      <div class="solution-grid reveal-stagger">
        <div class="solution-card">
          <div class="solution-icon">⚡</div>
          <h3>Live Automation Workflows</h3>
          <p>Appointment follow-ups, review requests, lead nurturing, social publishing. Built once, running 24/7 for $6/month in infrastructure.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">🔗</div>
          <h3>Everything Connected</h3>
          <p>Your website, email, CRM, social, and scheduling all talk to each other. No more copy-pasting between platforms. No more manual reports.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">📊</div>
          <h3>One Unified Dashboard</h3>
          <p>All your metrics, alerts, bookings, and approvals in a single Slack dashboard. Your business briefs you every morning, not the other way around.</p>
        </div>
        <div class="solution-card">
          <div class="solution-icon">🌐</div>
          <h3>Built to Be Found</h3>
          <p>Mobile-first, SEO-optimized websites built in Astro. Faster than WordPress, cheaper to host ($0 on Cloudflare), and designed to rank.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ TECH STACK MARQUEE -->
  <section class="tech-marquee-section">
    <div class="container">
      <p class="marquee-label">Built With Industry-Leading Tools</p>
    </div>
    <div class="marquee-track">
      <div class="marquee-inner">
        <span class="marquee-item">Astro</span>
        <span class="marquee-item">Cloudflare</span>
        <span class="marquee-item">n8n</span>
        <span class="marquee-item">Tailwind CSS</span>
        <span class="marquee-item">Slack</span>
        <span class="marquee-item">MailChimp</span>
        <span class="marquee-item">GitHub</span>
        <span class="marquee-item">Sage Intacct</span>
        <span class="marquee-item">Claude AI</span>
        <span class="marquee-item">Stripe</span>
        <span class="marquee-item">Google Analytics</span>
        <span class="marquee-item">Calendly</span>
        <span class="marquee-item">Astro</span>
        <span class="marquee-item">Cloudflare</span>
        <span class="marquee-item">n8n</span>
        <span class="marquee-item">Tailwind CSS</span>
        <span class="marquee-item">Slack</span>
        <span class="marquee-item">MailChimp</span>
        <span class="marquee-item">GitHub</span>
        <span class="marquee-item">Sage Intacct</span>
        <span class="marquee-item">Claude AI</span>
        <span class="marquee-item">Stripe</span>
        <span class="marquee-item">Google Analytics</span>
        <span class="marquee-item">Calendly</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PACKAGES -->
  <section class="section" id="services">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">Service Packages</span>
        <h2 class="section-title">Find the right level of engagement.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          Every engagement starts with a conversation. We match you to the right package based on
          where you are and where you want to go.
        </p>
      </div>

      <div class="packages-grid reveal-stagger">
        <div class="card pkg-card pkg-card-start-here">
          <div class="pkg-start-badge">Start Here</div>
          <div class="pkg-name">Complete Analysis</div>
          <div class="pkg-tagline">Business Infrastructure Diagnostic</div>
          <div class="pkg-price">$1,500–$3,000</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>8-area business audit</li>
            <li>Tool stack &amp; ops review</li>
            <li>AI readiness assessment</li>
            <li>20–30 page roadmap report</li>
          </ul>
          <Button variant="outline" href="/complete-analysis" class="pkg-cta">Learn More</Button>
        </div>

        <div class="card pkg-card">
          <div class="pkg-name">Launch</div>
          <div class="pkg-tagline">Digital Infrastructure Build</div>
          <div class="pkg-price">$2,500–$5,000</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Custom website (5–10 pages)</li>
            <li>3–5 automation workflows</li>
            <li>Email sequence setup</li>
            <li>30-day launch support</li>
          </ul>
          <Button variant="outline" href="/services" class="pkg-cta">Learn More</Button>
        </div>

        <div class="card featured pkg-card">
          <div class="badge badge-solid-primary" style="margin-bottom: 16px;">Most Popular</div>
          <div class="pkg-name">Run</div>
          <div class="pkg-tagline">Monthly Operations Retainer</div>
          <div class="pkg-price">$500–$1,000/mo</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Monthly content (blog + social)</li>
            <li>Automation monitoring</li>
            <li>SEO optimization &amp; reporting</li>
            <li>Monthly strategy call</li>
            <li>Priority Slack support</li>
          </ul>
          <Button variant="primary" href="/services" class="pkg-cta">Learn More</Button>
        </div>

        <div class="card pkg-card">
          <div class="pkg-name">Scale</div>
          <div class="pkg-tagline">Premium Growth Retainer</div>
          <div class="pkg-price">$1,000–$2,500/mo</div>
          <ul class="checklist" style="margin-top: 20px;">
            <li>Everything in Run</li>
            <li>AI agent setup &amp; management</li>
            <li>Advanced automation builds</li>
            <li>Fractional AI Ops advisory</li>
            <li>Quarterly business review</li>
          </ul>
          <Button variant="outline" href="/services" class="pkg-cta">Learn More</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CASE STUDY TEASER -->
  <section class="section case-study-teaser">
    <div class="container">
      <div class="cs-inner">
        <div class="cs-text reveal">
          <span class="section-eyebrow">Proof of Concept</span>
          <h2 class="section-title">Real client. Real numbers.<br />Day one.</h2>
          <p style="color: var(--color-muted); margin-bottom: 24px;">
            A luxury wellness spa at a five-star resort in South Florida was spending
            $342/month on disconnected tools, losing 8–12 hours a week to manual work,
            and missing leads because no system existed to follow up when someone visited the website
            or inquired about services. RelayLaunch replaced the entire stack with one connected
            system for $51/month, and the real value went far beyond the cost savings.
          </p>
          <div class="cs-stats">
            <div class="cs-stat">
              <div class="stat-number" style="color: var(--color-primary);">$342 → $51</div>
              <div class="stat-label">monthly infrastructure cost</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">8–12 hrs</div>
              <div class="stat-label">of manual work reclaimed every week</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">11</div>
              <div class="stat-label">automations catching leads 24/7</div>
            </div>
          </div>
          <p style="color: var(--color-muted); font-size: 14px; margin-top: 16px; margin-bottom: 8px;">
            The $3,492 annual tool savings is just the start. Factor in the missed bookings from zero follow-up,
            the invisible SEO presence, the leads who visited the site and left with no way to reconnect,
            and the hours spent copying data between platforms — the real cost of disconnected systems was
            tens of thousands in missed opportunity every year.
          </p>
          <Button variant="primary" href="/case-studies/luxury-wellness-spa" class="mt-6">Read the Full Case Study →</Button>
        </div>
        <div class="cs-deliverables">
          <div class="card" style="padding: 24px;">
            <p class="section-eyebrow" style="margin-bottom: 16px;">What Was Built</p>
            <ul class="checklist">
              <li>15-page custom Astro 6 website</li>
              <li>11 n8n automation workflows</li>
              <li>5 MailChimp email sequences</li>
              <li>30 days of social content (4 platforms)</li>
              <li>8 SEO blog posts</li>
              <li>Slack automated daily dashboard</li>
              <li>Membership platform (free + paid tiers)</li>
              <li>Corporate wellness sub-site</li>
              <li>Full platform migration</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CASE STUDY 2: ERP MIGRATION -->
  <section class="section case-study-teaser-2">
    <div class="container">
      <div class="cs-inner">
        <div class="cs-text reveal">
          <span class="section-eyebrow">Enterprise Scale</span>
          <h2 class="section-title">Three siloed systems.<br />One unified platform.</h2>
          <p style="color: var(--color-muted); margin-bottom: 24px;">
            A global events and trade show company had three separate QuickBooks instances
            with no consolidation, a 15+ day month-end close, and their UK parent had frozen
            acquisitions until financial infrastructure was modernized. RelayLaunch architected
            the full migration to Sage Intacct.
          </p>
          <div class="cs-stats">
            <div class="cs-stat">
              <div class="stat-number" style="color: var(--color-primary);">3 → 1</div>
              <div class="stat-label">siloed systems unified</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">10-day</div>
              <div class="stat-label">close cycle achieved (from 15+)</div>
            </div>
            <div class="cs-stat">
              <div class="stat-number">7</div>
              <div class="stat-label">enterprise deliverables</div>
            </div>
          </div>
          <Button variant="primary" href="/case-studies/events-erp-migration" class="mt-6">Read the Full Case Study →</Button>
        </div>
        <div class="cs-deliverables">
          <div class="card" style="padding: 24px;">
            <p class="section-eyebrow" style="margin-bottom: 16px;">What Was Delivered</p>
            <ul class="checklist">
              <li>Target-state architecture design</li>
              <li>Integration blueprint (API contracts + data flows)</li>
              <li>Field-level migration mapping workbook</li>
              <li>10-day close calendar with RACI</li>
              <li>SOPs &amp; runbooks for every close task</li>
              <li>3-wave go-live cutover plan</li>
              <li>Complete handoff bundle + training</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FOUNDER -->
  <section class="section founder-section">
    <div class="container">
      <div class="two-col">
        <div>
          <span class="section-eyebrow">Who Builds This</span>
          <h2 class="section-title">Cloud engineer.<br />Marine veteran.<br />Small business advocate.</h2>
          <p style="color: var(--color-muted); margin-bottom: 20px;">
            Victor David Medina brings Fortune 500 infrastructure experience to small business problems.
            The same engineering discipline that managed 1,000-user enterprise integrations at a billion-dollar company,
            now applied to local businesses that deserve the same quality systems.
          </p>
          <div class="credentials">
            <div class="credential">
              <span class="cred-icon">🏗️</span>
              <div>
                <strong>Cloud Engineering</strong>
                <p>DNS, CDN, CI/CD, security headers. Enterprise-grade infrastructure for small business budgets.</p>
              </div>
            </div>
            <div class="credential">
              <span class="cred-icon">🎖️</span>
              <div>
                <strong>USMC Sergeant (E-5)</strong>
                <p>Structured execution and mission completion. These are not aspirational values. They are ingrained ones.</p>
              </div>
            </div>
            <div class="credential">
              <span class="cred-icon">⚙️</span>
              <div>
                <strong>Enterprise Ops Background</strong>
                <p>Fortune 500 companies (1,000-user integrations, $1B+ transaction volume), cross-border post-merger systems. Built for complexity.</p>
              </div>
            </div>
          </div>
          <Button variant="outline" href="/about" class="mt-7">More About Victor →</Button>
        </div>
        <div class="advantage-card card">
          <p class="section-eyebrow" style="margin-bottom: 16px;">The Difference</p>
          <div class="compare-row">
            <div class="compare-col">
              <p class="compare-label">Web Designer</p>
              <ul class="compare-list">
                <li>Builds a website and hands it over</li>
                <li>Uses templates and page builders</li>
                <li>Bolts on automation as an upsell</li>
                <li>Hands you credentials and disappears</li>
              </ul>
            </div>
            <div class="compare-col accent-side">
              <p class="compare-label accent-label">RelayLaunch</p>
              <ul class="compare-list">
                <li>Builds an operating system for your business</li>
                <li>Custom-coded in Astro + Tailwind, no templates</li>
                <li>Automation built in from day one</li>
                <li>Daily dashboard briefings in Slack</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CLIENT RESULTS COUNTER -->
  <section class="section results-counter-section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">Proven Results</span>
        <h2 class="section-title" style="margin-bottom: 48px;">Numbers that speak for themselves.</h2>
      </div>
      <div class="results-grid">
        <div class="result-card" data-count="3492" data-prefix="$">
          <div class="result-number">$3,492</div>
          <div class="result-label">annual tool savings</div>
        </div>
        <div class="result-card" data-count="11">
          <div class="result-number">11</div>
          <div class="result-label">workflows automated</div>
        </div>
        <div class="result-card" data-count="12" data-suffix=" hrs/wk">
          <div class="result-number">12 hrs/wk</div>
          <div class="result-label">of manual work eliminated</div>
        </div>
        <div class="result-card" data-count="85" data-suffix="%">
          <div class="result-number">85%</div>
          <div class="result-label">reduction in tool costs</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ BEFORE / AFTER -->
  <section class="section ba-section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">The Transformation</span>
        <h2 class="section-title" style="margin-bottom: 48px;">From chaos to clarity.</h2>
      </div>
      <div class="ba-grid">
        <div class="ba-card ba-before">
          <h3 class="ba-title">Before RelayLaunch</h3>
          <div class="ba-tools-chaos">
            <div class="ba-tool ba-tool-disconnected">Website</div>
            <div class="ba-tool ba-tool-disconnected">Email</div>
            <div class="ba-tool ba-tool-disconnected">Social</div>
            <div class="ba-tool ba-tool-disconnected">CRM</div>
            <div class="ba-tool ba-tool-disconnected">Scheduling</div>
            <div class="ba-tool ba-tool-disconnected">Payments</div>
          </div>
          <ul class="ba-list ba-list-bad">
            <li>6 separate logins</li>
            <li>$300–500/mo in subscriptions</li>
            <li>5–10 hrs/week manual work</li>
            <li>Zero data connection</li>
          </ul>
        </div>
        <div class="ba-arrow">→</div>
        <div class="ba-card ba-after">
          <h3 class="ba-title">After RelayLaunch</h3>

---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
import ServiceIcons from '@/components/ServiceIcons.astro';

const serviceSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Complete Analysis: Business Infrastructure Diagnostic',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://www.relaylaunch.com' },
    description: 'An 8-area diagnostic of your entire business infrastructure, covering operations, tech stack, AI readiness, digital footprint, and more, delivered as a 15–20 page professional report with a prioritized roadmap in 5–7 business days.',
    url: 'https://www.relaylaunch.com/complete-analysis/',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1500',
      highPrice: '3000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Launch: Digital Infrastructure Build',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://www.relaylaunch.com' },
    description: 'One-time project build of unified digital infrastructure: custom website, automation workflows, email sequences, social scheduling, and a single connected dashboard replacing disconnected tools.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '2500',
      highPrice: '5000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Run: Monthly Digital Operations Retainer',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://www.relaylaunch.com' },
    description: 'Monthly retainer for ongoing digital operations support: social content, SEO and blog maintenance, automation monitoring, and monthly strategy calls. 3-month minimum.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '500',
      highPrice: '1000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Scale: Premium Growth Retainer',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://www.relaylaunch.com' },
    description: 'Premium monthly retainer for businesses scaling their digital infrastructure: expanded deliverables, priority support, advanced automation builds, and strategic advisory. 6-month minimum.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1000',
      highPrice: '2500',
    },
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Do I have to commit to a retainer right away?', acceptedAnswer: { '@type': 'Answer', text: 'No. The Complete Analysis is a standalone engagement with no strings attached. You get a 15–20 page report, keep it, and decide what to do next. Hire us, DIY it, or do nothing for now. Most clients choose to continue, but that\'s entirely your call.' } },
    { '@type': 'Question', name: 'Who owns what you build?', acceptedAnswer: { '@type': 'Answer', text: 'You own 100% of everything we build: website, code, automations, content, accounts, and domains. No vendor lock-in. No dependencies. If you walk away tomorrow, your systems keep running.' } },
    { '@type': 'Question', name: 'How long does a Complete Analysis take?', acceptedAnswer: { '@type': 'Answer', text: 'Five to seven business days from intake completion. We audit all 8 areas of your business, compile findings, and deliver a 15–20 page professional report with a 90-minute walkthrough call.' } },
    { '@type': 'Question', name: "What's the difference between Launch and Run?", acceptedAnswer: { '@type': 'Answer', text: 'Launch is a one-time build. We design and deploy your unified infrastructure, hand it off, and you run it. Run is ongoing operations. We stay on as your digital ops team, keeping systems optimized and content flowing. Most businesses start with Launch, then add Run once the foundation is solid.' } },
    { '@type': 'Question', name: 'Can I switch tiers once I start?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. You can upgrade from Run to Scale at any renewal point (monthly). Downgrading follows the same cadence. We\'ll never lock you into a tier that no longer fits where your business is.' } },
    { '@type': 'Question', name: 'Do I need to be local to work with you?', acceptedAnswer: { '@type': 'Answer', text: 'No. We work with small businesses across the U.S. remotely. Discovery calls, presentations, and strategy sessions are all via video. Geography is never a barrier.' } },
    { '@type': 'Question', name: 'What if I\'m already mid-build with another provider?', acceptedAnswer: { '@type': 'Answer', text: 'We can audit what exists and take it from there. The Complete Analysis covers your current stack regardless of who built it. We\'re not here to start from zero if there\'s solid work worth preserving.' } },
    { '@type': 'Question', name: 'How is this different from hiring a freelancer?', acceptedAnswer: { '@type': 'Answer', text: 'Freelancers deliver a project and move on. We deliver infrastructure designed to run your business, then stay accountable to its performance. We combine strategy, build, and operations in a single engagement, not three separate contracts with three separate people.' } },
    { '@type': 'Question', name: 'What industries do you work with?', acceptedAnswer: { '@type': 'Answer', text: 'Any small business that serves clients directly: wellness and spas, professional services, trades and contractors, fitness studios, restaurants, retail, and more. The infrastructure problems are the same across industries: disconnected tools, manual processes, and no unified view of operations.' } },
    { '@type': 'Question', name: 'Do you offer AI agents as part of your services?', acceptedAnswer: { '@type': 'Answer', text: 'Every engagement includes 8 AI agent divisions (the Relay Method Ops Suite) covering infrastructure, security, engineering, content, brand, automation, QA, and strategy. The Run tier adds 1 custom growth division and Scale adds 2 custom growth divisions built for your business. These handle content creation, lead qualification, client follow-up, and growth. We train them on your brand and workflows, not generic chatbots.' } },
  ],
};
---

<Layout
  title="Services | RelayLaunch | Digital Infrastructure for Small Business"
  description="Clear scope, fixed pricing, no surprises. From a $1,500 diagnostic to full-service retainers with custom AI agents. See exactly what you get at every tier before you commit."
  canonicalUrl="https://www.relaylaunch.com/services/"
  jsonLd={[...serviceSchemas, faqSchema]}
  breadcrumbs={[
    { name: 'Home', url: 'https://www.relaylaunch.com/' },
    { name: 'Services', url: 'https://www.relaylaunch.com/services/' },
  ]}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section svc-hero">
    <div class="svc-hero-grid" aria-hidden="true"></div>
    <div class="container">
      <div class="svc-hero-content">
        <span class="svc-hero-eyebrow">Service Packages</span>
        <h1 class="svc-hero-headline">
          Clear scope. Fixed price.<br />
          <span class="svc-accent">No surprises.</span>
        </h1>
        <p class="svc-hero-sub">
          Every package has defined deliverables and transparent pricing. We
          have a conversation before anything starts, and you'll know exactly
          what you're getting. Pick where you want to begin.
        </p>
        <div class="svc-hero-tiers">
          <a href="#complete-analysis-highlight" class="svc-tier-chip svc-tier-active">Complete Analysis</a>
          <a href="#launch" class="svc-tier-chip">Launch</a>
          <a href="#run" class="svc-tier-chip">Run</a>
          <a href="#scale" class="svc-tier-chip">Scale</a>
        </div>
        <div class="svc-hero-actions">
          <Button variant="primary" href="/contact" size="lg">Start a Conversation →</Button>
          <Button variant="outline" href="/complete-analysis" size="lg">Start with a Complete Analysis</Button>
        </div>
        <p class="svc-hero-note">
          No commitment required. Discovery call is free.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ RECOMMENDED FIRST STEP -->
  <section class="section" id="complete-analysis-highlight">
    <div class="container">
      <div class="ca-highlight card addon-card-featured">
        <div class="ca-highlight-inner">
          <div class="ca-highlight-text">
            <div class="addon-start-badge">Recommended First Step</div>
            <h2 style="font-size: clamp(24px, 3.5vw, 36px); font-weight: 800; margin-bottom: 8px; display: flex; align-items: center; gap: 10px;"><ServiceIcons icon="complete-analysis" size={32} /> Complete Analysis</h2>
            <div class="ca-highlight-price price-primary">$1,500–$3,000</div>
            <p style="color: var(--color-muted); font-size: 15px; line-height: 1.7; margin-bottom: 20px;">
              Before you spend a dollar on building, know exactly what needs building. A focused
              deep dive across eight areas of your business, delivered as a 15–20 page report
              with a prioritized roadmap in 5–7 business days. You keep it whether you hire us or not.
            </p>
            <ul class="checklist">
              <li>8-area business infrastructure audit</li>
              <li>Tool stack & ops review</li>
              <li>AI readiness assessment</li>
              <li>Prioritized roadmap with cost projections</li>
              <li>Delivered in 5–7 business days</li>
            </ul>
            <div style="margin-top: 24px; display: flex; gap: 12px; flex-wrap: wrap;">
              <Button variant="primary" href="/complete-analysis" size="lg">Learn More →</Button>
              <Button variant="outline" href="/contact" size="lg">Book a Discovery Call</Button>
            </div>
          </div>
          <div class="ca-highlight-sidebar">
            <div class="ca-highlight-stat">
              <div class="stat-number" style="color: var(--color-primary); font-size: 28px;">5–7 days</div>
              <div class="stat-label">from intake to deliverable</div>
            </div>
            <div class="ca-highlight-stat">
              <div class="stat-number" style="color: var(--color-primary); font-size: 28px;">15–20 pg</div>
              <div class="stat-label">professional roadmap report</div>
            </div>
            <div class="ca-highlight-stat">
              <div class="stat-number" style="color: var(--color-primary); font-size: 28px;">$0</div>
              <div class="stat-label">commitment beyond the analysis</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SERVICE TIERS -->
  <section class="section" id="tiers">
    <div class="container">
      <span class="section-eyebrow">Service Tiers</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Three tiers. Pick the one that fits.</h2>
      <p class="section-sub" style="max-width: var(--container-narrow); margin-bottom: 48px;">
        Need a one-time build? A team that stays on and runs things monthly? Or a full growth engine
        with AI agents and strategic advisory? There's a tier for wherever you are right now.
      </p>

      <div class="tiers-grid reveal-stagger">
        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 1</span>
          <h3 id="launch" class="tier-name"><ServiceIcons icon="launch" size={28} /> Launch</h3>
          <div class="tier-price price-primary">$2,500–$5,000 <span class="price-label">one-time</span></div>
          <p class="tier-best-for">Best for businesses starting fresh or replacing a broken setup.</p>
          <p class="tier-desc">The full Relay Method Ops Suite in build mode. 8 AI divisions actively construct, test, and harden your project. Every commit reviewed. Every page audited. Every deployment gated. You walk away with a system that works.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>8 AI agent divisions (Relay Method Ops Suite)</li>
            <li>Custom website (5–10 pages)</li>
            <li>3–5 automation workflows</li>
            <li>Email sequence setup</li>
            <li>Tool consolidation &amp; integration</li>
            <li>Unified dashboard</li>
            <li>30-day launch support</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Get Started →</Button>
        </div>

        <div class="card tier-card tier-featured">
          <div class="badge badge-solid-primary" style="margin-bottom: 12px;">Most Popular</div>
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 2</span>
          <h3 id="run" class="tier-name"><ServiceIcons icon="run" size={28} /> Run</h3>
          <div class="tier-price price-primary">$500–$1,000<span class="price-label">/month</span></div>
          <p class="tier-note">3-month minimum</p>
          <p class="tier-best-for">Best for businesses with infrastructure in place that need ongoing operations support.</p>
          <p class="tier-desc">Ongoing operations with the Ops Suite in watch mode, plus one custom growth division we activate and run for your business. We build it, run it, and refine it monthly. You get a dedicated ops team and a working AI growth engine without hiring either.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Launch</li>
            <li>8 AI agent divisions in ongoing ops mode</li>
            <li>+1 custom growth division (choose: Growth, Sales, or Social)</li>
            <li>Monthly content (blog + social) powered by AI</li>
            <li>Automation monitoring &amp; new workflows</li>
            <li>SEO optimization &amp; reporting</li>
            <li>Monthly strategy call</li>
            <li>Priority Slack support</li>
          </ul>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start Running →</Button>
        </div>

        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 3</span>
          <h3 id="scale" class="tier-name"><ServiceIcons icon="scale" size={28} /> Scale</h3>
          <div class="tier-price price-primary">$1,000–$2,500<span class="price-label">/month</span></div>
          <p class="tier-note">6-month minimum</p>
          <p class="tier-best-for">Best for multi-location businesses or teams ready for aggressive growth.</p>
          <p class="tier-desc">Full operational coverage plus two custom growth divisions working together. Paired agents don't just automate tasks. They automate workflows. Monthly optimization and the compounding advantage of a 6-month partnership.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Run</li>
            <li>+2 custom growth divisions (choose 2: Growth, Sales, or Social)</li>
            <li>Connected agents that feed each other's results</li>
            <li>Advanced workflow automation &amp; integrations</li>
            <li>AI-powered outreach &amp; lead qualification</li>
            <li>Multi-location or multi-brand support</li>
            <li>Quarterly business review with growth roadmap</li>
            <li>Dedicated AI operations advisory</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Let's Scale →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ ADDITIONAL ENGAGEMENTS -->
  <section class="section" id="additional">
    <div class="container">
      <span class="section-eyebrow">Additional Engagements</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Standalone services you can add anytime.</h2>
      <p class="section-sub" style="max-width: var(--container-narrow); margin-bottom: 48px;">
        You can add these engagements to any tier or buy them independently.
      </p>

      <div class="addons-grid">
        <div class="card addon-card">
          <h3>Custom AI Agent Build</h3>
          <div class="addon-price price-secondary">$1,500–$3,000</div>
          <p>We design and build a specialized AI agent for your business and hand you full ownership. For customer support, lead qualification, content generation, or internal knowledge retrieval. You get documentation, deployment, and integration. Want us to run it? Pair it with a Run or Scale retainer.</p>
        </div>

        <div class="card addon-card">
          <h3>Workflow Automation Build</h3>
          <div class="addon-price price-secondary">$1,000–$2,500 per workflow</div>
          <p>Custom n8n workflow design, build, and deployment. Connect your CRM, email, scheduling, invoicing, and any tool with an API into automated sequences that run 24/7.</p>
        </div>

        <div class="card addon-card">
          <h3>AI Operations Partner</h3>
          <div class="addon-price price-secondary">$2,000–$4,000/month</div>
          <p>A dedicated AI operations advisor embedded in your business. We identify the highest-value automations and manage your AI agent fleet. We continuously find time and cost savings you'd miss from inside the day-to-day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <span class="section-eyebrow">Common Questions</span>
      <h2 class="section-title" style="margin-bottom: 12px;">Questions we hear on almost every discovery call.</h2>
      <p class="section-sub" style="max-width: var(--container-narrow); margin-bottom: 48px;">
        Honest answers. No fine print. No surprises.
      </p>

      <div class="faq-list reveal-stagger">
        <details class="faq-item">
          <summary class="faq-question">Do I have to commit to a retainer right away?</summary>
          <div class="faq-answer">
            <p>No. The Complete Analysis is a standalone engagement with no strings attached. You get a 15–20 page report, keep it, and decide what to do next. Hire us, DIY it, or do nothing for now. Most clients choose to continue, but that's entirely your call.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Who owns what you build?</summary>
          <div class="faq-answer">
            <p>You own 100% of everything we build: website, code, automations, content, accounts, and domains. No vendor lock-in. No dependencies. If you walk away tomorrow, your systems keep running.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How long does a Complete Analysis take?</summary>
          <div class="faq-answer">
            <p>Five to seven business days from intake completion. We audit all 8 areas of your business, compile findings, and deliver a 15–20 page professional report with a 90-minute walkthrough call.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What's the difference between Launch and Run?</summary>
          <div class="faq-answer">
            <p><strong>Launch</strong> is a one-time build. We design and deploy your unified infrastructure, hand it off, and you run it. <strong>Run</strong> is ongoing operations. We stay on as your digital ops team, keeping systems optimized and content flowing. Most businesses start with Launch, then add Run once the foundation is solid.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Can I switch tiers once I start?</summary>
          <div class="faq-answer">
            <p>Yes. You can upgrade from Run to Scale at any renewal point (monthly). Downgrading follows the same cadence. We'll never lock you into a tier that no longer fits where your business is.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do I need to be local to work with you?</summary>
          <div class="faq-answer">
            <p>No. We work with small businesses across the U.S. remotely. Discovery calls, presentations, and strategy sessions are all via video. Geography is never a barrier.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What if I'm already mid-build with another provider?</summary>
          <div class="faq-answer">
            <p>We can audit what exists and take it from there. The Complete Analysis covers your current stack regardless of who built it. We're not here to start from zero if there's solid work worth preserving.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How is this different from hiring a freelancer?</summary>
          <div class="faq-answer">
            <p>Freelancers deliver a project and move on. We deliver infrastructure designed to run your business, then stay accountable to its performance. We combine strategy, build, and operations in a single engagement, not three separate contracts with three separate people.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What industries do you work with?</summary>
          <div class="faq-answer">
            <p>Any small business that serves clients directly: wellness and spas, professional services, trades and contractors, fitness studios, restaurants, retail, and more. The infrastructure problems are the same across industries: disconnected tools, manual processes, and no unified view of operations.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you offer AI agents as part of your services?</summary>
          <div class="faq-answer">
            <p>Every engagement includes 8 AI agent divisions (the Relay Method Ops Suite) covering infrastructure, security, engineering, content, brand, automation, QA, and strategy. The <strong>Run</strong> tier adds 1 custom growth division and <strong>Scale</strong> adds 2 custom growth divisions built for your business. These handle content creation, lead qualification, client follow-up, and growth. We train them on your brand and workflows, not generic chatbots.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ INDUSTRIES -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">Who We Work With</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Small businesses that serve clients directly.</h2>
      <p class="section-sub" style="max-width: var(--container-narrow); margin-bottom: 40px;">
        The infrastructure challenges are the same across industries: disconnected tools,
        manual processes, and zero automation. We solve them all.
      </p>
      <div class="industries-grid reveal-stagger">
        <div class="industry-item">
          <span class="industry-icon">💆</span>
          <span class="industry-name">Wellness & Spas</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">⚖️</span>
          <span class="industry-name">Professional Services</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🔧</span>
          <span class="industry-name">Trades & Contractors</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🏋️</span>
          <span class="industry-name">Fitness Studios</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🍽️</span>
          <span class="industry-name">Restaurants & Food</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🏪</span>
          <span class="industry-name">Retail & E-commerce</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🏥</span>
          <span class="industry-name">Healthcare & Clinics</span>
        </div>
        <div class="industry-item">
          <span class="industry-icon">🎓</span>
          <span class="industry-name">Education & Training</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Not sure where to start? That's normal.</h2>
      <p class="section-sub" style="margin: 16px auto 32px; max-width: var(--text-width-sm);">
        Most clients start with a conversation. Tell us where you are and what's not
        working. We'll be honest about whether we can help, and which package makes
        sense for your stage.
      </p>
      <Button variant="primary" href="/contact">Let's Talk →</Button>
      <p class="cta-no-commit">No commitment required. Discovery call is free.</p>
    </div>
  </section>

</Layout>

<script>
  // FAQ smooth accordion animation (P0-5)
  document.querySelectorAll('.faq-item').forEach((details) => {
    const answer = details.querySelector('.faq-answer') as HTMLElement;
    if (!answer) return;

    details.addEventListener('click', (e) => {
      const summary = (e.target as HTMLElement).closest('summary');
      if (!summary) return;

      e.preventDefault();

      if (details.hasAttribute('open')) {
        // Closing: animate then remove open
        answer.style.maxHeight = answer.scrollHeight + 'px';
        requestAnimationFrame(() => {
          answer.style.maxHeight = '0';
          answer.style.paddingBottom = '0';
        });
        answer.addEventListener('transitionend', () => {
          details.removeAttribute('open');
          answer.style.maxHeight = '';
          answer.style.paddingBottom = '';
        }, { once: true });
      } else {
        // Opening: set open then animate
        details.setAttribute('open', '');
        const height = answer.scrollHeight;
        answer.style.maxHeight = '0';
        answer.style.paddingBottom = '0';
        requestAnimationFrame(() => {
          answer.style.maxHeight = height + 'px';
          answer.style.paddingBottom = '20px';
        });
        answer.addEventListener('transitionend', () => {
          answer.style.maxHeight = '';
        }, { once: true });
      }
    });
  });
</script>

<style>
  /* ── Services Hero (distinct from homepage) ── */
  .svc-hero {
    background: var(--color-navy);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
    padding-top: 100px;
    padding-bottom: 80px;
    border-top: none;
  }

  .svc-hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--primary) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--primary) 5%, transparent) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 60% 50% at 80% 50%, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 80% 50%, black 20%, transparent 100%);
    pointer-events: none;
  }

  .svc-hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;

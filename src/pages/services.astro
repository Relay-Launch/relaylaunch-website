---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const serviceSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Signal — Visibility & Ops Audit',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'A focused audit of your business operations, digital presence, and tool stack. Identifies what\'s working, what\'s broken, and delivers a prioritized action plan.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '500',
      highPrice: '900',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Blueprint — Systems Strategy',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'Full growth roadmap and automation opportunity map including 90-day milestones, competitive landscape, and tech stack recommendations.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1200',
      highPrice: '2000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Relay — Build & Connect',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'Full build of unified digital infrastructure — website, automation workflows, email sequences, social scheduling, and a single dashboard. One connected system replacing disconnected tools.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1800',
      highPrice: '6000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Sustain — Monthly Growth Support',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'Ongoing monthly support including social content, SEO & blog maintenance, automation monitoring, performance reports, and priority support.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '300',
      highPrice: '500',
    },
  },
];
---

<Layout
  title="Services — RelayLaunch"
  description="RelayLaunch service packages for small businesses: Signal audit, Blueprint strategy, Relay full build, and Sustain monthly support."
  canonicalUrl="https://relaylaunch.com/services/"
  jsonLd={serviceSchemas}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero">
    <div class="container">
      <span class="section-eyebrow">Service Packages</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px);">
        Built for businesses ready<br />to run leaner and be seen more.
      </h1>
      <p class="section-sub">
        Every package is a defined scope with clear deliverables. You know what you're getting,
        what it costs, and what it replaces. Every engagement starts with a conversation.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SIGNAL -->
  <section class="section pkg-section" id="signal">
    <div class="container pkg-inner">
      <div class="pkg-header">
        <div>
          <span class="pkg-number">01</span>
          <h2 class="pkg-title">Signal</h2>
          <div class="pkg-subtitle">Visibility &amp; Ops Audit</div>
          <div class="pkg-price-tag">$500–$900 <span>one-time</span></div>
        </div>
        <div class="pkg-quote">
          "For businesses that want an honest outside look before committing to anything bigger."
        </div>
      </div>

      <div class="pkg-body">
        <div>
          <p class="pkg-desc">
            A focused audit of your business operations, digital presence, and tool stack. We
            identify what's working, what's broken, what's invisible online, and where you're
            losing hours to manual work — then hand you a clear, prioritized action plan.
          </p>
          <p class="pkg-desc" style="margin-top: 16px;">
            No commitment to anything further. This package stands on its own. Some clients
            use it to validate that RelayLaunch is the right fit. Others use it to tackle
            the action plan themselves.
          </p>

          <h3 class="deliverables-title">Deliverables</h3>
          <ul class="checklist">
            <li>Business &amp; Digital Presence Audit Report</li>
            <li>Tool stack inventory (what's redundant, what's missing, what to cut)</li>
            <li>Workflow bottleneck map — where your time is actually going</li>
            <li>30-Day Priority Action Plan</li>
          </ul>
        </div>

        <div>
          <div class="card best-for">
            <p class="section-eyebrow" style="margin-bottom: 12px;">Best For</p>
            <ul class="checklist">
              <li>Businesses that feel scattered or stretched</li>
              <li>Owners who've been meaning to "fix the systems" for months</li>
              <li>Anyone who wants clarity before a bigger investment</li>
            </ul>
          </div>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start with Signal →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ BLUEPRINT -->
  <section class="section pkg-section" id="blueprint">
    <div class="container pkg-inner">
      <div class="pkg-header">
        <div>
          <span class="pkg-number">02</span>
          <h2 class="pkg-title">Blueprint</h2>
          <div class="pkg-subtitle">Systems Strategy</div>
          <div class="pkg-price-tag">$1,200–$2,000 <span>one-time</span></div>
        </div>
        <div class="pkg-quote">
          "For businesses ready to stop guessing and start building with a real plan."
        </div>
      </div>

      <div class="pkg-body">
        <div>
          <p class="pkg-desc">
            Everything in Signal, plus a full growth roadmap and automation opportunity map.
            We document exactly where your time is going, where automation can take over, and
            what your next 90 days should look like — including specific tool recommendations
            and a full competitive landscape.
          </p>

          <h3 class="deliverables-title">Deliverables</h3>
          <ul class="checklist">
            <li>All Signal deliverables</li>
            <li>90-Day Growth Roadmap with milestones</li>
            <li>Automation Opportunity Map — exactly where manual work can go away</li>
            <li>Competitive landscape overview</li>
            <li>Tech stack recommendation (what to keep, what to replace, what to add)</li>
          </ul>
        </div>

        <div>
          <div class="card best-for">
            <p class="section-eyebrow" style="margin-bottom: 12px;">Best For</p>
            <ul class="checklist">
              <li>Businesses that know they need to move but want direction first</li>
              <li>Owners evaluating whether to DIY or hire out the build</li>
              <li>Anyone planning a significant tech or ops overhaul</li>
            </ul>
          </div>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start with Blueprint →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ RELAY -->
  <section class="section pkg-section featured-pkg" id="relay">
    <div class="container pkg-inner">
      <div class="pkg-header">
        <div>
          <div class="badge badge-solid-green" style="margin-bottom: 12px;">Most Popular</div>
          <span class="pkg-number">03</span>
          <h2 class="pkg-title">Relay</h2>
          <div class="pkg-subtitle">Build &amp; Connect</div>
          <div class="pkg-price-tag">$1,800–$6,000 <span>project-based</span></div>
        </div>
        <div class="pkg-quote">
          "For businesses ready to run leaner, be seen more, and have tools that work together."
        </div>
      </div>

      <div class="pkg-body">
        <div>
          <p class="pkg-desc">
            This is the full build. We design, build, and launch your unified digital
            infrastructure — website, automation workflows, email sequences, social content
            scheduling, and a single dashboard where everything reports back to you.
            One connected system doing the work of five disconnected tools.
          </p>
          <p class="pkg-desc" style="margin-top: 16px;">
            The automation continues running after we hand off. You're not dependent on a
            monthly retainer for your systems to keep working — the Relay package delivers
            a self-running operation.
          </p>

          <h3 class="deliverables-title">Deliverables</h3>
          <ul class="checklist">
            <li>Custom website — mobile-first, SEO-optimized, fast (5–15 pages)</li>
            <li>Live automation workflows — 3 to 7 connected, running 24/7</li>
            <li>Email sequences (welcome, follow-up, nurture, reactivation)</li>
            <li>Social content scheduling (4 platforms, 30 posts/month for launch month)</li>
            <li>Unified business dashboard — all metrics, alerts, and approvals in one place</li>
            <li>SOP library and tool documentation for your team</li>
            <li>30-day launch support</li>
          </ul>
        </div>

        <div>
          <div class="card best-for">
            <p class="section-eyebrow" style="margin-bottom: 12px;">What's Included by Scale</p>
            <table class="rl-table">
              <thead>
                <tr>
                  <th>Scope</th>
                  <th>Price Range</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Starter build (5–8 pages, 3 workflows, email setup)</td>
                  <td>$1,800–$3,000</td>
                </tr>
                <tr>
                  <td>Full build (10–15 pages, 7 workflows, social + analytics)</td>
                  <td>$3,500–$6,000</td>
                </tr>
                <tr>
                  <td>Enterprise build (full stack + membership + sub-sites)</td>
                  <td>$6,000–$10,000</td>
                </tr>
              </tbody>
            </table>
          </div>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start the Build →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SUSTAIN -->
  <section class="section pkg-section" id="sustain">
    <div class="container pkg-inner">
      <div class="pkg-header">
        <div>
          <span class="pkg-number">04</span>
          <h2 class="pkg-title">Sustain</h2>
          <div class="pkg-subtitle">Monthly Growth Support</div>
          <div class="pkg-price-tag">$300–$500<span>/month</span></div>
        </div>
        <div class="pkg-quote">
          "For businesses that want a consistent partner keeping the engine running and the momentum building."
        </div>
      </div>

      <div class="pkg-body">
        <div>
          <p class="pkg-desc">
            Monthly ongoing support to keep your systems optimized, your content flowing, and
            your growth moving. This is not a business partnership or equity arrangement — it's
            operational support from someone who stays in the work with you month over month.
          </p>
          <p class="pkg-desc" style="margin-top: 16px;">
            The Relay package delivers automation that runs without a retainer. Sustain is for
            optimizing, growing, and adding new capability on top of what's already running.
          </p>

          <h3 class="deliverables-title">Monthly Deliverables</h3>
          <ul class="checklist">
            <li>Social content — 30 posts/month across 4 platforms</li>
            <li>SEO &amp; blog maintenance — 4 posts/month, ongoing optimization</li>
            <li>Automation monitoring + new workflows as your business evolves</li>
            <li>Monthly performance report + strategy call</li>
            <li>Priority support channel (Slack-based)</li>
          </ul>
        </div>

        <div>
          <div class="card best-for">
            <p class="section-eyebrow" style="margin-bottom: 12px;">Best For</p>
            <ul class="checklist">
              <li>Businesses that completed a Relay build</li>
              <li>Owners who want consistent output without hiring in-house</li>
              <li>Businesses actively growing and needing regular new workflows</li>
            </ul>
          </div>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start Sustain →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONSULTING -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">Also Available</span>
      <h2 class="section-title">Systems Integration Consulting</h2>
      <p class="section-sub" style="margin-bottom: 32px;">
        For businesses that already have tools but need them connected. $100–$175/hour.
        Includes API integrations, workflow design, data mapping, and platform consolidation.
      </p>
      <Button variant="outline" href="/contact">Book a Consulting Session →</Button>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SERVICE TIERS -->
  <section class="section" id="tiers">
    <div class="container">
      <span class="section-eyebrow">Service Tiers</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Three tiers. Pick where you are.</h2>
      <p class="section-sub" style="max-width: 600px; margin-bottom: 48px;">
        Whether you need a one-time build, ongoing operations, or full-scale growth infrastructure — there's a tier designed for your stage.
      </p>

      <div class="tiers-grid">
        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 1</span>
          <h3 class="tier-name">Launch</h3>
          <div class="tier-price">$2,500–$5,000 <span>one-time</span></div>
          <p class="tier-desc">Get your foundation built — a professional website, core automations, and connected tools, delivered in a single engagement.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Custom website (5–10 pages)</li>
            <li>3–5 automation workflows</li>
            <li>Email sequence setup</li>
            <li>Tool consolidation &amp; integration</li>
            <li>Unified dashboard</li>
            <li>30-day launch support</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Get Started →</Button>
        </div>

        <div class="card tier-card tier-featured">
          <div class="badge badge-solid-green" style="margin-bottom: 12px;">Most Popular</div>
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 2</span>
          <h3 class="tier-name">Run</h3>
          <div class="tier-price">$500–$1,000<span>/month</span></div>
          <p class="tier-note">3-month minimum</p>
          <p class="tier-desc">Ongoing operations support — we keep your systems optimized, your content flowing, and your automations evolving.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Launch</li>
            <li>Monthly content (blog + social)</li>
            <li>Automation monitoring &amp; new workflows</li>
            <li>SEO optimization &amp; reporting</li>
            <li>Monthly strategy call</li>
            <li>Priority Slack support</li>
          </ul>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start Running →</Button>
        </div>

        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 3</span>
          <h3 class="tier-name">Scale</h3>
          <div class="tier-price">$1,000–$2,500<span>/month</span></div>
          <p class="tier-note">6-month minimum</p>
          <p class="tier-desc">Full growth infrastructure — AI agents, advanced automations, multi-location support, and a fractional ops partner in your corner.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Run</li>
            <li>AI agent setup &amp; management</li>
            <li>Advanced workflow automation</li>
            <li>Multi-location or multi-brand support</li>
            <li>Quarterly business review</li>
            <li>Fractional AI Ops advisory</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Let's Scale →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ ADDITIONAL ENGAGEMENTS -->
  <section class="section" id="additional">
    <div class="container">
      <span class="section-eyebrow">Additional Engagements</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Standalone services you can add anytime.</h2>
      <p class="section-sub" style="max-width: 600px; margin-bottom: 48px;">
        These engagements can be added to any tier or purchased independently.
      </p>

      <div class="addons-grid">
        <div class="card addon-card">
          <h3>Complete Analysis</h3>
          <div class="addon-price">$1,500–$2,500</div>
          <p>Two-day deep dive combining Signal audit and Blueprint strategy into one comprehensive engagement. 20–30 page deliverable with full operational roadmap.</p>
          <Button variant="outline" href="/complete-analysis" size="sm" class="mt-3">Learn More →</Button>
        </div>

        <div class="card addon-card">
          <h3>AI Agent Setup</h3>
          <div class="addon-price">$800–$2,000</div>
          <p>Design and deploy AI-powered agents for customer support, lead qualification, content generation, or internal knowledge retrieval — integrated into your existing tools.</p>
        </div>

        <div class="card addon-card">
          <h3>Workflow Automation Build</h3>
          <div class="addon-price">$500–$1,500 per workflow</div>
          <p>Custom n8n workflow design, build, and deployment. Connect your CRM, email, scheduling, invoicing, and any tool with an API into automated sequences.</p>
        </div>

        <div class="card addon-card">
          <h3>Systems Integration</h3>
          <div class="addon-price">$100–$175/hour</div>
          <p>For businesses that have tools but need them connected. API integrations, data mapping, platform consolidation, and workflow design — billed hourly.</p>
        </div>

        <div class="card addon-card">
          <h3>Fractional AI Ops Officer</h3>
          <div class="addon-price">$1,500–$3,000/month</div>
          <p>A dedicated AI operations advisor embedded in your business. Identifies automation opportunities, manages AI tooling, and drives operational efficiency at the executive level.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Not sure which package is right for you?</h2>
      <p class="section-sub" style="margin: 16px auto 32px; max-width: 500px;">
        Every engagement starts with a conversation. Tell us where you are and what you're
        trying to build — we'll figure out the right fit together.
      </p>
      <Button variant="primary" href="/contact">Start a Conversation →</Button>
    </div>
  </section>

</Layout>

<style>
  .hero { padding-top: 80px; }

  /* ── Package sections ── */
  .pkg-section { border-top: 1px solid var(--color-border); }
  .featured-pkg { background: rgba(35,134,54,0.04); }

  .pkg-inner { display: flex; flex-direction: column; gap: 40px; }

  .pkg-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .pkg-number {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .pkg-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    margin-bottom: 6px;
  }

  .pkg-subtitle {
    font-size: 15px;
    color: var(--color-muted);
    margin-bottom: 12px;
  }

  .pkg-price-tag {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-green);
  }

  .pkg-price-tag span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 4px;
  }

  .pkg-quote {
    font-size: 17px;
    color: var(--color-muted);
    font-style: italic;
    border-left: 3px solid var(--color-green);
    padding-left: 20px;
    margin-top: 8px;
    line-height: 1.6;
  }

  .pkg-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .pkg-desc {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .deliverables-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 28px 0 16px;
  }

  .best-for { padding: 20px; }

  /* ── Service Tiers ── */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .tier-card {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
  }

  .tier-featured {
    border-color: var(--color-green);
    box-shadow: 0 0 0 1px var(--color-green);
  }

  .tier-name {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .tier-price {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-green);
    margin-bottom: 4px;
  }

  .tier-price span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 2px;
  }

  .tier-note {
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 4px;
  }

  .tier-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  .tier-includes-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }

  /* ── Additional Engagements ── */
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .addon-card {
    padding: 24px;
  }

  .addon-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }

  .addon-price {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-green);
    margin-bottom: 12px;
  }

  .addon-card p { font-size: 14px; line-height: 1.65; color: var(--color-muted); }

  @media (max-width: 768px) {
    .pkg-header, .pkg-body { grid-template-columns: 1fr; }
    .tiers-grid { grid-template-columns: 1fr; }
  }
</style>

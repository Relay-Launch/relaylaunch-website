---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const serviceSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Complete Analysis — Business Infrastructure Diagnostic',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://relaylaunch.com' },
    description: 'An 8-area diagnostic of your entire business infrastructure — operations, tech stack, AI readiness, digital footprint, and more — delivered as a 20–30 page professional report with a prioritized roadmap.',
    url: 'https://relaylaunch.com/complete-analysis/',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1500',
      highPrice: '3000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Launch — Digital Infrastructure Build',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://relaylaunch.com' },
    description: 'One-time project build of unified digital infrastructure — custom website, automation workflows, email sequences, social scheduling, and a single connected dashboard replacing disconnected tools.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '2500',
      highPrice: '5000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Run — Monthly Digital Operations Retainer',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://relaylaunch.com' },
    description: 'Monthly retainer for ongoing digital operations support — social content, SEO and blog maintenance, automation monitoring, and monthly strategy calls. 3-month minimum.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '500',
      highPrice: '1000',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Scale — Premium Growth Retainer',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC', url: 'https://relaylaunch.com' },
    description: 'Premium monthly retainer for businesses scaling their digital infrastructure — expanded deliverables, priority support, advanced automation builds, and strategic advisory. 6-month minimum.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1000',
      highPrice: '2500',
    },
  },
];
---

<Layout
  title="Services — RelayLaunch | Digital Infrastructure for Small Business"
  description="RelayLaunch service packages: Complete Analysis diagnostic ($1,500–$3,000), Launch build ($2,500–$5,000), Run retainer ($500–$1,000/mo), Scale retainer ($1,000–$2,500/mo)."
  canonicalUrl="https://relaylaunch.com/services/"
  jsonLd={serviceSchemas}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero">
    <div class="container">
      <span class="section-eyebrow">Service Packages</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px);">
        Built for businesses ready<br />to run leaner and be seen more.
      </h1>
      <p class="section-sub" style="margin-bottom: 28px;">
        Every package is a defined scope with clear deliverables. You know what you're getting,
        what it costs, and what it replaces. Every engagement starts with a conversation.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: center;">
        <Button variant="primary" href="/contact" size="lg">Start a Conversation →</Button>
        <Button variant="outline" href="/complete-analysis" size="lg">Start with a Complete Analysis</Button>
      </div>
      <p style="margin-top: 14px; font-size: 13px; color: var(--color-muted);">
        No commitment required. Discovery call is free. &nbsp;·&nbsp; Not sure which package fits? A <a href="/complete-analysis" style="color: var(--color-primary); text-decoration: underline;">Complete Analysis</a> gives you the data to decide.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SERVICE TIERS -->
  <section class="section" id="tiers">
    <div class="container">
      <span class="section-eyebrow">Service Tiers</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Three tiers. Pick where you are.</h2>
      <p class="section-sub" style="max-width: 600px; margin-bottom: 48px;">
        Whether you need a one-time build, ongoing operations, or full-scale growth infrastructure — there's a tier designed for your stage.
      </p>

      <div class="tiers-grid reveal-stagger">
        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 1</span>
          <h3 class="tier-name">Launch</h3>
          <div class="tier-price">$2,500–$5,000 <span>one-time</span></div>
          <p class="tier-desc">Get your foundation built — a professional website, core automations, and connected tools, delivered in a single engagement.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Custom website (5–10 pages)</li>
            <li>3–5 automation workflows</li>
            <li>Email sequence setup</li>
            <li>Tool consolidation &amp; integration</li>
            <li>Unified dashboard</li>
            <li>30-day launch support</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Get Started →</Button>
        </div>

        <div class="card tier-card tier-featured">
          <div class="badge badge-solid-primary" style="margin-bottom: 12px;">Most Popular</div>
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 2</span>
          <h3 class="tier-name">Run</h3>
          <div class="tier-price">$500–$1,000<span>/month</span></div>
          <p class="tier-note">3-month minimum</p>
          <p class="tier-desc">Ongoing operations support — we keep your systems optimized, your content flowing, and your automations evolving.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Launch</li>
            <li>Monthly content (blog + social)</li>
            <li>Automation monitoring &amp; new workflows</li>
            <li>SEO optimization &amp; reporting</li>
            <li>Monthly strategy call</li>
            <li>Priority Slack support</li>
          </ul>
          <Button variant="primary" href="/contact" class="mt-4 w-full justify-center">Start Running →</Button>
        </div>

        <div class="card tier-card">
          <span class="section-eyebrow" style="margin-bottom: 12px;">Tier 3</span>
          <h3 class="tier-name">Scale</h3>
          <div class="tier-price">$1,000–$2,500<span>/month</span></div>
          <p class="tier-note">6-month minimum</p>
          <p class="tier-desc">Full growth infrastructure — AI agents, advanced automations, multi-location support, and a fractional ops partner in your corner.</p>
          <h4 class="tier-includes-title">Includes</h4>
          <ul class="checklist">
            <li>Everything in Run</li>
            <li>AI agent setup &amp; management</li>
            <li>Advanced workflow automation</li>
            <li>Multi-location or multi-brand support</li>
            <li>Quarterly business review</li>
            <li>Fractional AI Ops advisory</li>
          </ul>
          <Button variant="outline" href="/contact" class="mt-4 w-full justify-center">Let's Scale →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ ADDITIONAL ENGAGEMENTS -->
  <section class="section" id="additional">
    <div class="container">
      <span class="section-eyebrow">Additional Engagements</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Standalone services you can add anytime.</h2>
      <p class="section-sub" style="max-width: 600px; margin-bottom: 48px;">
        These engagements can be added to any tier or purchased independently.
      </p>

      <div class="addons-grid">
        <div class="card addon-card addon-card-featured">
          <div class="addon-start-badge">Recommended First Step</div>
          <h3>Complete Analysis</h3>
          <div class="addon-price">$1,500–$3,000</div>
          <p>Two-day deep dive combining audit and strategy into one comprehensive engagement. 20–30 page deliverable with full operational roadmap — so you know exactly what to build before you spend a dollar.</p>
          <Button variant="primary" href="/complete-analysis" size="sm" class="mt-3">Learn More →</Button>
        </div>

        <div class="card addon-card">
          <h3>AI Agent Setup</h3>
          <div class="addon-price">$800–$2,000</div>
          <p>Design and deploy AI-powered agents for customer support, lead qualification, content generation, or internal knowledge retrieval — integrated into your existing tools.</p>
        </div>

        <div class="card addon-card">
          <h3>Workflow Automation Build</h3>
          <div class="addon-price">$500–$1,500 per workflow</div>
          <p>Custom n8n workflow design, build, and deployment. Connect your CRM, email, scheduling, invoicing, and any tool with an API into automated sequences.</p>
        </div>

        <div class="card addon-card">
          <h3>Systems Integration</h3>
          <div class="addon-price">$100–$175/hour</div>
          <p>For businesses that have tools but need them connected. API integrations, data mapping, platform consolidation, and workflow design — billed hourly.</p>
        </div>

        <div class="card addon-card">
          <h3>Fractional AI Ops Officer</h3>
          <div class="addon-price">$1,500–$3,000/month</div>
          <p>A dedicated AI operations advisor embedded in your business. Identifies automation opportunities, manages AI tooling, and drives operational efficiency at the executive level.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <span class="section-eyebrow">Common Questions</span>
      <h2 class="section-title" style="margin-bottom: 12px;">Before you reach out, here's what people usually ask.</h2>
      <p class="section-sub" style="max-width: 600px; margin-bottom: 48px;">
        No gotchas. No lock-in. Just honest answers.
      </p>

      <div class="faq-list reveal-stagger">
        <details class="faq-item">
          <summary class="faq-question">Do I have to commit to a retainer right away?</summary>
          <div class="faq-answer">
            <p>No. The Complete Analysis is a standalone engagement with no strings attached. You get a 20–30 page report, keep it, and decide what to do next — hire us, DIY it, or do nothing for now. Most clients choose to continue, but that's entirely your call.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Who owns what you build?</summary>
          <div class="faq-answer">
            <p>You own 100% of everything we build — website, code, automations, content, accounts, and domains. No vendor lock-in. No dependencies. If you walk away tomorrow, your systems keep running.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How long does a Complete Analysis take?</summary>
          <div class="faq-answer">
            <p>Two business days from intake completion. Day 1 is the deep audit across 8 areas of your business. Day 2 is report writing and review. You receive the deliverable within 5 business days of kickoff.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What's the difference between Launch and Run?</summary>
          <div class="faq-answer">
            <p><strong>Launch</strong> is a one-time build — we design and deploy your unified infrastructure, hand it off, and you run it. <strong>Run</strong> is ongoing operations — we stay on as your digital ops team, keeping systems optimized and content flowing. Most businesses start with Launch, then add Run once the foundation is solid.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Can I switch tiers once I start?</summary>
          <div class="faq-answer">
            <p>Yes. You can upgrade from Run to Scale at any renewal point (monthly). Downgrading follows the same cadence. We'll never lock you into a tier that no longer fits where your business is.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do I need to be local to Boston?</summary>
          <div class="faq-answer">
            <p>No. We work with small businesses across the U.S. remotely. Discovery calls, presentations, and strategy sessions are all via video. Boston and the Northeast get priority scheduling, but geography is never a barrier.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What if I'm already mid-build with another provider?</summary>
          <div class="faq-answer">
            <p>We can audit what exists and take it from there. The Complete Analysis covers your current stack regardless of who built it. We're not here to start from zero if there's solid work worth preserving.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How is this different from hiring a freelancer?</summary>
          <div class="faq-answer">
            <p>Freelancers deliver a project and move on. We deliver infrastructure designed to run your business — then stay accountable to its performance. We combine strategy, build, and operations in a single engagement, not three separate contracts with three separate people.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Not sure which package is right for you?</h2>
      <p class="section-sub" style="margin: 16px auto 32px; max-width: 500px;">
        Every engagement starts with a conversation. Tell us where you are and what you're
        trying to build — we'll figure out the right fit together.
      </p>
      <Button variant="primary" href="/contact">Start a Conversation →</Button>
      <p class="cta-no-commit">No commitment required. Discovery call is free.</p>
    </div>
  </section>

</Layout>

<style>
  .hero { padding-top: 80px; }

  /* ── Package sections ── */
  .pkg-section { border-top: 1px solid var(--color-border); }
  .featured-pkg { background: color-mix(in srgb, var(--primary) 4%, var(--color-bg)); }

  .pkg-inner { display: flex; flex-direction: column; gap: 40px; }

  .pkg-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .pkg-number {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .pkg-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    margin-bottom: 6px;
  }

  .pkg-subtitle {
    font-size: 15px;
    color: var(--color-muted);
    margin-bottom: 12px;
  }

  .pkg-price-tag {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .pkg-price-tag span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 4px;
  }

  .pkg-quote {
    font-size: 17px;
    color: var(--color-muted);
    font-style: italic;
    border-left: 3px solid var(--color-primary);
    padding-left: 20px;
    margin-top: 8px;
    line-height: 1.6;
  }

  .pkg-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .pkg-desc {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .deliverables-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 28px 0 16px;
  }

  .best-for { padding: 20px; }

  /* ── Service Tiers ── */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .tier-card {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
  }

  .tier-featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-md);
    background: linear-gradient(135deg, var(--color-surface) 0%, color-mix(in srgb, var(--primary) 3%, var(--color-surface)) 100%);
  }

  .tier-name {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .tier-price {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 4px;
  }

  .tier-price span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 2px;
  }

  .tier-note {
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 4px;
  }

  .tier-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  .tier-includes-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }

  /* ── Additional Engagements ── */
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .addon-card {
    padding: 24px;
  }

  .addon-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }

  .addon-price {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .addon-card p { font-size: 14px; line-height: 1.65; color: var(--color-muted); }

  .addon-card-featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-sm);
    position: relative;
    background: linear-gradient(135deg, var(--color-surface) 0%, color-mix(in srgb, var(--primary) 3%, var(--color-surface)) 100%);
  }

  .addon-start-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    border-radius: 4px;
    padding: 3px 10px;
    margin-bottom: 12px;
  }

  /* ── FAQ ── */
  .faq-list {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--color-text);
    gap: 16px;
    transition: color 0.15s ease;
  }

  .faq-question:hover {
    color: var(--color-primary);
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
    font-size: 20px;
    font-weight: 400;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(.22,1,.36,1);
  }

  .faq-item[open] .faq-question::after {
    content: '−';
  }

  .faq-answer {
    padding: 0 0 20px;
  }

  .faq-answer p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
    margin: 0;
  }

  .faq-answer strong {
    color: var(--color-text);
  }

  /* ── CTA micro-copy ── */
  .cta-no-commit {
    margin-top: 14px;
    font-size: 13px;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .pkg-header, .pkg-body { grid-template-columns: 1fr; }
    .tiers-grid { grid-template-columns: 1fr; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const waitlistWebhookUrl = import.meta.env.PUBLIC_WAITLIST_WEBHOOK_URL || '#';
---

<Layout
  title="Control Center | RelayLaunch — AI Agents & Unified Operations"
  description="Six specialist AI agents. One unified dashboard. The RelayLaunch Control Center replaces scattered tools with an intelligent operations system that monitors, builds, protects, and grows your business."
  canonicalUrl="https://www.relaylaunch.com/control-center"
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'RelayLaunch Control Center',
      description: 'AI-powered operations platform with six specialist agents for infrastructure, security, content, growth, brand, and development.',
      url: 'https://www.relaylaunch.com/control-center',
    },
  ]}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="cc-hero section">
    <div class="cc-hero-grid-bg" aria-hidden="true"></div>
    <div class="cc-hero-orb cc-hero-orb-1" aria-hidden="true"></div>
    <div class="cc-hero-orb cc-hero-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="cc-hero-content">
        <span class="section-eyebrow" style="color: var(--color-primary);">The Relay Method&trade;</span>
        <h1 class="cc-hero-headline">
          Six AI agents.<br />
          <span class="text-accent">One Control Center.</span>
        </h1>
        <p class="cc-hero-sub">
          Most businesses juggle disconnected tools, manual processes, and zero
          visibility. The RelayLaunch Control Center replaces that chaos with an
          intelligent operations system — six specialist agents that monitor, build,
          protect, and grow your business around the clock.
        </p>
        <p class="cc-hero-proof">
          This isn't a concept. We run our own business on this system today, and
          it's built into every client engagement.
        </p>
        <div class="cc-waitlist-block" style="margin-top: 36px;">
          <div class="cc-waitlist-badge-row">
            <span class="cc-waitlist-badge">Early Preview</span>
          </div>
          <h3 class="cc-waitlist-headline">Your AI operations team is almost ready.</h3>
          <p class="cc-waitlist-pitch">
            We're building the Control Center with a small group of business owners
            who are tired of duct-taping their ops together. Six specialist agents.
            One dashboard. Zero busywork. Join the waitlist and you could be in the
            first preview group to put it to work.
          </p>
          <form id="waitlist-form-cc" class="cc-waitlist-form" data-webhook={waitlistWebhookUrl} novalidate>
            <div class="cc-waitlist-fields">
              <label for="waitlist-name-cc" class="sr-only">Name</label>
              <input type="text" id="waitlist-name-cc" name="name" required autocomplete="name" placeholder="Your name" class="cc-waitlist-input" />
              <label for="waitlist-email-cc" class="sr-only">Email address</label>
              <input type="email" id="waitlist-email-cc" name="email" required autocomplete="email" placeholder="you@company.com" class="cc-waitlist-input" />
            </div>
            <button type="submit" class="cc-waitlist-submit">Join the Waitlist <span>&rarr;</span></button>
            <p class="cc-waitlist-fine-print">*Early Preview slots are limited and granted on a rolling basis. No commitment required — we just want to make sure it's the right fit.</p>
          </form>
          <div id="waitlist-success-cc" class="cc-waitlist-success" role="status" aria-live="polite" hidden>
            <p class="cc-waitlist-success-title">You're in.</p>
            <p class="cc-waitlist-success-text">We're reviewing waitlist requests now and will reach out when your preview access is ready.</p>
          </div>
          <div id="waitlist-error-cc" class="cc-waitlist-error" role="alert" aria-live="assertive" hidden>
            <p class="cc-waitlist-error-text">Something went wrong. Please try again.</p>
          </div>
        </div>
        <div class="hero-actions" style="margin-top: 20px;">
          <Button variant="outline" href="/services" size="lg">See Service Tiers</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ HOW IT WORKS OVERVIEW -->
  <section class="section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">How It Works</span>
        <h2 class="section-title">One system. Six specialists. Zero manual work.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          Each agent has a defined role, automated triggers, and direct access to your
          infrastructure. They coordinate through a unified dashboard — so you see
          one view of everything happening across your business.
        </p>
      </div>

      <div class="cc-flow reveal-stagger">
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>You define the mission</h3>
          <p>Tell us your goals, constraints, and priorities. We configure your agents to match your business.</p>
        </div>
        <div class="cc-flow-connector" aria-hidden="true">→</div>
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          </div>
          <h3>Agents activate</h3>
          <p>Each agent starts monitoring and operating in its domain — infrastructure, security, content, growth, brand, and code.</p>
        </div>
        <div class="cc-flow-connector" aria-hidden="true">→</div>
        <div class="cc-flow-step">
          <div class="cc-flow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3>You see one dashboard</h3>
          <p>All agent activity, alerts, metrics, and recommendations surface to a single view. Your business briefs you — not the other way around.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ THE SIX AGENTS -->
  <section class="section cc-agents-section">
    <div class="cc-agents-bg-grid" aria-hidden="true"></div>
    <div class="cc-agents-orb cc-agents-orb-1" aria-hidden="true"></div>
    <div class="cc-agents-orb cc-agents-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow" style="color: var(--color-primary);">The Agent Roster</span>
        <h2 class="section-title" style="color: var(--color-white);">Meet your operations team.</h2>
        <p class="section-sub" style="color: color-mix(in srgb, var(--color-white) 70%, transparent); margin-bottom: 48px;">
          Each agent is a specialist with defined triggers, automated workflows, and
          deep integration into your systems. They work together through the Control
          Center — and they never take a day off.
        </p>
      </div>

      <div class="cc-agents-grid reveal-stagger">
        <!-- Infrastructure Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-infra">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
              <circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/>
              <line x1="12" y1="6" x2="18" y2="6"/><line x1="12" y1="18" x2="18" y2="18"/>
            </svg>
          </div>
          <h3>Infra Agent</h3>
          <p class="cc-agent-role">DNS, CDN, CI/CD, hosting, uptime</p>
          <p class="cc-agent-desc">Manages your entire cloud stack. DNS propagation, edge deployments, build pipelines, and zero-downtime releases. Enterprise-grade infrastructure on autopilot.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Deploys code changes to Cloudflare edge in under 60 seconds</li>
              <li>Monitors uptime and alerts your Slack if anything drops</li>
              <li>Manages DNS records, SSL certificates, and CDN caching</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/devops</span>
            <span class="cc-tag">/architect</span>
            <span class="cc-tag">/infra</span>
          </div>
        </div>

        <!-- Security Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot cc-status-dot-alert"></span>Monitoring</div>
          <div class="cc-agent-icon cc-icon-security">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h3>Security Agent</h3>
          <p class="cc-agent-role">Threat detection, headers, compliance</p>
          <p class="cc-agent-desc">Scans for vulnerabilities, enforces CSP headers, monitors dependencies, and runs security audits. Your always-on threat detection layer.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Scans every code change for XSS, injection, and secret leaks</li>
              <li>Enforces Content Security Policy and security headers</li>
              <li>Audits npm dependencies for known vulnerabilities</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/security</span>
            <span class="cc-tag">/qa</span>
          </div>
        </div>

        <!-- Build Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-build">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              <line x1="14" y1="4" x2="10" y2="20"/>
            </svg>
          </div>
          <h3>Build Agent</h3>
          <p class="cc-agent-role">Features, fixes, code quality, PRs</p>
          <p class="cc-agent-desc">Implements features, fixes bugs, reviews pull requests, and enforces code quality standards. Writes clean, tested code with your architecture in mind.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Ships new website pages and features end-to-end</li>
              <li>Reviews every pull request for quality and brand compliance</li>
              <li>Maintains Lighthouse 95+ scores and sub-second load times</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/build</span>
            <span class="cc-tag">/frontend</span>
          </div>
        </div>

        <!-- Content Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-content">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <h3>Content Agent</h3>
          <p class="cc-agent-role">Blog posts, social, email copy</p>
          <p class="cc-agent-desc">Writes on-brand content across every channel. Knows your voice, your audience, and your editorial calendar. Publishes to four platforms simultaneously.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Writes and publishes SEO blog posts on a recurring schedule</li>
              <li>Creates 30 days of social content across four platforms</li>
              <li>Drafts email sequences for lead nurturing and follow-ups</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/content</span>
            <span class="cc-tag">/seo</span>
          </div>
        </div>

        <!-- Growth Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot"></span>Active</div>
          <div class="cc-agent-icon cc-icon-growth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>Growth Agent</h3>
          <p class="cc-agent-role">Acquisition, conversion, retention</p>
          <p class="cc-agent-desc">Tracks your funnel, spots drop-off points, runs A/B experiments, and recommends the highest-impact moves to grow your customer base.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Monitors Google Analytics and flags conversion anomalies</li>
              <li>Suggests and tests landing page improvements</li>
              <li>Tracks lead sources and identifies highest-ROI channels</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/growth</span>
            <span class="cc-tag">/ads</span>
          </div>
        </div>

        <!-- Brand Agent -->
        <div class="cc-agent-card">
          <div class="cc-agent-status"><span class="cc-status-dot cc-status-dot-alert"></span>Monitoring</div>
          <div class="cc-agent-icon cc-icon-brand">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <h3>Brand Agent</h3>
          <p class="cc-agent-role">Identity, consistency, compliance</p>
          <p class="cc-agent-desc">Enforces your brand standards across every touchpoint. Colors, fonts, voice, and visual identity stay locked in. Catches violations before they ship.</p>
          <div class="cc-agent-usecases">
            <p class="cc-usecase-label">What it does for clients:</p>
            <ul>
              <li>Scans every code change and content update for brand violations</li>
              <li>Enforces color palette, font stack, and voice guidelines</li>
              <li>Generates brand compliance reports on demand</li>
            </ul>
          </div>
          <div class="cc-agent-tags">
            <span class="cc-tag">/brand</span>
            <span class="cc-tag">/audit</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONTROL CENTER PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">The Dashboard</span>
        <h2 class="section-title">One screen. Complete visibility.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          The Control Center is a unified dashboard where all six agents report.
          Instead of logging into eight different tools, you open one view and see
          everything — builds deploying, content publishing, security scanning,
          growth tracking, and brand compliance — all in real time.
        </p>
      </div>

      <div class="cc-preview-card reveal">
        <div class="cc-preview-header">
          <div class="cc-preview-dots">
            <span></span><span></span><span></span>
          </div>
          <span class="cc-preview-title">RelayLaunch Control Center</span>
        </div>
        <div class="cc-preview-body">
          <div class="cc-preview-sidebar">
            <div class="cc-sidebar-item cc-sidebar-active">
              <span class="cc-sidebar-dot"></span> Dashboard
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Agents
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Workflows
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Content
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Analytics
            </div>
            <div class="cc-sidebar-item">
              <span class="cc-sidebar-dot cc-sidebar-dot-dim"></span> Settings
            </div>
          </div>
          <div class="cc-preview-main">
            <div class="cc-preview-row">
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Uptime</div>
                <div class="cc-metric-value">99.98%</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Deploys Today</div>
                <div class="cc-metric-value">4</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Security Score</div>
                <div class="cc-metric-value">A+</div>
              </div>
              <div class="cc-preview-metric">
                <div class="cc-metric-label">Brand Compliance</div>
                <div class="cc-metric-value">100%</div>
              </div>
            </div>
            <div class="cc-preview-agents-row">
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Infra</span>
                <span class="cc-pa-state">Deploying</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-monitoring"></span>
                <span class="cc-pa-name">Security</span>
                <span class="cc-pa-state">Scanning</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Build</span>
                <span class="cc-pa-state">PR Review</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Content</span>
                <span class="cc-pa-state">Publishing</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-active"></span>
                <span class="cc-pa-name">Growth</span>
                <span class="cc-pa-state">Tracking</span>
              </div>
              <div class="cc-preview-agent-status">
                <span class="cc-pa-dot cc-pa-monitoring"></span>
                <span class="cc-pa-name">Brand</span>
                <span class="cc-pa-state">Watching</span>
              </div>
            </div>
            <div class="cc-preview-feed">
              <div class="cc-feed-item">
                <span class="cc-feed-time">2 min ago</span>
                <span class="cc-feed-msg"><strong>Build Agent</strong> deployed v2.4.1 to production</span>
              </div>
              <div class="cc-feed-item">
                <span class="cc-feed-time">14 min ago</span>
                <span class="cc-feed-msg"><strong>Content Agent</strong> published blog post: "5 Signs Your Tools Are Costing You"</span>
              </div>
              <div class="cc-feed-item">
                <span class="cc-feed-time">1 hr ago</span>
                <span class="cc-feed-msg"><strong>Security Agent</strong> completed dependency audit — 0 vulnerabilities found</span>
              </div>
              <div class="cc-feed-item">
                <span class="cc-feed-time">3 hrs ago</span>
                <span class="cc-feed-msg"><strong>Growth Agent</strong> flagged 12% conversion increase on /complete-analysis</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ USE CASES -->
  <section class="section cc-usecases-section">
    <div class="container">
      <div class="reveal">
        <span class="section-eyebrow">Real Use Cases</span>
        <h2 class="section-title">What the agents do every day.</h2>
        <p class="section-sub" style="margin-bottom: 48px;">
          These aren't theoretical capabilities. Here's what the agent system
          handles for RelayLaunch and our clients right now.
        </p>
      </div>

      <div class="cc-usecase-grid reveal-stagger">
        <div class="cc-usecase-card">
          <div class="cc-uc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <h3>Zero-Touch Deployments</h3>
          <p>Push code to a branch and the Infra Agent handles the rest — build, test, deploy to Cloudflare edge, verify uptime, and report back to Slack. Average deploy time: 47 seconds.</p>
        </div>
        <div class="cc-usecase-card">
          <div class="cc-uc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>Content Pipeline on Autopilot</h3>
          <p>The Content Agent writes blog posts, creates social media content for four platforms, and drafts email sequences. Everything is on-brand because the Brand Agent reviews before publishing.</p>
        </div>
        <div class="cc-usecase-card">
          <div class="cc-uc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>24/7 Security Scanning</h3>
          <p>Every code change, dependency update, and configuration change is scanned for vulnerabilities. The Security Agent enforces CSP headers, checks for leaked secrets, and audits npm packages automatically.</p>
        </div>
        <div class="cc-usecase-card">
          <div class="cc-uc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Conversion Intelligence</h3>
          <p>The Growth Agent monitors your analytics, spots funnel drop-offs, and suggests improvements. When a landing page starts underperforming, you know about it before your monthly report.</p>
        </div>
        <div class="cc-usecase-card">
          <div class="cc-uc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3>Brand Lock</h3>

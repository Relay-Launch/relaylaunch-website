---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
---

<Layout
  title="Complete Business Analysis — RelayLaunch"
  description="See exactly where your business stands and where it can go. An 8-area diagnostic covering operations, tech stack, AI readiness, and more — with a prioritized roadmap."
  canonicalUrl="https://relaylaunch.com/complete-analysis/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Complete Business Analysis',
    provider: {
      '@type': 'Organization',
      name: 'RelayLaunch LLC',
      url: 'https://relaylaunch.com',
    },
    description: 'A comprehensive 8-area business analysis covering operations, digital infrastructure, tech stack, AI readiness, digital footprint, market snapshot, connection map, and priority roadmap.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1500',
      highPrice: '3000',
    },
  }}
>

  <!-- ═══════════════════════════════════════════════ 1. HERO -->
  <section class="ca-hero">
    <div class="container">
      <div class="ca-hero-inner">
        <span class="ca-eyebrow-light">Complete Analysis</span>
        <h1 class="ca-hero-title">
          See exactly where your business stands&mdash;<br class="hide-mobile" />
          and where it can go.
        </h1>
        <p class="ca-hero-sub">
          An 8-area diagnostic of your entire business infrastructure. You get a professional
          report with findings, benchmarks, and a prioritized roadmap&mdash;so you know
          exactly what to fix, what to keep, and what to build next.
        </p>
        <div class="ca-hero-actions">
          <Button variant="primary" href="/contact" size="lg">Book Your Analysis &rarr;</Button>
          <Button variant="outline" href="#process" size="lg" class="ca-outline-btn">See How It Works</Button>
        </div>
        <div class="ca-hero-trust">
          <span>&#10003; Veteran-Owned</span>
          <span>&#10003; Fixed Pricing</span>
          <span>&#10003; No Retainer Required</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 2. WHAT YOU GET — 8-Area Grid -->
  <section class="section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 48px;">
        <span class="section-eyebrow">What You Get</span>
        <h2 class="section-title" style="margin-left: auto; margin-right: auto;">
          Eight areas. One clear picture.
        </h2>
        <p class="section-sub" style="margin-left: auto; margin-right: auto;">
          Every Complete Analysis covers these eight areas so nothing gets missed.
        </p>
      </div>

      <div class="ca-grid-8 reveal-stagger">
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#9881;</div>
          <h3>Business Ops</h3>
          <p>Workflows, processes, and daily operations mapped for inefficiencies and automation opportunities.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#9729;</div>
          <h3>Digital Infrastructure</h3>
          <p>Hosting, domains, email, DNS, and the systems that keep your business running online.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#128295;</div>
          <h3>Tech Stack</h3>
          <p>Every tool you pay for, how they connect (or don't), and where you're overspending.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#9889;</div>
          <h3>AI Readiness</h3>
          <p>Where AI can save you time right now, and what needs to be in place before it works.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#127760;</div>
          <h3>Digital Footprint</h3>
          <p>Website performance, SEO, social presence, and how your brand looks to someone finding you for the first time.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#128200;</div>
          <h3>Market Snapshot</h3>
          <p>How you compare to competitors in your space&mdash;pricing, positioning, and digital maturity.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#128279;</div>
          <h3>Connection Map</h3>
          <p>How your systems, data, and teams connect (or don't)&mdash;and where the gaps cause friction.</p>
        </div>
        <div class="ca-area-card reveal">
          <div class="ca-area-icon">&#128205;</div>
          <h3>Priority Roadmap</h3>
          <p>A sequenced action plan ranked by impact and effort, so you know exactly where to start.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 3. THE DELIVERABLE -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <div class="ca-deliverable reveal">
        <div class="ca-deliverable-text">
          <span class="section-eyebrow">The Deliverable</span>
          <h2 class="section-title" style="font-size: clamp(24px, 3.5vw, 36px);">
            A professional 20&ndash;30 page report.<br />Not a slide deck. Not a checklist.
          </h2>
          <p style="color: var(--color-muted); font-size: 16px; line-height: 1.7; margin-bottom: 24px;">
            You receive a comprehensive document with an executive summary, detailed findings
            across all eight areas, benchmarks against your industry, and a prioritized roadmap
            with specific next steps.
          </p>
          <ul class="checklist">
            <li>Executive summary with key findings</li>
            <li>Detailed analysis of all 8 areas</li>
            <li>Visual diagrams of your current systems</li>
            <li>Industry benchmarks and comparisons</li>
            <li>Prioritized roadmap with effort/impact ratings</li>
            <li>90-minute walkthrough call included</li>
          </ul>
        </div>
        <div class="ca-deliverable-preview card featured">
          <div class="ca-report-mock">
            <div class="ca-report-header">
              <div class="ca-report-logo">RL</div>
              <span>Complete Analysis Report</span>
            </div>
            <div class="ca-report-line ca-report-line-title"></div>
            <div class="ca-report-line" style="width: 90%;"></div>
            <div class="ca-report-line" style="width: 75%;"></div>
            <div class="ca-report-line" style="width: 85%;"></div>
            <div class="ca-report-divider"></div>
            <div class="ca-report-section">Executive Summary</div>
            <div class="ca-report-line" style="width: 100%;"></div>
            <div class="ca-report-line" style="width: 60%;"></div>
            <div class="ca-report-divider"></div>
            <div class="ca-report-section">Findings &amp; Roadmap</div>
            <div class="ca-report-line" style="width: 95%;"></div>
            <div class="ca-report-line" style="width: 70%;"></div>
          </div>
          <p style="text-align: center; font-size: 13px; color: var(--color-muted); margin-top: 16px;">
            Sample report structure
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 4. PROOF POINTS -->
  <section class="ca-proof-section">
    <div class="container">
      <div class="ca-proof-inner reveal">
        <div class="ca-proof-stat">86%</div>
        <p class="ca-proof-text">
          of consulting buyers seek AI-enabled services when evaluating providers.
          <span class="ca-proof-source">The Complete Analysis includes AI readiness as a core area&mdash;not an upsell.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 5. PRICING -->
  <section class="section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 48px;">
        <span class="section-eyebrow">Investment</span>
        <h2 class="section-title" style="margin-left: auto; margin-right: auto;">
          Transparent pricing. No surprises.
        </h2>
      </div>

      <div class="ca-pricing-card card featured reveal" style="max-width: 560px; margin: 0 auto; text-align: center;">
        <span class="badge badge-solid-primary" style="margin-bottom: 20px;">Most Popular Starting Point</span>
        <div class="ca-price-range">$1,500&ndash;$3,000</div>
        <div class="ca-price-anchor">
          Most engagements land around <strong>$2,000</strong>
        </div>
        <p style="color: var(--color-muted); font-size: 15px; line-height: 1.7; margin: 20px 0 28px;">
          Scope depends on your business size and complexity. You get an exact quote
          after the free discovery call&mdash;before any commitment.
        </p>
        <ul class="checklist" style="text-align: left; margin-bottom: 28px;">
          <li>One-time engagement, no retainer</li>
          <li>All 8 analysis areas included</li>
          <li>20&ndash;30 page professional report</li>
          <li>90-minute walkthrough call</li>
          <li>Delivered in 2&ndash;3 weeks</li>
        </ul>
        <Button variant="primary" href="/contact" class="w-full justify-center">
          Book Your Analysis &rarr;
        </Button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 6. PROCESS -->
  <section class="section" style="background: var(--color-surface);" id="process">
    <div class="container">
      <div style="text-align: center; margin-bottom: 48px;">
        <span class="section-eyebrow">The Process</span>
        <h2 class="section-title" style="margin-left: auto; margin-right: auto;">
          Four steps. Zero guesswork.
        </h2>
      </div>

      <div class="ca-process-flow reveal-stagger">
        <div class="ca-process-step reveal">
          <span class="ca-step-num">01</span>
          <h3>Discovery</h3>
          <p>Free 30-minute call. We learn your business, tools, pain points, and goals. No prep needed.</p>
        </div>
        <div class="ca-process-connector" aria-hidden="true">&rarr;</div>
        <div class="ca-process-step reveal">
          <span class="ca-step-num">02</span>
          <h3>Intake</h3>
          <p>You share access to key accounts and fill out a short intake form. Takes about 15 minutes.</p>
        </div>
        <div class="ca-process-connector" aria-hidden="true">&rarr;</div>
        <div class="ca-process-step reveal">
          <span class="ca-step-num">03</span>
          <h3>Analysis</h3>
          <p>We audit all 8 areas, build benchmarks, and draft your prioritized roadmap. Takes 2&ndash;3 weeks.</p>
        </div>
        <div class="ca-process-connector" aria-hidden="true">&rarr;</div>
        <div class="ca-process-step reveal">
          <span class="ca-step-num">04</span>
          <h3>Presentation</h3>
          <p>90-minute call to walk through every finding and recommendation. You leave with a clear path forward.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 7. FINAL CTA -->
  <section class="ca-final-cta">
    <div class="container">
      <div class="ca-cta-inner reveal">
        <h2 class="ca-cta-title">
          Book a 30-minute discovery call.
        </h2>
        <p class="ca-cta-sub">
          No pitch. No obligation. Just a conversation about your business and whether
          a Complete Analysis is the right next step.
        </p>
        <div class="ca-cta-actions">
          <Button variant="primary" href="/contact" size="lg">Book Your Discovery Call &rarr;</Button>
          <Button variant="outline" href="mailto:hello@relaylaunch.com" size="lg" class="ca-outline-btn">
            Email Us Directly
          </Button>
        </div>
        <p class="ca-cta-note">
          Or call <a href="tel:+18573186498" style="color: var(--color-primary);">857-318-6498</a> during business hours.
        </p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ─── Hero (Dark Navy) ──────────────────────────────────── */
  .ca-hero {
    background: var(--color-navy);
    padding: 100px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .ca-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    pointer-events: none;
  }

  .ca-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .ca-eyebrow-light {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .ca-hero-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .ca-hero-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 32px;
  }

  .ca-hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .ca-outline-btn {
    color: #fff !important;
    border-color: rgba(255,255,255,0.3) !important;
  }
  .ca-outline-btn:hover {
    border-color: rgba(255,255,255,0.6) !important;
    background: rgba(255,255,255,0.05) !important;
  }

  .ca-hero-trust {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    font-weight: 600;
  }

  /* ─── 8-Area Grid ───────────────────────────────────────── */
  .ca-grid-8 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .ca-area-card {
    padding: 28px 24px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .ca-area-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--primary) 30%, var(--color-border));
  }

  .ca-area-icon {
    font-size: 28px;
    margin-bottom: 14px;
    line-height: 1;
  }

  .ca-area-card h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .ca-area-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-muted);
  }

  /* ─── Deliverable ───────────────────────────────────────── */
  .ca-deliverable {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .ca-deliverable-text { }

  .ca-deliverable-preview {
    padding: 32px !important;
  }

  .ca-report-mock {
    padding: 24px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--color-border);
  }

  .ca-report-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ca-report-logo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
  }

  .ca-report-line {
    height: 8px;
    border-radius: 4px;
    background: var(--color-surface);
    margin-bottom: 8px;
  }

  .ca-report-line-title {
    height: 14px;
    width: 60%;
    background: var(--color-navy);
    margin-bottom: 16px;
  }

  .ca-report-divider {
    height: 1px;
    background: var(--color-border);
    margin: 16px 0;
  }

  .ca-report-section {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  /* ─── Proof Points (Dark Navy) ──────────────────────────── */
  .ca-proof-section {
    background: var(--color-navy);
    padding: 64px 0;
  }

  .ca-proof-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    max-width: 700px;
    margin: 0 auto;
  }

  .ca-proof-stat {
    font-size: clamp(48px, 8vw, 72px);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    flex-shrink: 0;
  }

  .ca-proof-text {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
  }

  .ca-proof-source {
    display: block;
    margin-top: 8px;
    font-size: 14px;
    color: rgba(255,255,255,0.5);
  }

  /* ─── Pricing ───────────────────────────────────────────── */
  .ca-price-range {
    font-size: clamp(36px, 5vw, 48px);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .ca-price-anchor {
    font-size: 16px;
    color: var(--color-muted);
  }

  .ca-price-anchor strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* ─── Process Flow ──────────────────────────────────────── */
  .ca-process-flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }

  .ca-process-step {
    padding: 28px 24px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: #fff;
  }

  .ca-process-connector {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    font-size: 20px;
    font-weight: 700;
    padding: 0 8px;
    margin-top: 40px;
  }

  .ca-step-num {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .ca-process-step h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .ca-process-step p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-muted);
  }

  /* ─── Final CTA (Dark Navy) ─────────────────────────────── */
  .ca-final-cta {
    background: var(--color-navy);
    padding: 80px 0;
  }

  .ca-cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .ca-cta-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .ca-cta-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .ca-cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .ca-cta-note {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
  }

  /* ─── Responsive ────────────────────────────────────────── */
  .hide-mobile { display: inline; }

  @media (max-width: 1024px) {
    .ca-grid-8 { grid-template-columns: repeat(2, 1fr); }
    .ca-process-flow {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .ca-process-connector {
      transform: rotate(90deg);
      margin: 0 auto;
      padding: 0;
    }
  }

  @media (max-width: 768px) {
    .ca-hero { padding: 80px 0 60px; }
    .hide-mobile { display: none; }
    .ca-deliverable { grid-template-columns: 1fr; gap: 40px; }
    .ca-proof-inner {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .ca-grid-8 { grid-template-columns: 1fr; }
    .ca-hero-trust { flex-direction: column; gap: 8px; }
  }
</style>

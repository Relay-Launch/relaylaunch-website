---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

const webhookUrl = import.meta.env.PUBLIC_CONTACT_WEBHOOK_URL || '#';
---

<Layout
  title="Complete Business Analysis | RelayLaunch"
  description="See exactly where your business stands and where it can go. An 8-area diagnostic covering operations, tech stack, AI readiness, and more, with a prioritized roadmap."
  canonicalUrl="https://relaylaunch.com/complete-analysis/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Complete Business Analysis',
    provider: {
      '@type': 'Organization',
      name: 'RelayLaunch LLC',
      url: 'https://relaylaunch.com',
    },
    description: 'A comprehensive 8-area business analysis covering operations, digital infrastructure, tech stack, AI readiness, digital footprint, market snapshot, connection map, and priority roadmap.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1500',
      highPrice: '3000',
    },
  }}
>

  <!-- ═══════════════════════════════════════════════ 1. HERO — Dark Navy -->
  <section class="ca-hero">
    <div class="container">
      <div class="ca-hero-layout">

        <!-- Left: Headline + CTA -->
        <div class="ca-hero-left">
          <span class="ca-eyebrow-light">Complete Analysis · $1,500–$3,000</span>
          <h1 class="ca-hero-title">
            See exactly where your business stands<br class="hide-mobile" />
            and where it can go.
          </h1>
          <p class="ca-hero-sub">
            An 8-area diagnostic of your entire business infrastructure. You get a professional
            20–30 page report with findings, benchmarks, and a prioritized roadmap so
            you know exactly what to fix, what to keep, and what to build next.
          </p>
          <div class="ca-hero-actions">
            <Button variant="primary" href="#book" size="lg">Book Your Analysis &rarr;</Button>
            <a href="#process" class="ca-ghost-link">See How It Works ↓</a>
          </div>
          <div class="ca-hero-trust">
            <span><span class="ca-trust-check">&#10003;</span> Veteran-Owned</span>
            <span><span class="ca-trust-check">&#10003;</span> Fixed Pricing</span>
            <span><span class="ca-trust-check">&#10003;</span> No Retainer Required</span>
          </div>
        </div>

        <!-- Right: Deliverable snapshot card -->
        <div class="ca-hero-right" aria-hidden="true">
          <div class="ca-snapshot-card">
            <div class="ca-snapshot-header">
              <div class="ca-snapshot-logo">RL</div>
              <div>
                <div class="ca-snapshot-title">Complete Analysis Report</div>
                <div class="ca-snapshot-sub">RelayLaunch LLC · Confidential</div>
              </div>
            </div>
            <div class="ca-snapshot-divider"></div>
            <div class="ca-snapshot-section">Executive Summary</div>
            <div class="ca-snapshot-bar" style="width: 100%;"></div>
            <div class="ca-snapshot-bar" style="width: 80%;"></div>
            <div class="ca-snapshot-bar" style="width: 65%;"></div>
            <div class="ca-snapshot-divider"></div>
            <div class="ca-snapshot-section">8-Area Findings</div>
            <div class="ca-snapshot-areas">
              <span class="ca-snapshot-tag ca-tag-hi">Business Ops</span>
              <span class="ca-snapshot-tag ca-tag-hi">AI Readiness</span>
              <span class="ca-snapshot-tag ca-tag-med">Tech Stack</span>
              <span class="ca-snapshot-tag ca-tag-hi">Digital Footprint</span>
              <span class="ca-snapshot-tag ca-tag-low">Infrastructure</span>
              <span class="ca-snapshot-tag ca-tag-med">Market Snapshot</span>
            </div>
            <div class="ca-snapshot-divider"></div>
            <div class="ca-snapshot-section">Priority Roadmap</div>
            <div class="ca-snapshot-roadmap">
              <div class="ca-roadmap-item">
                <span class="ca-roadmap-dot ca-dot-hi"></span>
                <div>
                  <div class="ca-roadmap-bar" style="width: 90%;"></div>
                </div>
                <span class="ca-roadmap-label">High Impact</span>
              </div>
              <div class="ca-roadmap-item">
                <span class="ca-roadmap-dot ca-dot-med"></span>
                <div>
                  <div class="ca-roadmap-bar" style="width: 70%;"></div>
                </div>
                <span class="ca-roadmap-label">Medium</span>
              </div>
              <div class="ca-roadmap-item">
                <span class="ca-roadmap-dot ca-dot-low"></span>
                <div>
                  <div class="ca-roadmap-bar" style="width: 50%;"></div>
                </div>
                <span class="ca-roadmap-label">Low</span>
              </div>
            </div>
            <div class="ca-snapshot-footer">
              20–30 pages · Delivered in 2–3 weeks
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 2. WHAT YOU GET — White -->
  <section class="section">
    <div class="container">
      <div class="ca-section-header reveal">
        <span class="section-eyebrow">What You Get</span>
        <h2 class="section-title">Eight areas. One clear picture.</h2>
        <p class="section-sub">
          Every Complete Analysis covers all eight areas so nothing gets missed.
          Most businesses have never seen all of these in one place.
        </p>
      </div>

      <div class="ca-grid-8">
        {[
          { num: '01', icon: '⚙️', title: 'Business Ops', desc: 'Workflows, processes, and daily operations mapped for inefficiencies and automation opportunities.' },
          { num: '02', icon: '☁️', title: 'Digital Infrastructure', desc: 'Hosting, domains, email, DNS, and the systems that keep your business running online.' },
          { num: '03', icon: '🔧', title: 'Tech Stack', desc: 'Every tool you pay for, how they connect (or don\'t), and where you\'re overspending.' },
          { num: '04', icon: '⚡', title: 'AI Readiness', desc: 'Where AI can save you time right now, and what needs to be in place before it actually works.' },
          { num: '05', icon: '🌐', title: 'Digital Footprint', desc: 'Website performance, SEO, social presence, and how your brand looks to someone finding you for the first time.' },
          { num: '06', icon: '📈', title: 'Market Snapshot', desc: 'How you compare to competitors in your space: pricing, positioning, and digital maturity.' },
          { num: '07', icon: '🔗', title: 'Connection Map', desc: 'How your systems, data, and teams connect (or don\'t), and where the gaps create friction and manual work.' },
          { num: '08', icon: '📍', title: 'Priority Roadmap', desc: 'A sequenced action plan ranked by impact and effort, so you know exactly where to start.' },
        ].map((area) => (
          <div class="ca-area-card reveal">
            <div class="ca-area-num">{area.num}</div>
            <div class="ca-area-icon">{area.icon}</div>
            <h3>{area.title}</h3>
            <p>{area.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 3. THE DELIVERABLE — Light Gray -->
  <section class="section ca-deliverable-section">
    <div class="container">
      <div class="ca-deliverable reveal">

        <div class="ca-deliverable-text">
          <span class="section-eyebrow">The Deliverable</span>
          <h2 class="section-title" style="font-size: clamp(24px, 3.5vw, 36px);">
            A professional 20–30 page report.<br />Not a slide deck. Not a checklist.
          </h2>
          <p class="ca-body-text">
            You receive a comprehensive document with an executive summary, detailed findings
            across all eight areas, benchmarks against your industry, and a prioritized roadmap
            with specific next steps. Written in plain language, not consultant-speak.
          </p>
          <ul class="checklist ca-deliverable-list">
            <li>Executive summary with top 3–5 findings</li>
            <li>Detailed analysis of all 8 areas</li>
            <li>Visual diagrams of your current systems</li>
            <li>Industry benchmarks and comparisons</li>
            <li>Prioritized roadmap with effort/impact ratings</li>
            <li>90-minute walkthrough call included</li>
          </ul>
          <div class="ca-delivery-meta">
            <div class="ca-delivery-item">
              <span class="ca-delivery-num">2–3 wks</span>
              <span class="ca-delivery-label">Delivery timeline</span>
            </div>
            <div class="ca-delivery-item">
              <span class="ca-delivery-num">20–30 pg</span>
              <span class="ca-delivery-label">Report length</span>
            </div>
            <div class="ca-delivery-item">
              <span class="ca-delivery-num">90 min</span>
              <span class="ca-delivery-label">Walkthrough call</span>
            </div>
          </div>
        </div>

        <!-- Report mockup -->
        <div class="ca-report-wrap" aria-hidden="true">
          <div class="ca-report-mock">
            <div class="ca-report-toolbar">
              <span class="ca-report-dot" style="background:var(--color-border);"></span>
              <span class="ca-report-dot" style="background:var(--color-border);"></span>
              <span class="ca-report-dot" style="background:var(--color-border);"></span>
              <span class="ca-report-filename">complete-analysis-report.pdf</span>
            </div>
            <div class="ca-report-body">
              <div class="ca-report-header">
                <div class="ca-report-logo">RL</div>
                <div>
                  <div class="ca-report-co">RelayLaunch LLC</div>
                  <div class="ca-report-subtitle">Complete Business Analysis</div>
                </div>
              </div>
              <div class="ca-report-client-block">
                <div class="ca-report-client-label">Prepared for</div>
                <div class="ca-report-client-name">[Your Business Name]</div>
                <div class="ca-report-client-date">Analysis Date: 2026</div>
              </div>
              <div class="ca-report-section-label">Executive Summary</div>
              <div class="ca-report-line" style="width:100%;"></div>
              <div class="ca-report-line" style="width:82%;"></div>
              <div class="ca-report-line" style="width:94%;"></div>
              <div class="ca-report-line" style="width:68%;"></div>
              <div class="ca-report-divider"></div>
              <div class="ca-report-section-label">8-Area Analysis</div>
              <div class="ca-report-area-row">
                <span class="ca-area-pill ca-pill-hi">Business Ops</span>
                <span class="ca-area-pill ca-pill-med">Tech Stack</span>
                <span class="ca-area-pill ca-pill-hi">AI Readiness</span>
              </div>
              <div class="ca-report-area-row">
                <span class="ca-area-pill ca-pill-hi">Digital Footprint</span>
                <span class="ca-area-pill ca-pill-low">Infrastructure</span>
              </div>
              <div class="ca-report-divider"></div>
              <div class="ca-report-section-label">Priority Roadmap</div>
              <div class="ca-report-roadmap">
                <div class="ca-rm-row">
                  <span class="ca-rm-badge ca-rm-badge-hi">HIGH</span>
                  <div class="ca-rm-bar ca-rm-hi" style="width:95%;"></div>
                </div>
                <div class="ca-rm-row">
                  <span class="ca-rm-badge ca-rm-badge-med">MED</span>
                  <div class="ca-rm-bar ca-rm-med" style="width:72%;"></div>
                </div>
                <div class="ca-rm-row">
                  <span class="ca-rm-badge ca-rm-badge-low">LOW</span>
                  <div class="ca-rm-bar ca-rm-low" style="width:48%;"></div>
                </div>
              </div>
            </div>
          </div>
          <p class="ca-report-caption">Sample report structure</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 4. PROOF POINTS — Dark Navy -->
  <section class="ca-proof-section">
    <div class="container">
      <div class="ca-proof-header reveal">
        <span class="ca-eyebrow-light">Why It Matters</span>
        <h2 class="ca-proof-title">Most businesses are flying blind.</h2>
      </div>
      <div class="ca-proof-grid reveal-stagger">
        <div class="ca-proof-card">
          <div class="ca-proof-stat">86%</div>
          <p class="ca-proof-label">of consulting buyers now seek AI-enabled services when evaluating providers</p>
          <p class="ca-proof-note">AI readiness is a core area in every Complete Analysis, not an upsell.</p>
        </div>
        <div class="ca-proof-card">
          <div class="ca-proof-stat">$400<span class="ca-proof-unit">/mo</span></div>
          <p class="ca-proof-label">average small business spends on disconnected tools that don't share data</p>
          <p class="ca-proof-note">The analysis identifies exactly which tools to cut, consolidate, or replace.</p>
        </div>
        <div class="ca-proof-card">
          <div class="ca-proof-stat">37%</div>
          <p class="ca-proof-label">of small businesses have a website but zero marketing automation running</p>
          <p class="ca-proof-note">The Connection Map shows exactly where automation would save the most time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 5. PRICING — White -->
  <section class="section">
    <div class="container">
      <div class="ca-section-header reveal">
        <span class="section-eyebrow">Investment</span>
        <h2 class="section-title">Transparent pricing. No surprises.</h2>
        <p class="section-sub">
          You get an exact quote after the free discovery call, before any commitment.
        </p>
      </div>

      <div class="ca-pricing-layout">
        <div class="ca-pricing-card card featured reveal">
          <span class="badge badge-solid-primary" style="margin-bottom: 20px;">Most Popular Starting Point</span>
          <div class="ca-price-range">$1,500&ndash;$3,000</div>
          <div class="ca-price-anchor">Most engagements land around <strong>$2,000</strong></div>
          <p class="ca-body-text" style="margin: 20px 0;">
            Scope depends on your business size and complexity.
            One-time engagement. No retainer, no surprise invoices.
          </p>
          <ul class="checklist" style="margin-bottom: 28px; text-align: left;">
            <li>All 8 analysis areas included</li>
            <li>20–30 page professional report</li>
            <li>90-minute walkthrough call</li>
            <li>Delivered in 2–3 weeks</li>
            <li>Veteran-owned, fixed price</li>
          </ul>
          <Button variant="primary" href="#book" class="w-full justify-center" size="lg">
            Book Your Analysis &rarr;
          </Button>
        </div>

        <div class="ca-vs-col reveal">
          <div class="ca-vs-header">vs. the alternatives</div>
          <div class="ca-vs-table">
            <div class="ca-vs-row ca-vs-row-head">
              <div></div>
              <div class="ca-vs-col-label">Complete Analysis</div>
              <div class="ca-vs-col-label">Freelance Consultant</div>
              <div class="ca-vs-col-label">DIY Audit</div>
            </div>
            {[
              { label: 'Cost', ours: '$1,500–3,000', alt1: '$3,000–10,000+', alt2: 'Your time ($0)' },
              { label: 'Time to results', ours: '2–3 weeks', alt1: '4–8 weeks', alt2: '3–6 months' },
              { label: '8-area coverage', ours: '✓', alt1: 'Varies', alt2: '✗' },
              { label: 'AI readiness check', ours: '✓', alt1: 'Rare', alt2: '✗' },
              { label: 'Prioritized roadmap', ours: '✓', alt1: '✓', alt2: '✗' },
              { label: 'Walkthrough call', ours: '✓', alt1: 'Extra $$', alt2: '✗' },
            ].map((row) => (
              <div class="ca-vs-row">
                <div class="ca-vs-item-label">{row.label}</div>
                <div class="ca-vs-item ca-vs-ours">{row.ours}</div>
                <div class="ca-vs-item ca-vs-alt">{row.alt1}</div>
                <div class="ca-vs-item ca-vs-alt">{row.alt2}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 5b. CASE STUDY PROOF — White -->
  <section class="section">
    <div class="container">
      <div class="ca-cs-proof reveal">
        <div class="ca-cs-proof-text">
          <span class="section-eyebrow">Real Result</span>
          <h2 class="section-title" style="font-size: clamp(22px, 3vw, 32px);">
            A luxury spa was paying $342/mo for tools<br class="hide-mobile" /> that didn't talk to each other.
          </h2>
          <p class="ca-body-text" style="margin: 16px 0 24px;">
            After a Complete Analysis, we identified $280/month in redundant subscriptions,
            consolidated five disconnected tools into one connected system, and launched
            an automated booking and follow-up workflow, all in under 30 days.
          </p>
          <div class="ca-cs-stats">
            <div class="ca-cs-stat">
              <span class="ca-cs-num">$280</span>
              <span class="ca-cs-label">saved per month in redundant tools</span>
            </div>
            <div class="ca-cs-stat">
              <span class="ca-cs-num">5→1</span>
              <span class="ca-cs-label">disconnected tools unified</span>
            </div>
            <div class="ca-cs-stat">
              <span class="ca-cs-num">30 days</span>
              <span class="ca-cs-label">from analysis to live automation</span>
            </div>
          </div>
          <a href="/case-studies/luxury-wellness-spa" class="ca-cs-link">Read the full case study →</a>
        </div>
        <div class="ca-cs-proof-card reveal">
          <div class="ca-cs-card-label">Before the Analysis</div>
          <ul class="ca-cs-before-list">
            <li>ClickFunnels + Squarespace + 3 other tools</li>
            <li>Manual booking confirmations</li>
            <li>No follow-up automation</li>
            <li>$342/month in subscriptions</li>
            <li>Owner doing everything by hand</li>
          </ul>
          <div class="ca-cs-card-divider"></div>
          <div class="ca-cs-card-label ca-cs-after-label">After the Analysis + Launch</div>
          <ul class="ca-cs-after-list">
            <li>One connected system (website + CRM + automations)</li>
            <li>Automated booking, confirmation, and follow-up</li>
            <li>$62/month total tool spend</li>
            <li>Owner's time freed from manual admin work</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 6. PROCESS — Light Gray -->
  <section class="section ca-process-section" id="process">
    <div class="container">
      <div class="ca-section-header reveal">
        <span class="section-eyebrow">The Process</span>
        <h2 class="section-title">Four steps. Zero guesswork.</h2>
        <p class="section-sub">
          From first call to final report. No prep required on your end. Just show up.
        </p>
      </div>

      <div class="ca-process-flow">
        {[
          {
            num: '01',
            step: 'Discovery',
            time: '30 min',
            desc: 'Free call. We learn your business, tools, pain points, and goals. No prep needed. Just show up.',
          },
          {
            num: '02',
            step: 'Intake',
            time: '15 min',
            desc: 'You share access to key accounts and fill out a short intake form. That\'s it on your end.',
          },
          {
            num: '03',
            step: 'Analysis',
            time: '2–3 weeks',
            desc: 'We audit all 8 areas, pull benchmarks, and build your prioritized roadmap. You don\'t touch a thing.',
          },
          {
            num: '04',
            step: 'Presentation',
            time: '90 min',
            desc: 'We walk through every finding and recommendation. You leave with a clear path forward, not more questions.',
          },
        ].map((step, i) => (
          <div class="ca-process-step reveal">
            <div class="ca-step-header">
              <span class="ca-step-num">{step.num}</span>
              <span class="ca-step-time">{step.time}</span>
            </div>
            <h3 class="ca-step-title">{step.step}</h3>
            <p class="ca-step-desc">{step.desc}</p>
            {i < 3 && <div class="ca-step-arrow" aria-hidden="true">→</div>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 7. WHAT HAPPENS AFTER — White -->
  <section class="section">
    <div class="container">
      <div class="ca-section-header reveal">
        <span class="section-eyebrow">No Commitment Required</span>
        <h2 class="section-title">The analysis stands on its own.</h2>
        <p class="section-sub">
          You get the full report and walkthrough regardless of what you do next.
          Most clients use it to make their own decision. It's not ours to make for you.
        </p>
      </div>
      <div class="ca-after-grid reveal-stagger">
        <div class="ca-after-card">
          <div class="ca-after-num">A</div>
          <h3 class="ca-after-title">Take it and run</h3>
          <p class="ca-after-desc">
            Use the roadmap to execute yourself, hire in-house, or bring in another vendor.
            The report is yours. Fully documented, no strings attached.
          </p>
        </div>
        <div class="ca-after-card ca-after-featured">
          <div class="ca-after-badge">Most Common Path</div>
          <div class="ca-after-num">B</div>
          <h3 class="ca-after-title">Continue with RelayLaunch</h3>
          <p class="ca-after-desc">
            If the analysis shows you're ready to build, we'll scope a Launch engagement.
            If ongoing support fits better, we'll talk Run or Scale, with the analysis
            cost applied toward your first engagement.
          </p>
          <div class="ca-after-tiers">
            <span class="ca-after-tier">Launch ($2,500–$5,000)</span>
            <span class="ca-after-tier">Run ($500–$1,000/mo)</span>
            <span class="ca-after-tier">Scale ($1,000–$2,500/mo)</span>
          </div>
        </div>
        <div class="ca-after-card">
          <div class="ca-after-num">C</div>
          <h3 class="ca-after-title">Park it for now</h3>
          <p class="ca-after-desc">
            Timing isn't right? The report stays relevant for 12–18 months.
            Come back when you're ready. You'll have a clear head start.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ 8. FINAL CTA + FORM — Dark Navy -->
  <section class="ca-final-cta" id="book">
    <div class="container">
      <div class="ca-cta-layout">

        <!-- Left: Headline + trust -->
        <div class="ca-cta-left reveal">
          <span class="ca-eyebrow-light">Book Your Discovery Call</span>
          <h2 class="ca-cta-title">
            30 minutes. No pitch.<br />Just the truth about your business.
          </h2>
          <p class="ca-cta-sub">
            We'll look at what you have, what it's costing you, and whether a Complete
            Analysis makes sense. No commitment required.
          </p>
          <div class="ca-cta-trust">
            <div class="ca-cta-trust-item">
              <span class="ca-trust-check">&#10003;</span>
              Free 30-minute call
            </div>
            <div class="ca-cta-trust-item">
              <span class="ca-trust-check">&#10003;</span>
              Exact quote before any commitment
            </div>
            <div class="ca-cta-trust-item">
              <span class="ca-trust-check">&#10003;</span>
              USMC Veteran-Owned
            </div>
          </div>
          <p class="ca-cta-contact-alt">
            Prefer email? <a href="mailto:hello@relaylaunch.com">hello@relaylaunch.com</a><br />
            Or call <a href="tel:+18573186498">857-318-6498</a> during business hours.
          </p>
        </div>

        <!-- Right: Inline form -->
        <div class="ca-form-wrap reveal">
          <form
            id="ca-book-form"
            class="ca-book-form"
            data-webhook={webhookUrl}
            novalidate
          >
            <div class="ca-form-row">
              <div class="ca-form-field">
                <label for="ca-name">Your Name</label>
                <input
                  type="text"
                  id="ca-name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Victor Medina"
                />
              </div>
              <div class="ca-form-field">
                <label for="ca-email">Business Email</label>
                <input
                  type="email"
                  id="ca-email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@company.com"
                />
              </div>
            </div>
            <div class="ca-form-field">
              <label for="ca-business">Business Name</label>
              <input
                type="text"
                id="ca-business"
                name="business"
                autocomplete="organization"
                placeholder="Acme Corp"
              />

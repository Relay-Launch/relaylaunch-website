---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/starwind/button';
---

<Layout
  title="Complete Business Analysis — RelayLaunch"
  description="A deep-dive analysis of your digital presence, operations, tool stack, and growth opportunities. Signal + Blueprint combined into one comprehensive engagement."
  canonicalUrl="https://relaylaunch.com/complete-analysis/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Complete Business Analysis',
    provider: { '@type': 'Organization', name: 'RelayLaunch LLC' },
    description: 'A comprehensive engagement combining Signal audit and Blueprint strategy — full analysis of digital presence, operations, tool stack, and a 90-day growth roadmap.',
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '1500',
      highPrice: '3000',
    },
  }}
>

  <!-- ═══════════════════════════════════════════════ HERO -->
  <section class="section hero">
    <div class="container">
      <span class="section-eyebrow">Complete Analysis</span>
      <h1 class="section-title" style="font-size: clamp(32px, 5vw, 52px); max-width: 700px;">
        Know exactly where your business<br />
        stands — and where it should go.
      </h1>
      <p class="section-sub" style="max-width: 620px;">
        The Complete Analysis combines our Signal audit and Blueprint strategy into a single,
        comprehensive engagement. You get a full picture of what's working, what's broken,
        and a 90-day roadmap to fix it — all in one package.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ WHAT YOU GET -->
  <section class="section">
    <div class="container">
      <div class="analysis-grid">
        <div>
          <span class="section-eyebrow">What's Included</span>
          <h2 class="section-title" style="font-size: clamp(24px, 3vw, 36px);">
            Two packages. One engagement.<br />Complete clarity.
          </h2>
          <p style="color: var(--color-muted); font-size: 16px; line-height: 1.7; margin-top: 16px; margin-bottom: 32px;">
            Instead of choosing between a quick audit (Signal) and a full strategy engagement
            (Blueprint), the Complete Analysis delivers both — at a combined rate that's more
            efficient than running them separately.
          </p>

          <div class="price-block">
            <div class="price-tag">$1,500–$2,500 <span>one-time</span></div>
            <p class="price-note">Compared to $1,700–$2,900 if purchased separately</p>
          </div>
        </div>

        <div class="card deliverables-card">
          <p class="section-eyebrow" style="margin-bottom: 20px;">Full Deliverables</p>

          <h3 class="phase-title">Phase 1 — Signal (Audit)</h3>
          <ul class="checklist">
            <li>Business &amp; digital presence audit report</li>
            <li>Tool stack inventory — what's redundant, what's missing, what to cut</li>
            <li>Workflow bottleneck map — where your time is actually going</li>
            <li>30-day priority action plan</li>
          </ul>

          <h3 class="phase-title" style="margin-top: 28px;">Phase 2 — Blueprint (Strategy)</h3>
          <ul class="checklist">
            <li>90-day growth roadmap with milestones</li>
            <li>Automation opportunity map — exactly where manual work can go away</li>
            <li>Competitive landscape overview</li>
            <li>Tech stack recommendation — what to keep, replace, or add</li>
            <li>ROI projection for recommended changes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ WHO IT'S FOR -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <span class="section-eyebrow">Who This Is For</span>
      <h2 class="section-title" style="margin-bottom: 40px;">Business owners who want the full picture.</h2>

      <div class="audience-grid">
        <div class="audience-item">
          <div class="audience-icon">🔍</div>
          <h3>You know something's off</h3>
          <p>You're spending too much on tools, losing hours to manual work, or your online presence isn't matching the quality of your service — but you're not sure where to start.</p>
        </div>
        <div class="audience-item">
          <div class="audience-icon">📋</div>
          <h3>You want a plan before you build</h3>
          <p>You're not ready to commit to a full build yet. You want a documented strategy you can execute yourself, hand to a team, or bring back to RelayLaunch for the Relay package.</p>
        </div>
        <div class="audience-item">
          <div class="audience-icon">💰</div>
          <h3>You want to stop wasting money</h3>
          <p>You suspect you're paying for overlapping tools and doing work that could be automated. The Complete Analysis puts hard numbers on exactly where the waste is.</p>
        </div>
        <div class="audience-item">
          <div class="audience-icon">📈</div>
          <h3>You're ready to scale</h3>
          <p>Business is good but growth is bottlenecked by systems. You need to know what infrastructure changes will unlock the next stage — and in what order.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PROCESS -->
  <section class="section">
    <div class="container">
      <span class="section-eyebrow">The Process</span>
      <h2 class="section-title" style="margin-bottom: 40px;">How it works.</h2>

      <div class="process-grid">
        <div class="process-step">
          <span class="step-number">01</span>
          <h3>Discovery Call</h3>
          <p>30–45 minutes. We learn your business model, current tools, pain points, and goals. No prep required on your end.</p>
        </div>
        <div class="process-step">
          <span class="step-number">02</span>
          <h3>Audit &amp; Research</h3>
          <p>We inventory your tool stack, map your workflows, audit your digital presence, and research your competitive landscape.</p>
        </div>
        <div class="process-step">
          <span class="step-number">03</span>
          <h3>Analysis &amp; Strategy</h3>
          <p>We build the automation opportunity map, growth roadmap, tech stack recommendations, and ROI projections.</p>
        </div>
        <div class="process-step">
          <span class="step-number">04</span>
          <h3>Delivery &amp; Review</h3>
          <p>You receive the full report and we walk through every finding and recommendation together. You walk away with a clear path forward.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Ready to get the full picture?</h2>
      <p class="section-sub" style="margin: 16px auto 32px; max-width: 520px;">
        Start with a conversation. We'll scope the analysis to your specific business
        and give you a clear proposal before anything starts.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <Button variant="primary" href="/contact">Start a Complete Analysis →</Button>
        <Button variant="outline" href="/intake">Already approved? Start the intake →</Button>
        <Button variant="outline" href="/services">Compare All Packages</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero { padding-top: 80px; }

  .analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .price-block {
    padding: 20px 24px;
    border-radius: 10px;
    border: 1px solid var(--color-green);
    background: rgba(35, 134, 54, 0.04);
  }

  .price-tag {
    font-size: 28px;
    font-weight: 800;
    color: var(--color-green);
  }

  .price-tag span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    margin-left: 4px;
  }

  .price-note {
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 6px;
  }

  .deliverables-card { padding: 28px; }

  .phase-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 16px;
  }

  /* Audience grid */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .audience-item {
    padding: 28px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .audience-icon { font-size: 28px; margin-bottom: 14px; }
  .audience-item h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
  .audience-item p { font-size: 14px; line-height: 1.65; }

  /* Process grid */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .process-step {
    padding: 24px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .step-number {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-green);
    margin-bottom: 12px;
  }

  .process-step h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; }
  .process-step p { font-size: 14px; line-height: 1.65; }

  @media (max-width: 768px) {
    .analysis-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

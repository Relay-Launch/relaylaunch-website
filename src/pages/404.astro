---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found — RelayLaunch"
  description="The page you're looking for doesn't exist. Head back to RelayLaunch to find what you need."
>

  <section class="section not-found-section">
    <div class="container not-found-inner">
      <p class="error-code">404</p>
      <h1 class="not-found-title">Page not found.</h1>
      <p class="not-found-sub">
        The page you're looking for has moved, been renamed, or doesn't exist.
        Here are some places to go instead:
      </p>
      <nav class="not-found-links" aria-label="Helpful links">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/services" class="btn-secondary">View Services</a>
        <a href="/contact" class="btn-secondary">Contact Us</a>
      </nav>
    </div>
  </section>

</Layout>

<style>
  .not-found-section {
    min-height: calc(100vh - 60px - 200px);
    display: flex;
    align-items: center;
  }

  .not-found-inner {
    text-align: center;
    max-width: 520px;
    margin-inline: auto;
  }

  .error-code {
    font-size: clamp(80px, 18vw, 140px);
    font-weight: 800;
    letter-spacing: -4px;
    color: var(--color-surface);
    line-height: 1;
    margin-bottom: 8px;
    /* Outlined style */
    -webkit-text-stroke: 2px var(--color-border);
  }

  .not-found-title {
    font-size: clamp(24px, 5vw, 36px);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 16px;
  }

  .not-found-sub {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .not-found-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

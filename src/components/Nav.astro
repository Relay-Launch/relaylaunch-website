---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Control Center', href: '/control-center' },
  { label: 'How We Work', href: '/how-we-work' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;

/**
 * Check if a navigation link is active
 * Optimized with early returns to reduce unnecessary string operations
 */
function isActive(href: string): boolean {
  if (currentPath === href) return true;
  if (href === '/') return false; // Prevent home from always being active
  return currentPath.startsWith(href + '/');
}
import { Button } from '@/components/starwind/button';
import { ThemeToggle } from '@/components/starwind/theme-toggle';
---

<header>
  <nav class="nav-inner container">
    <a href="/" class="nav-brand" aria-label="RelayLaunch home">
      <span class="nav-brand-group">
        <span class="nav-brand-text">
          <span class="brand-relay">Relay</span><span class="brand-arrow">&#x25BA;</span><span class="brand-launch">Launch</span>
        </span>
        <span class="nav-brand-tagline">Ops on Autopilot. You on Strategy.</span>
      </span>
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-right">
      <ThemeToggle size="sm" class="nav-theme-toggle" />
      <Button variant="primary" href="/contact" size="sm" class="nav-cta">Start a Project</Button>
      <button class="menu-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <ul role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['mobile-nav-link', { active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <Button variant="primary" href="/contact" class="mobile-nav-cta w-full justify-center">Start a Project</Button>
      </li>
      <li class="mobile-theme-row">
        <span class="mobile-theme-label">Dark mode</span>
        <ThemeToggle size="sm" />
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;

  function closeMobileNav() {
    toggle.setAttribute('aria-expanded', 'false');
    mobileNav.setAttribute('aria-hidden', 'true');
    mobileNav.classList.remove('open');
    toggle.classList.remove('is-open');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav.setAttribute('aria-hidden', String(isOpen));
    mobileNav.classList.toggle('open', !isOpen);
    toggle.classList.toggle('is-open', !isOpen);
  });

  // Close on link click using event delegation (more efficient)
  mobileNav?.addEventListener('click', (e) => {
    if (!(e.target instanceof Element) || !e.target.closest('a')) return;
    closeMobileNav();
  });

  // Close on Escape key for keyboard accessibility
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMobileNav();
      toggle.focus();
    }
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: var(--z-dropdown);
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 32px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .nav-brand:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .nav-brand-group {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1;
  }

  .nav-brand-text {
    display: flex;
    align-items: center;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .nav-brand-tagline {
    font-size: 9px;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.3px;
    white-space: nowrap;
    opacity: 0.8;
  }

  .brand-relay, .brand-launch { color: var(--color-text); }
  .brand-arrow { color: var(--color-primary); margin: 0 2px; font-size: 14px; transition: transform 0.2s ease; }
  .nav-brand:hover .brand-arrow { transform: translateX(2px); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-link {
    display: block;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
  }

  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 13px;
    padding: 8px 16px;
  }

  /* ── Hamburger ── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .menu-toggle:hover { border-color: var(--color-muted); }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
    transform-origin: center;
  }

  /* Animate to X when open */
  .menu-toggle.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile nav drawer ── */
  .mobile-nav {
    display: none;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transform: translateY(-8px);
    background: color-mix(in srgb, var(--color-bg) 98%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
    transition: max-height 0.3s cubic-bezier(.22,1,.36,1),
      transform var(--transition-smooth),
      opacity var(--transition-smooth);
  }

  .mobile-nav.open {
    max-height: 500px;
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 12px 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-link {
    display: block;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
    text-decoration: none;
  }

  .mobile-nav-link.active {
    color: var(--color-primary);
    background: var(--color-primary-subtle, color-mix(in srgb, var(--primary) 8%, transparent));
    font-weight: 600;
    text-decoration: none;
  }

  .mobile-nav-cta {
    display: block;
    text-align: center;
    margin-top: 8px;
    font-size: 14px;
    padding: 10px 16px;
    text-decoration: none;
  }

  .nav-theme-toggle {
    color: var(--color-muted);
  }

  .mobile-theme-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    margin-top: 4px;
    border-top: 1px solid var(--color-border);
  }

  .mobile-theme-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .nav-inner { height: 56px; gap: 12px; }
    .nav-links { display: none; }
    .menu-toggle { display: flex; }
    .mobile-nav { display: block; }
    .nav-cta { display: none; }
    .nav-theme-toggle { display: none; }
    .nav-brand { gap: 7px; }
    .nav-brand-text { font-size: 17px; }
    .nav-brand-tagline { font-size: 8px; }
  }
</style>

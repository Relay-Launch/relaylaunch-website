---
import { Button } from '@/components/starwind/button';
---

<!-- ═══════════════════════════════════════════════ ROI CALCULATOR -->
<section class="section roi-section mobile-condensed">
  <div class="container">
    <div class="reveal">
      <span class="section-eyebrow">ROI Calculator</span>
      <h2 class="section-title" style="margin-bottom: 12px;">How much is the chaos actually costing you?</h2>
      <p class="section-sub" style="margin-bottom: 40px;">Plug in your numbers. The math speaks for itself.</p>
    </div>
    <div class="roi-calc card" style="max-width: 800px; margin: 0 auto; padding: 40px;">
      <div class="roi-inputs">
        <div class="roi-field">
          <label for="roi-tools">Monthly tool spend</label>
          <div class="roi-input-wrap">
            <span class="roi-prefix">$</span>
            <input type="number" id="roi-tools" value="350" min="0" max="5000" step="50" />
          </div>
        </div>
        <div class="roi-field">
          <label for="roi-hours">Hours/week on manual work</label>
          <input type="number" id="roi-hours" value="8" min="0" max="60" step="1" />
        </div>
        <div class="roi-field">
          <label for="roi-num-tools">Number of tools</label>
          <input type="number" id="roi-num-tools" value="6" min="1" max="20" step="1" />
        </div>
        <div class="roi-field">
          <label for="roi-rate">Your hourly rate</label>
          <div class="roi-input-wrap">
            <span class="roi-prefix">$</span>
            <input type="number" id="roi-rate" value="100" min="0" max="1000" step="25" />
          </div>
        </div>
      </div>
      <div class="roi-results" id="roi-results">
        <h3>Your estimated annual savings</h3>
        <div class="roi-stats">
          <div class="roi-stat">
            <div class="roi-stat-number" id="roi-tool-savings">$3,588</div>
            <div class="roi-stat-label">in tool cost savings</div>
          </div>
          <div class="roi-stat">
            <div class="roi-stat-number" id="roi-time-value">$41,600</div>
            <div class="roi-stat-label">in reclaimed time value</div>
          </div>
          <div class="roi-stat">
            <div class="roi-stat-number roi-stat-total" id="roi-total">$45,188</div>
            <div class="roi-stat-label">total annual impact</div>
          </div>
        </div>
        <Button variant="primary" href="/complete-analysis" class="mt-6">Get Your Free Assessment →</Button>
      </div>
    </div>
  </div>
</section>

<script>
  // ── ROI Calculator ──
  function calcROI() {
    const tools = parseFloat((document.getElementById('roi-tools') as HTMLInputElement)?.value) || 0;
    const hours = parseFloat((document.getElementById('roi-hours') as HTMLInputElement)?.value) || 0;
    const numTools = parseFloat((document.getElementById('roi-num-tools') as HTMLInputElement)?.value) || 1;
    const rate = parseFloat((document.getElementById('roi-rate') as HTMLInputElement)?.value) || 0;
    const consolidationRate = Math.min(0.6, numTools * 0.08);
    const toolSavings = Math.round(tools * consolidationRate * 12);
    const timeValue = Math.round(hours * rate * 52);
    const total = toolSavings + timeValue;
    const fmt = (n: number) => '$' + Math.abs(n).toLocaleString();
    const el = (id: string) => document.getElementById(id);
    if (el('roi-tool-savings')) el('roi-tool-savings')!.textContent = fmt(Math.max(0, toolSavings));
    if (el('roi-time-value')) el('roi-time-value')!.textContent = fmt(Math.max(0, timeValue));
    if (el('roi-total')) el('roi-total')!.textContent = fmt(Math.max(0, total));
  }
  document.querySelectorAll('.roi-field input').forEach(input => {
    input.addEventListener('input', calcROI);
  });
  calcROI();
</script>

<style>
  /* ── ROI Calculator ── */
  .roi-section { background: var(--color-surface); }
  .roi-inputs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }
  .roi-field { display: flex; flex-direction: column; gap: 6px; }
  .roi-field label { font-size: 13px; font-weight: 600; color: var(--color-text); }
  .roi-field input {
    padding: 10px 14px;
    font-size: 16px;
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .roi-field input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--shadow-primary-focus);
  }
  .roi-input-wrap { position: relative; display: flex; }
  .roi-prefix {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-muted);
    pointer-events: none;
  }
  .roi-input-wrap input { padding-left: 28px; width: 100%; }
  .roi-results { text-align: center; padding-top: 24px; border-top: 1px solid var(--color-border); }
  .roi-results h3 { font-size: 18px; font-weight: 800; margin-bottom: 24px; }
  .roi-stats { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
  .roi-stat { flex: 1; min-width: 140px; }
  .roi-stat-number { font-size: 28px; font-weight: 800; color: var(--color-primary); }
  .roi-stat-total { font-size: 34px; }
  .roi-stat-label { font-size: 13px; color: var(--color-muted); margin-top: 4px; }

  @media (max-width: 768px) {
    .roi-inputs { grid-template-columns: 1fr; }
    .roi-stats { flex-direction: column; gap: 16px; }
  }

  @media (max-width: 640px) {
    .mobile-condensed { display: none; }
  }
</style>

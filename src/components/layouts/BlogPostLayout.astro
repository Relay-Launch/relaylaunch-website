---
/**
 * BlogPostLayout — wraps individual MDX blog posts.
 * Provides article structure, post metadata, and back-to-blog link.
 */
import BaseLayout from './BaseLayout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { Button } from '@/components/starwind/button';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    author?: string;
    ogImage?: string;
    tags?: string[];
  };
  canonicalUrl?: string;
}

const { frontmatter, canonicalUrl } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.date,
  author: {
    '@type': 'Person',
    name: frontmatter.author || 'Victor David Medina',
  },
  publisher: {
    '@type': 'Organization',
    name: 'RelayLaunch LLC',
    url: 'https://relaylaunch.com',
  },
};
---

<BaseLayout
  title={`${frontmatter.title} — RelayLaunch Blog`}
  description={frontmatter.description}
  ogImage={frontmatter.ogImage}
  ogType="article"
  canonicalUrl={canonicalUrl}
  jsonLd={articleSchema}
>
  <Nav />
  <main id="main-content">
    <article class="section blog-article">
      <div class="container blog-container">
        <a href="/blog" class="back-link">&larr; Blog</a>

        <header class="blog-header">
          {frontmatter.tags && (
            <div class="blog-tags">
              {frontmatter.tags.map((tag: string) => (
                <span class="badge badge-green">{tag}</span>
              ))}
            </div>
          )}
          <h1 class="blog-title">{frontmatter.title}</h1>
          <p class="blog-meta">
            <time datetime={frontmatter.date}>{formattedDate}</time>
            {frontmatter.author && <span> · {frontmatter.author}</span>}
          </p>
        </header>

        <div class="blog-content">
          <slot />
        </div>
      </div>
    </article>

    <section class="section blog-cta">
      <div class="container" style="text-align: center;">
        <h2 class="section-title" style="font-size: clamp(22px, 3vw, 30px);">Ready to build smarter?</h2>
        <p class="section-sub" style="margin: 12px auto 28px; max-width: 480px;">
          See how RelayLaunch replaces disconnected tools with unified infrastructure.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <Button variant="primary" href="/services">View Services</Button>
          <Button variant="outline" href="/contact">Start a Project</Button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-container { max-width: 720px; }

  .back-link {
    display: inline-block;
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-text); text-decoration: none; }

  .blog-header { margin-bottom: 48px; }

  .blog-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

  .blog-title {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .blog-meta {
    font-size: 14px;
    color: var(--color-muted);
  }

  /* Prose styling for MDX content */
  .blog-content :global(h2) {
    font-size: 24px;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .blog-content :global(h3) {
    font-size: 20px;
    font-weight: 700;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  .blog-content :global(p) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .blog-content :global(li) { margin-bottom: 8px; }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding-left: 20px;
    margin: 28px 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .blog-content :global(code) {
    font-size: 14px;
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .blog-content :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .blog-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .blog-content :global(a) {
    color: var(--color-green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }

  .blog-cta { background: var(--color-surface); }

  .blog-article { padding-top: 80px; }
</style>

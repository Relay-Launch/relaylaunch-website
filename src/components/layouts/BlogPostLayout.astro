---
/**
 * BlogPostLayout - wraps individual MDX blog posts.
 * Provides article structure, post metadata, and back-to-blog link.
 */
import BaseLayout from './BaseLayout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { Button } from '@/components/starwind/button';
import { formatDate } from '@/utils/blog';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    author?: string;
    ogImage?: string;
    heroImage?: string;
    tags?: string[];
  };
  canonicalUrl?: string;
  readingTime?: string;
}

const { frontmatter, canonicalUrl, readingTime } = Astro.props;

const formattedDate = formatDate(frontmatter.pubDate);

const formattedUpdatedDate = frontmatter.updatedDate
  ? formatDate(frontmatter.updatedDate)
  : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.pubDate.toISOString(),
  ...(frontmatter.updatedDate && { dateModified: frontmatter.updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: frontmatter.author || 'Victor David Medina',
  },
  publisher: {
    '@type': 'Organization',
    name: 'RelayLaunch LLC',
    url: 'https://www.relaylaunch.com',
  },
};
---

<BaseLayout
  title={`${frontmatter.title} | RelayLaunch Blog`}
  description={frontmatter.description}
  ogImage={frontmatter.ogImage}
  ogType="article"
  canonicalUrl={canonicalUrl}
  jsonLd={articleSchema}
>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Nav />
  <main id="main-content">
    <article class="section blog-article">
      <div class="container blog-container">
        <a href="/blog" class="back-link">&larr; Blog</a>

        <header class="blog-header">
          {frontmatter.tags && (
            <div class="blog-tags">
              {frontmatter.tags.map((tag: string) => (
                <span class="badge badge-primary">{tag}</span>
              ))}
            </div>
          )}
          <h1 class="blog-title">{frontmatter.title}</h1>
          <p class="blog-meta">
            <time datetime={frontmatter.pubDate.toISOString()}>{formattedDate}</time>
            {formattedUpdatedDate && (
              <span class="updated-date"> · Updated <time datetime={frontmatter.updatedDate!.toISOString()}>{formattedUpdatedDate}</time></span>
            )}
            {frontmatter.author && <span> · {frontmatter.author}</span>}
            {readingTime && <span> · {readingTime}</span>}
          </p>
        </header>

        {frontmatter.heroImage && (
          <img src={frontmatter.heroImage} alt={`Hero image for ${frontmatter.title}`} class="blog-hero-image" loading="eager" />
        )}

        <div class="blog-content">
          <slot />
        </div>
      </div>
    </article>

    <section class="section blog-cta">
      <div class="container blog-cta-inner">
        <h2 class="section-title blog-cta-title">Ready to run leaner?</h2>
        <p class="section-sub blog-cta-desc">
          We connect your tools, automate your ops, and keep everything running so you stay on strategy.
        </p>
        <div class="blog-cta-buttons">
          <Button variant="primary" href="/complete-analysis">Start with a Complete Analysis →</Button>
          <Button variant="outline" href="/services">View All Services</Button>
        </div>
        <a href="/how-we-work" style="color: var(--color-primary); font-size: var(--font-size-base); display: inline-flex; align-items: center; gap: 6px; margin-top: 8px;">See how we work →</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-container { max-width: 720px; }

  .back-link {
    display: inline-block;
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-text); text-decoration: none; }

  .blog-header { margin-bottom: 48px; }

  .blog-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

  .blog-title {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .blog-meta {
    font-size: 14px;
    color: var(--color-muted);
  }

  /* Prose styling for MDX content */
  .blog-content :global(h2) {
    font-size: 24px;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .blog-content :global(h3) {
    font-size: 20px;
    font-weight: 700;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  .blog-content :global(p) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .blog-content :global(li) { margin-bottom: 8px; }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 20px;
    margin: 28px 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .blog-content :global(code) {
    font-size: 14px;
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: var(--radius-xs);
    border: 1px solid var(--color-border);
  }

  .blog-content :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .blog-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .blog-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }

  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 15px;
  }

  .blog-content :global(th) {
    text-align: left;
    font-weight: 700;
    padding: 10px 12px;
    border-bottom: 2px solid var(--color-border);
    font-size: 14px;
  }

  .blog-content :global(td) {
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .blog-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .updated-date { font-style: italic; }

  .blog-hero-image {
    width: 100%;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    margin-bottom: 40px;
  }

  .blog-cta { background: var(--color-surface); }

  .blog-cta-inner { text-align: center; }

  .blog-cta-title { font-size: clamp(22px, 3vw, 30px); }

  .blog-cta-desc {
    margin: 12px auto 28px;
    max-width: 480px;
  }

  .blog-cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .blog-article { padding-top: 80px; }
</style>

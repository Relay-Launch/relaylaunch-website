---
/**
 * BaseLayout - minimal HTML shell used by all page layouts.
 * Provides <html>, <head> (with SEO), <body>, and global styles.
 * Does NOT include Nav/Footer - that's the responsibility of the
 * consuming layout (e.g. Layout.astro or BlogPostLayout.astro).
 */
import SEO from '../seo/SEO.astro';
import '../../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean;
}

const { title, description, ogImage, ogType, canonicalUrl, jsonLd, breadcrumbs, noindex } = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Initialize theme from localStorage or system preference (no flash)
      (function () {
        var t = localStorage.getItem("colorTheme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    {isProd && gaId && (
      <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} async></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
    <SEO title={title} description={description} ogImage={ogImage} ogType={ogType} canonicalUrl={canonicalUrl} jsonLd={jsonLd} breadcrumbs={breadcrumbs} noindex={noindex} />
  </head>
  <body>
    <slot />
    <script is:inline>
      // Scroll-reveal: observe .reveal and .reveal-stagger elements
      (function() {
        if (!('IntersectionObserver' in window)) {
          // Fallback: show everything immediately
          document.querySelectorAll('.reveal,.reveal-stagger').forEach(function(el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal,.reveal-stagger').forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
    <!-- Cal.com embed: scheduling widget for discovery calls (lazy-loaded on interaction) -->
    <script is:inline>
      (function() {
        // Only load Cal.com on pages that have scheduling links
        if (!document.querySelector('[data-cal-link]')) return;
        var calLoaded = false;
        function loadCal() {
          if (calLoaded) return;
          calLoaded = true;
          (function (C, A, L) { var p = function (a, ar) { a.q.push(ar); }; var d = C.document; C.Cal = C.Cal || function () { var cal = C.Cal; var ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { var api = function () { p(api, arguments); }; var namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
          Cal("init", {origin:"https://cal.com"});
          var calTheme = document.documentElement.classList.contains("dark") ? "dark" : "light";
          Cal("ui", {
            theme: calTheme,
            styles: { branding: { brandColor: "#007AFF" } },
            hideEventTypeDetails: false,
          });
        }
        // Load on first interaction with a Cal link, or after idle
        document.addEventListener('click', function(e) {
          if (e.target && e.target.closest && e.target.closest('[data-cal-link]')) loadCal();
        }, { once: true, passive: true });
        // Fallback: load after page is idle (3s)
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadCal, { timeout: 3000 });
        } else {
          setTimeout(loadCal, 3000);
        }
      })();
    </script>

    {isProd && gaId && (
      <script is:inline>
        // CTA click tracking via optimized event delegation
        document.addEventListener('click', function(e) {
          // Early exit if gtag not available
          if (typeof gtag !== 'function') return;

          var target = e.target;
          if (!(target instanceof Element)) return;

          var link = target.closest('a[href]');
          if (!link) return;

          var href = link.getAttribute('href');
          if (!href) return;

          // Track primary CTA clicks
          if (href === '/contact' || href === '/intake') {
            gtag('event', 'cta_click', {
              event_category: 'engagement',
              event_label: link.textContent.trim(),
              link_url: href,
            });
          }
          // Track lead magnet download (startsWith is faster than includes)
          else if (href.startsWith('/lead-magnets/')) {
            gtag('event', 'lead_magnet_download', {
              event_category: 'conversion',
              event_label: href,
            });
          }

          // Track Cal.com scheduling clicks
          var calEl = target.closest('[data-cal-link]');
          if (calEl) {
            gtag('event', 'schedule_click', {
              event_category: 'conversion',
              event_label: calEl.textContent.trim(),
              link_url: calEl.getAttribute('data-cal-link'),
            });
          }
        }, { passive: true });

        // Form submission tracking via event delegation
        document.addEventListener('submit', function(e) {
          if (typeof gtag !== 'function') return;
          var form = e.target;

          if (form.id === 'lead-magnet-form') {
            gtag('event', 'lead_magnet_submit', {
              event_category: 'conversion',
              event_label: 'digital-readiness-assessment',
            });
          }

          if (form.id === 'contact-form') {
            gtag('event', 'contact_form_submit', {
              event_category: 'conversion',
              event_label: 'contact',
            });
          }
        }, { passive: true });
      </script>
    )}
  </body>
</html>

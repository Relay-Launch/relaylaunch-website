---
/**
 * BaseLayout — minimal HTML shell used by all page layouts.
 * Provides <html>, <head> (with SEO), <body>, and global styles.
 * Does NOT include Nav/Footer — that's the responsibility of the
 * consuming layout (e.g. Layout.astro or BlogPostLayout.astro).
 */
import SEO from '../seo/SEO.astro';
import '../../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage, ogType, canonicalUrl, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      function initTheme() {
        const colorTheme = localStorage.getItem("colorTheme");
        if (!colorTheme) {
          if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
            localStorage.setItem("colorTheme", "dark");
          } else {
            document.documentElement.classList.remove("dark");
            localStorage.setItem("colorTheme", "light");
          }
        } else if (colorTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else if (colorTheme === "light") {
          document.documentElement.classList.remove("dark");
        }
      }
      initTheme();
      document.addEventListener("astro:after-swap", initTheme);
    </script>
    <SEO title={title} description={description} ogImage={ogImage} ogType={ogType} canonicalUrl={canonicalUrl} jsonLd={jsonLd} />
  </head>
  <body>
    <slot />
  </body>
</html>

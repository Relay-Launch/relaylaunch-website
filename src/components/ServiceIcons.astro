---
/**
 * ServiceIcons.astro
 * Inline SVG icons for each RelayLaunch service tier.
 * Brand colors only: Navy #0F172A, Blue #007AFF, White #FFFFFF, Gray #F8FAFC.
 *
 * Usage:
 *   import ServiceIcons from '@/components/ServiceIcons.astro';
 *   Then use the individual SVGs by class or slot:
 *   <ServiceIcons icon="complete-analysis" />
 */
export interface Props {
  icon: 'complete-analysis' | 'launch' | 'run' | 'scale';
  size?: number;
}

const { icon, size = 32 } = Astro.props;
---

{icon === 'complete-analysis' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class="service-icon">
    <!-- Magnifying glass with chart bars -->
    <rect x="4" y="18" width="4" height="6" rx="1" fill="#007AFF" opacity="0.6" />
    <rect x="9" y="14" width="4" height="10" rx="1" fill="#007AFF" opacity="0.8" />
    <rect x="14" y="10" width="4" height="14" rx="1" fill="#007AFF" />
    <circle cx="11" cy="13" r="8" stroke="#0F172A" stroke-width="2.5" fill="none" />
    <line x1="17" y1="19" x2="26" y2="28" stroke="#0F172A" stroke-width="2.5" stroke-linecap="round" />
  </svg>
)}

{icon === 'launch' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class="service-icon">
    <!-- Rocket / upward launch -->
    <path d="M16 4 L20 14 L16 12 L12 14 Z" fill="#0F172A" />
    <path d="M12 14 L14 22 L16 19 L18 22 L20 14 L16 12 Z" fill="#007AFF" />
    <path d="M10 18 L12 14 L11 20 Z" fill="#0F172A" opacity="0.5" />
    <path d="M22 18 L20 14 L21 20 Z" fill="#0F172A" opacity="0.5" />
    <path d="M14 22 L13 28 L16 25 L19 28 L18 22 L16 19 Z" fill="#007AFF" opacity="0.5" />
  </svg>
)}

{icon === 'run' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class="service-icon">
    <!-- Gear with refresh arrow -->
    <circle cx="16" cy="16" r="6" stroke="#0F172A" stroke-width="2.5" fill="none" />
    <circle cx="16" cy="16" r="2.5" fill="#007AFF" />
    <!-- Gear teeth -->
    <rect x="14.5" y="2" width="3" height="5" rx="1" fill="#0F172A" />
    <rect x="14.5" y="25" width="3" height="5" rx="1" fill="#0F172A" />
    <rect x="2" y="14.5" width="5" height="3" rx="1" fill="#0F172A" />
    <rect x="25" y="14.5" width="5" height="3" rx="1" fill="#0F172A" />
    <rect x="5.5" y="5.5" width="3" height="5" rx="1" fill="#0F172A" transform="rotate(-45 7 8)" />
    <rect x="23.5" y="21.5" width="3" height="5" rx="1" fill="#0F172A" transform="rotate(-45 25 24)" />
    <rect x="5.5" y="21.5" width="3" height="5" rx="1" fill="#0F172A" transform="rotate(45 7 24)" />
    <rect x="23.5" y="5.5" width="3" height="5" rx="1" fill="#0F172A" transform="rotate(45 25 8)" />
    <!-- Refresh arrow overlay -->
    <path d="M22 10 A8 8 0 0 1 24 16" stroke="#007AFF" stroke-width="2" stroke-linecap="round" fill="none" />
    <path d="M24 16 L22 13 L26 13 Z" fill="#007AFF" />
  </svg>
)}

{icon === 'scale' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class="service-icon">
    <!-- Ascending bar chart with growth arrow -->
    <rect x="3" y="22" width="5" height="6" rx="1" fill="#0F172A" opacity="0.4" />
    <rect x="10" y="17" width="5" height="11" rx="1" fill="#0F172A" opacity="0.6" />
    <rect x="17" y="12" width="5" height="16" rx="1" fill="#007AFF" opacity="0.8" />
    <rect x="24" y="6" width="5" height="22" rx="1" fill="#007AFF" />
    <!-- Growth arrow -->
    <line x1="5" y1="20" x2="27" y2="5" stroke="#0F172A" stroke-width="2" stroke-linecap="round" />
    <path d="M27 5 L22 6 L26 10 Z" fill="#0F172A" />
  </svg>
)}

<style>
  .service-icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>

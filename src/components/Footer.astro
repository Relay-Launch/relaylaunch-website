---
import LinkedInIcon from "@tabler/icons/outline/brand-linkedin.svg";
import GitHubIcon from "@tabler/icons/outline/brand-github.svg";

const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand-link" aria-label="RelayLaunch home">
        <span class="brand-relay">Relay</span><span class="brand-arrow">&#x25BA;</span><span class="brand-launch">Launch</span>
      </a>
      <p class="footer-tagline">Launch your digital infrastructure,<br />without pausing your business.</p>
      <p class="footer-location">Watertown, MA · Serving Boston &amp; the Northeast</p>
      <a href="mailto:hello@relaylaunch.com" class="footer-email">hello@relaylaunch.com</a>
      <div class="footer-social" id="footer-social">
        <a href="https://www.linkedin.com/company/relaylaunch" target="_blank" rel="noopener" aria-label="RelayLaunch on LinkedIn" class="social-link social-stagger">
          <LinkedInIcon class="social-icon" />
        </a>
        <a href="https://github.com/Relay-Launch" target="_blank" rel="noopener" aria-label="RelayLaunch on GitHub" class="social-link social-stagger">
          <GitHubIcon class="social-icon" />
        </a>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-col">
        <p class="footer-col-label">Services</p>
        <ul role="list">
          <li><a href="/complete-analysis">Complete Analysis</a></li>
          <li><a href="/services#launch">Launch</a></li>
          <li><a href="/services#run">Run</a></li>
          <li><a href="/services#scale">Scale</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-label">Quick Links</p>
        <ul role="list">
          <li><a href="/services">Services</a></li>
          <li><a href="/how-we-work">How We Work</a></li>
          <li><a href="/case-studies">Case Studies</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-label">Company</p>
        <ul role="list">
          <li><a href="/about">About</a></li>
          <li><a href="/intake">Client Intake</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {year} RelayLaunch LLC. Veteran-Owned.</p>
      <div class="footer-bottom-right">
        <nav class="footer-legal" aria-label="Legal links">
          <a href="/privacy">Privacy Policy</a>
          <span class="footer-legal-sep">·</span>
          <a href="/terms">Terms of Service</a>
        </nav>
        <span class="footer-badge">USMC · Serving Small Business</span>
      </div>
    </div>
  </div>

  <div class="footer-signature">
    <div class="container footer-signature-inner">
      <p class="signature-text">
        Designed &amp; built by <a href="/about" class="signature-link"><span class="signature-brand">Relay</span><span class="signature-arrow">&#x25BA;</span><span class="signature-brand">Launch</span></a> <span class="signature-sep">·</span> Our own infrastructure, launched.
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-navy);
    margin-top: 0;
    border-top: 2px solid var(--color-primary);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    padding: 56px 24px 48px;
  }

  .brand-link {
    display: inline-block;
    font-size: 20px;
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.5px;
    transition: opacity 0.15s ease;
  }

  .brand-link:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .brand-relay, .brand-launch { color: var(--color-white); }
  .brand-arrow { color: var(--color-primary); margin: 0 1px; transition: transform 0.2s ease; }
  .brand-link:hover .brand-arrow { transform: translateX(1px); }

  .footer-tagline {
    font-size: 14px;
    color: color-mix(in srgb, var(--color-white) 65%, transparent);
    margin-top: 14px;
    line-height: 1.6;
  }

  .footer-location {
    font-size: 13px;
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
    margin-top: 10px;
  }

  .footer-email {
    display: inline-block;
    font-size: 13px;
    color: color-mix(in srgb, var(--color-white) 55%, transparent);
    text-decoration: none;
    margin-top: 6px;
    transition: color 0.15s;
  }

  .footer-email:hover {
    color: var(--color-white);
    text-decoration: none;
  }

  .footer-social {
    display: flex;
    gap: 12px;
    margin-top: 18px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--color-white) 15%, transparent);
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-white);
    border-color: color-mix(in srgb, var(--color-white) 40%, transparent);
    background: color-mix(in srgb, var(--color-white) 8%, transparent);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .social-icon {
    width: 18px;
    height: 18px;
  }

  .footer-nav {
    display: flex;
    gap: 48px;
  }

  .footer-col-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
    margin-bottom: 14px;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .footer-col a {
    font-size: 14px;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--color-white);
    text-decoration: none;
  }

  .footer-bottom {
    border-top: 1px solid color-mix(in srgb, var(--color-white) 10%, transparent);
    padding: 18px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-legal a {
    font-size: 12px;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-legal a:hover {
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
    text-decoration: none;
  }

  .footer-legal-sep {
    font-size: 12px;
    color: color-mix(in srgb, var(--color-white) 20%, transparent);
  }

  .footer-bottom p {
    font-size: 13px;
    color: color-mix(in srgb, var(--color-white) 45%, transparent);
    margin: 0;
  }

  .footer-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-primary);
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--primary) 8%, transparent);
  }

  /* ── Footer signature strip ── */
  .footer-signature {
    border-top: 1px solid color-mix(in srgb, var(--color-white) 6%, transparent);
    padding: 14px 0;
  }

  .footer-signature-inner {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .signature-text {
    font-size: 11px;
    letter-spacing: 0.3px;
    color: color-mix(in srgb, var(--color-white) 28%, transparent);
    margin: 0;
    transition: color 0.3s ease;
  }

  .footer-signature:hover .signature-text {
    color: color-mix(in srgb, var(--color-white) 50%, transparent);
  }

  .signature-link {
    text-decoration: none;
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .signature-link:hover {
    color: var(--color-white);
    text-decoration: none;
  }

  .footer-signature:hover .signature-link {
    color: color-mix(in srgb, var(--color-white) 65%, transparent);
  }

  .signature-arrow {
    color: var(--color-primary);
    margin: 0 1px;
    font-size: 10px;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .signature-link:hover .signature-arrow {
    opacity: 1;
  }

  .signature-sep {
    color: color-mix(in srgb, var(--color-white) 15%, transparent);
    margin: 0 2px;
  }

  /* ── Social icon stagger animation ── */
  .social-stagger {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .social-stagger.social-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .social-stagger {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 40px 16px 32px;
    }
    .footer-nav {
      flex-wrap: wrap;
      gap: 28px;
    }
    .footer-bottom-inner {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
    }
    .footer-bottom-right {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .footer-signature {
      padding: 12px 16px;
    }
    .signature-text {
      text-align: center;
      line-height: 1.5;
    }
  }
</style>

<script>
  const footerSocial = document.getElementById('footer-social');
  if (footerSocial) {
    const icons = footerSocial.querySelectorAll('.social-stagger');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      icons.forEach((icon) => icon.classList.add('social-visible'));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            icons.forEach((icon, i) => {
              setTimeout(() => {
                icon.classList.add('social-visible');
              }, i * 100);
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      observer.observe(footerSocial);
    }
  }
</script>

# Lead magnet webhook (receives name + email JSON on form submission)
PUBLIC_LEAD_MAGNET_WEBHOOK_URL=https://your-webhook-url.example.com

# Client intake form URL (external form link)
PUBLIC_INTAKE_FORM_URL=https://your-intake-form-url.example.com

# Google Analytics 4 Measurement ID (only loaded in production builds)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
